.fridge-section {
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: var(--radius-xl, 52rpx);
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.94) 0, rgba(255, 255, 255, 0) 170rpx),
    linear-gradient(180deg, var(--ice-50, #f5fcff) 0%, var(--ice-100, #e4f7ff) 100%);
  box-shadow:
    inset 0 10rpx 20rpx rgba(255, 255, 255, 0.94),
    inset 0 -16rpx 28rpx rgba(56, 166, 215, 0.16),
    var(--shadow-ice);
}

.fridge-drawer {
  border: 3rpx solid rgba(255, 255, 255, 0.76);
  border-radius: var(--radius-lg, 38rpx);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(199, 237, 252, 0.44));
  box-shadow:
    inset 0 6rpx 14rpx rgba(255, 255, 255, 0.94),
    inset 0 -8rpx 16rpx rgba(56, 166, 215, 0.12);
}

.fridge-glass-card {
  border: 3rpx solid rgba(255, 255, 255, 0.8);
  border-radius: var(--radius-lg, 38rpx);
  background:
    linear-gradient(120deg, rgba(255, 255, 255, 0.42) 0, rgba(255, 255, 255, 0.08) 38%, rgba(255, 255, 255, 0) 39%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(199, 237, 252, 0.48));
  box-shadow:
    inset 0 6rpx 16rpx rgba(255, 255, 255, 0.94),
    0 10rpx 24rpx rgba(56, 166, 215, 0.14);
}

.fridge-glass-line {
  height: 3rpx;
  border-radius: var(--radius-pill, 999rpx);
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.92), rgba(145, 212, 236, 0.20));
}

.fridge-mascot {
  position: relative;
  width: 76rpx;
  height: 82rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 25rpx 25rpx 21rpx 21rpx;
  background: linear-gradient(180deg, #f7fff8 0%, #bdefd2 100%);
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.86),
    0 8rpx 18rpx rgba(21, 154, 91, 0.18);
}

.fridge-mascot::before {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 35rpx;
  height: 3rpx;
  border-radius: var(--radius-pill, 999rpx);
  background: rgba(8, 122, 73, 0.18);
}

.fridge-mascot::after {
  content: "";
  position: absolute;
  right: 10rpx;
  top: 14rpx;
  width: 8rpx;
  height: 26rpx;
  border-radius: var(--radius-pill, 999rpx);
  background: rgba(8, 122, 73, 0.35);
}

.fridge-mascot-face {
  position: absolute;
  left: 19rpx;
  top: 20rpx;
  width: 38rpx;
  height: 18rpx;
  border-bottom: 4rpx solid var(--text-main, #24352f);
  border-radius: 0 0 999rpx 999rpx;
}
