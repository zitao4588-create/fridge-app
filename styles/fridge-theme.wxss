.fridge-section {
  border: 2rpx solid var(--color-line-ice, rgba(103, 188, 232, 0.18));
  border-radius: var(--radius-lg, 36rpx);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(221, 244, 255, 0.74));
  box-shadow:
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.9),
    inset 0 -8rpx 20rpx rgba(80, 150, 190, 0.1),
    var(--shadow-ice, 0 10rpx 28rpx rgba(92, 160, 190, 0.18));
}

.fridge-drawer {
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: var(--radius-md, 28rpx);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(184, 230, 245, 0.42));
  box-shadow:
    inset 0 4rpx 10rpx rgba(255, 255, 255, 0.9),
    inset 0 -6rpx 14rpx rgba(82, 150, 180, 0.12);
}

.fridge-glass-card {
  border: 2rpx solid rgba(255, 255, 255, 0.76);
  border-radius: var(--radius-lg, 36rpx);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(221, 244, 255, 0.56)),
    linear-gradient(90deg, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0));
  box-shadow:
    inset 0 4rpx 12rpx rgba(255, 255, 255, 0.9),
    var(--shadow-ice, 0 10rpx 28rpx rgba(90, 166, 196, 0.16));
}

.fridge-glass-line {
  height: 2rpx;
  border-radius: var(--radius-pill, 999rpx);
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.92), rgba(100, 181, 246, 0.18));
}

.fridge-mascot {
  position: relative;
  width: 76rpx;
  height: 82rpx;
  border: 3rpx solid rgba(36, 169, 107, 0.16);
  border-radius: 24rpx 24rpx 20rpx 20rpx;
  background: linear-gradient(180deg, #dff8ee 0%, #b9efd7 100%);
  box-shadow:
    inset 0 3rpx 8rpx rgba(255, 255, 255, 0.86),
    0 8rpx 18rpx rgba(88, 201, 139, 0.2);
}

.fridge-mascot::before {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 35rpx;
  height: 3rpx;
  border-radius: var(--radius-pill, 999rpx);
  background: rgba(36, 169, 107, 0.2);
}

.fridge-mascot::after {
  content: "";
  position: absolute;
  right: 10rpx;
  top: 14rpx;
  width: 8rpx;
  height: 26rpx;
  border-radius: var(--radius-pill, 999rpx);
  background: rgba(36, 169, 107, 0.38);
}

.fridge-mascot-face {
  position: absolute;
  left: 19rpx;
  top: 20rpx;
  width: 38rpx;
  height: 18rpx;
  border-bottom: 4rpx solid #24352f;
  border-radius: 0 0 999rpx 999rpx;
}
