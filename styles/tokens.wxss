page {
  /* Scene */
  --cream-bg: #fff6e8;
  --cream-bg-2: #fffaf0;
  --cream-surface: #fffef8;
  --cream-surface-2: #ffffff;
  --cream-line: #eadbc4;

  /* Semantic soft accents */
  --brand-mint: #28B978;
  --brand-mint-deep: #087A49;
  --brand-mint-soft: #EAF8EE;

  --ice-bg: #F2FBFF;
  --ice-soft: #DDF4FF;
  --ice-mid: #A9DDF1;
  --ice-strong: #3AAFD8;
  --ice-ink: #1F6D89;

  --honey-bg: #FFF5DC;
  --honey-soft: #FFE7B2;
  --honey-mid: #FFC76B;
  --honey: #FFB23E;
  --honey-deep: #B96A12;

  --coral-bg: #FFECE6;
  --coral: #F36C5B;
  --coral-deep: #C94238;

  /* Brand mint */
  --mint-50: var(--brand-mint-soft);
  --mint-100: var(--brand-mint-soft);
  --mint-200: #ccefd9;
  --mint-300: #8fdcb3;
  --mint-500: var(--brand-mint);
  --mint-600: var(--brand-mint-deep);
  --mint-700: var(--brand-mint-deep);

  /* Ice fridge */
  --ice-50: var(--ice-bg);
  --ice-100: var(--ice-soft);
  --ice-200: var(--ice-mid);
  --ice-300: #78c5e2;
  --ice-500: var(--ice-strong);
  --ice-700: var(--ice-ink);

  /* Honey CTA */
  --honey-100: var(--honey-bg);
  --honey-300: var(--honey-mid);
  --honey-500: var(--honey);
  --honey-700: var(--honey-deep);

  /* Coral danger */
  --coral-100: var(--coral-bg);
  --coral-400: var(--coral);
  --coral-600: var(--coral-deep);

  /* AI and saved recipes */
  --ai-lilac-bg: #F2EFFF;
  --ai-lilac: #7C62C7;
  --ai-lilac-deep: #5D46A3;
  --ai-100: var(--ai-lilac-bg);
  --ai-300: #d8cffb;
  --ai-500: var(--ai-lilac);
  --ai-700: var(--ai-lilac-deep);

  /* Text */
  --text-main: #253730;
  --text-sub: #6f7c74;
  --text-light: #647264;   /* 提升空态/浅字对比（原 #9aa9a1 不达标） */
  --text-inverse: #ffffff;

  /* Neutral 中性操作（编辑等非语义动作，替代误用的冰蓝） */
  --neutral-soft: #eef0ec;
  --neutral-ink: #4d5a52;

  /* Material shadows */
  --shadow-soft: 0 10rpx 22rpx rgba(135, 105, 64, 0.08);
  --shadow-card: 0 12rpx 26rpx rgba(135, 105, 64, 0.09);
  --shadow-toy: 0 16rpx 32rpx rgba(135, 105, 64, 0.10);
  --shadow-float: 0 20rpx 46rpx rgba(37, 55, 48, 0.12);
  --shadow-ice: 0 14rpx 30rpx rgba(58, 175, 216, 0.12);
  --shadow-button-green: 0 8rpx 16rpx rgba(40, 185, 120, 0.16);
  --shadow-button-honey: 0 8rpx 16rpx rgba(255, 178, 62, 0.16);
  --shadow-button-ai: 0 8rpx 16rpx rgba(124, 98, 199, 0.14);
  --shadow-warning: 0 6rpx 14rpx rgba(255, 178, 62, 0.14);

  /* Rounded toy geometry */
  --radius-xs: 12rpx;
  --radius-sm: 18rpx;
  --radius-md: 28rpx;
  --radius-lg: 38rpx;
  --radius-xl: 52rpx;
  --radius-xxl: 68rpx;
  --radius-pill: 999rpx;

  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 40rpx;
  --font-xxl: 48rpx;

  /* ===== 高级质感升级（轻奢黏土） ===== */
  /* 渐变 */
  --grad-mint: linear-gradient(135deg, #34c785 0%, #1fa368 100%);
  --grad-honey: linear-gradient(135deg, #ffc766 0%, #ff9f45 100%);
  --grad-card: linear-gradient(180deg, #ffffff 0%, #fffdf6 100%);
  --grad-hero: linear-gradient(135deg, #eaf8ee 0%, #fff6e8 100%);

  /* 黏土阴影 + 内高光 */
  --shadow-1: 0 6rpx 16rpx rgba(124, 138, 112, 0.10), 0 2rpx 4rpx rgba(124, 138, 112, 0.05);
  --shadow-2: 0 14rpx 34rpx rgba(124, 138, 112, 0.16);
  --shadow-mint: 0 10rpx 22rpx rgba(40, 185, 120, 0.26);
  --shadow-honey: 0 10rpx 22rpx rgba(255, 160, 70, 0.26);
  --shadow-press: 0 3rpx 8rpx rgba(124, 138, 112, 0.12);
  --hi-inset: inset 0 2rpx 0 rgba(255, 255, 255, 0.75);

  /* 分区彩色身份：tint 底 / accent 强调 / ink 文字 */
  --zone-cold-tint: #ecf6ff;
  --zone-cold-accent: #5bb8dd;
  --zone-cold-ink: #1f6d89;
  --zone-freeze-tint: #eaf0ff;
  --zone-freeze-accent: #7c9be0;
  --zone-freeze-ink: #3a52a3;
  --zone-door-tint: #f1ece3;     /* 暖棕：避开蜜橙(临期)撞色 */
  --zone-door-accent: #bfa074;
  --zone-door-ink: #7d5f38;
  --zone-produce-tint: #e9f8ee;
  --zone-produce-accent: #34c785;
  --zone-produce-ink: #087a49;
  --zone-temp-tint: #f1eefa;
  --zone-temp-accent: #9b86d6;
  --zone-temp-ink: #5d46a3;
}
