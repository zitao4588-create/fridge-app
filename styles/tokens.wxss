page {
  /* Scene */
  --cream-bg: #fff4de;
  --cream-bg-2: #fff9ea;
  --cream-surface: #fffef8;
  --cream-line: #f1dec0;

  /* Brand mint */
  --mint-50: #effcf3;
  --mint-100: #ddf8e8;
  --mint-200: #bdefd2;
  --mint-300: #8fe1b3;
  --mint-500: #35bf7a;
  --mint-600: #159a5b;
  --mint-700: #087a49;

  /* Ice fridge */
  --ice-50: #f5fcff;
  --ice-100: #e4f7ff;
  --ice-200: #c7edfc;
  --ice-300: #91d4ec;
  --ice-500: #38a6d7;
  --ice-700: #22789e;

  /* Honey CTA */
  --honey-100: #fff1c9;
  --honey-300: #ffd16a;
  --honey-500: #ffb13d;
  --honey-700: #c86f13;

  /* Coral danger */
  --coral-100: #ffe8df;
  --coral-400: #ff8d76;
  --coral-600: #e85242;

  /* Text */
  --text-main: #24352f;
  --text-sub: #6d7e76;
  --text-light: #a2b0aa;
  --text-inverse: #ffffff;

  /* Material shadows */
  --shadow-soft: 0 10rpx 24rpx rgba(85, 106, 75, 0.10);
  --shadow-card: 0 12rpx 28rpx rgba(82, 124, 94, 0.12);
  --shadow-toy: 0 16rpx 34rpx rgba(82, 124, 94, 0.16);
  --shadow-float: 0 22rpx 52rpx rgba(54, 76, 68, 0.18);
  --shadow-ice: 0 18rpx 38rpx rgba(56, 166, 215, 0.20);
  --shadow-button-green: 0 10rpx 20rpx rgba(21, 154, 91, 0.24);
  --shadow-button-honey: 0 10rpx 22rpx rgba(255, 177, 61, 0.28);
  --shadow-warning: 0 8rpx 18rpx rgba(255, 177, 61, 0.20);

  /* Rounded toy geometry */
  --radius-xs: 12rpx;
  --radius-sm: 18rpx;
  --radius-md: 28rpx;
  --radius-lg: 38rpx;
  --radius-xl: 52rpx;
  --radius-xxl: 68rpx;
  --radius-pill: 999rpx;

  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 40rpx;
  --font-xxl: 48rpx;

  /* Backward-compatible aliases used by older pages. */
  --color-primary: var(--mint-500);
  --color-primary-deep: var(--mint-600);
  --color-primary-light: var(--mint-100);
  --color-bg: var(--cream-bg);
  --color-bg-soft: var(--cream-bg-2);
  --color-bg-ice: var(--ice-100);
  --color-surface: rgba(255, 254, 248, 0.94);
  --color-surface-cream: rgba(255, 249, 234, 0.94);
  --color-line: rgba(241, 222, 192, 0.72);
  --color-line-ice: rgba(145, 212, 236, 0.32);
  --color-mint: var(--mint-100);
  --color-cream: var(--cream-bg);
  --color-orange: var(--honey-500);
  --color-orange-light: var(--honey-100);
  --color-peach: var(--coral-400);
  --color-peach-light: var(--coral-100);
  --color-blue-ice: var(--ice-100);
  --color-blue-ice-deep: var(--ice-500);
  --color-text-main: var(--text-main);
  --color-text-title: var(--text-main);
  --color-text-sub: var(--text-sub);
  --color-text-light: var(--text-light);
  --color-text-inverse: var(--text-inverse);
  --color-fresh: var(--mint-500);
  --color-expiring: var(--honey-500);
  --color-expired: var(--coral-600);
  --color-info: var(--ice-500);
  --color-disabled: #d8e0dc;
  --shadow-button: var(--shadow-button-green);
}
