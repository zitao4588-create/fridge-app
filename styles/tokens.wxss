page {
  --color-primary: #58c98b;
  --color-primary-deep: #1f9f73;
  --color-primary-light: #def7e9;
  --color-bg: #fff9ed;
  --color-bg-soft: #f7fff6;
  --color-bg-ice: #eef9ff;
  --color-surface: rgba(255, 255, 255, 0.9);
  --color-surface-cream: rgba(255, 250, 240, 0.92);
  --color-line: rgba(88, 201, 139, 0.13);
  --color-line-ice: rgba(103, 188, 232, 0.18);
  --color-mint: #def7e9;
  --color-cream: #fff4dc;
  --color-orange: #ffb85c;
  --color-orange-light: #fff0d6;
  --color-peach: #ff9b82;
  --color-peach-light: #ffe7e3;
  --color-blue-ice: #ddf3ff;
  --color-blue-ice-deep: #67bce8;
  --color-text-main: #24352f;
  --color-text-title: #24352f;
  --color-text-sub: #778781;
  --color-text-light: #a5b1ad;
  --color-text-inverse: #ffffff;
  --color-fresh: #58c98b;
  --color-expiring: #ffb85c;
  --color-expired: #ff7d73;
  --color-info: #67bce8;
  --color-disabled: #d8e0dc;
  --radius-xs: 12rpx;
  --radius-sm: 20rpx;
  --radius-md: 28rpx;
  --radius-lg: 36rpx;
  --radius-xl: 48rpx;
  --radius-pill: 999rpx;
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 40rpx;
  --font-xxl: 48rpx;
  --shadow-soft: 0 8rpx 20rpx rgba(82, 124, 94, 0.07);
  --shadow-card: 0 12rpx 30rpx rgba(82, 124, 94, 0.11);
  --shadow-float: 0 18rpx 46rpx rgba(82, 124, 94, 0.15);
  --shadow-button: 0 8rpx 18rpx rgba(88, 201, 139, 0.28);
  --shadow-ice: 0 10rpx 28rpx rgba(90, 166, 196, 0.16);
  --shadow-warning: 0 8rpx 20rpx rgba(255, 184, 92, 0.2);
}
