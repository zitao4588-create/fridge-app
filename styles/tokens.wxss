page {
  /* Scene */
  --cream-bg: #fff6e8;
  --cream-bg-2: #fffaf0;
  --cream-surface: #fffef8;
  --cream-surface-2: #ffffff;
  --cream-line: #eadbc4;

  /* Semantic soft accents */
  --brand-mint: #28B978;
  --brand-mint-deep: #087A49;
  --brand-mint-soft: #EAF8EE;

  --ice-bg: #F2FBFF;
  --ice-soft: #DDF4FF;
  --ice-mid: #A9DDF1;
  --ice-strong: #3AAFD8;
  --ice-ink: #1F6D89;

  --honey-bg: #FFF5DC;
  --honey-soft: #FFE7B2;
  --honey-mid: #FFC76B;
  --honey: #FFB23E;
  --honey-deep: #B96A12;

  --coral-bg: #FFECE6;
  --coral: #F36C5B;
  --coral-deep: #C94238;

  /* Brand mint */
  --mint-50: var(--brand-mint-soft);
  --mint-100: var(--brand-mint-soft);
  --mint-200: #ccefd9;
  --mint-300: #8fdcb3;
  --mint-500: var(--brand-mint);
  --mint-600: var(--brand-mint-deep);
  --mint-700: var(--brand-mint-deep);

  /* Ice fridge */
  --ice-50: var(--ice-bg);
  --ice-100: var(--ice-soft);
  --ice-200: var(--ice-mid);
  --ice-300: #78c5e2;
  --ice-500: var(--ice-strong);
  --ice-700: var(--ice-ink);

  /* Honey CTA */
  --honey-100: var(--honey-bg);
  --honey-300: var(--honey-mid);
  --honey-500: var(--honey);
  --honey-700: var(--honey-deep);

  /* Coral danger */
  --coral-100: var(--coral-bg);
  --coral-400: var(--coral);
  --coral-600: var(--coral-deep);

  /* AI and saved recipes */
  --ai-lilac-bg: #F2EFFF;
  --ai-lilac: #7C62C7;
  --ai-lilac-deep: #5D46A3;
  --ai-100: var(--ai-lilac-bg);
  --ai-300: #d8cffb;
  --ai-500: var(--ai-lilac);
  --ai-700: var(--ai-lilac-deep);

  /* Text */
  --text-main: #253730;
  --text-sub: #6f7c74;
  --text-light: #9aa9a1;
  --text-inverse: #ffffff;

  /* Material shadows */
  --shadow-soft: 0 10rpx 22rpx rgba(135, 105, 64, 0.08);
  --shadow-card: 0 12rpx 26rpx rgba(135, 105, 64, 0.09);
  --shadow-toy: 0 16rpx 32rpx rgba(135, 105, 64, 0.10);
  --shadow-float: 0 20rpx 46rpx rgba(37, 55, 48, 0.12);
  --shadow-ice: 0 14rpx 30rpx rgba(58, 175, 216, 0.12);
  --shadow-button-green: 0 8rpx 16rpx rgba(40, 185, 120, 0.16);
  --shadow-button-honey: 0 8rpx 16rpx rgba(255, 178, 62, 0.16);
  --shadow-button-ai: 0 8rpx 16rpx rgba(124, 98, 199, 0.14);
  --shadow-warning: 0 6rpx 14rpx rgba(255, 178, 62, 0.14);

  /* Rounded toy geometry */
  --radius-xs: 12rpx;
  --radius-sm: 18rpx;
  --radius-md: 28rpx;
  --radius-lg: 38rpx;
  --radius-xl: 52rpx;
  --radius-xxl: 68rpx;
  --radius-pill: 999rpx;

  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 40rpx;
  --font-xxl: 48rpx;

  /* Backward-compatible aliases used by older pages. */
  --color-primary: var(--mint-500);
  --color-primary-deep: var(--mint-600);
  --color-primary-light: var(--mint-100);
  --color-bg: var(--cream-bg);
  --color-bg-soft: var(--cream-bg-2);
  --color-bg-ice: var(--ice-100);
  --color-surface: rgba(255, 254, 248, 0.94);
  --color-surface-cream: rgba(255, 250, 240, 0.94);
  --color-line: rgba(234, 219, 196, 0.78);
  --color-line-ice: rgba(169, 221, 241, 0.34);
  --color-mint: var(--mint-100);
  --color-cream: var(--cream-bg);
  --color-orange: var(--honey-500);
  --color-orange-light: var(--honey-100);
  --color-peach: var(--coral-400);
  --color-peach-light: var(--coral-100);
  --color-blue-ice: var(--ice-100);
  --color-blue-ice-deep: var(--ice-500);
  --color-text-main: var(--text-main);
  --color-text-title: var(--text-main);
  --color-text-sub: var(--text-sub);
  --color-text-light: var(--text-light);
  --color-text-inverse: var(--text-inverse);
  --color-fresh: var(--mint-500);
  --color-expiring: var(--honey-500);
  --color-expired: var(--coral-600);
  --color-info: var(--ice-500);
  --color-ai: var(--ai-500);
  --color-ai-deep: var(--ai-700);
  --color-ai-light: var(--ai-100);
  --color-disabled: #d8e0dc;
  --shadow-button: var(--shadow-button-green);
}
