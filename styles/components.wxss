.cute-card,
.cream-card,
.fridge-card {
  border-radius: var(--radius-lg, 38rpx);
  background: var(--cream-surface, #fffef8);
}

.cute-card {
  border: 2rpx solid rgba(241, 222, 192, 0.72);
  box-shadow: var(--shadow-card);
}

.cream-card {
  border: 2rpx solid rgba(241, 222, 192, 0.72);
  background: linear-gradient(180deg, #fffef8 0%, #fff4de 100%);
  box-shadow: var(--shadow-soft);
}

.fridge-card {
  border: 3rpx solid rgba(255, 255, 255, 0.86);
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.92) 0, rgba(255, 255, 255, 0) 150rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(199, 237, 252, 0.58) 100%);
  box-shadow:
    inset 0 8rpx 16rpx rgba(255, 255, 255, 0.94),
    inset 0 -10rpx 22rpx rgba(56, 166, 215, 0.12),
    var(--shadow-ice);
}

.btn-primary,
.btn-camera,
.btn-scan,
.btn-secondary,
.btn-danger,
.btn-gummy-green,
.btn-gummy-honey,
.btn-soft-white {
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  line-height: 1;
}

.btn-primary,
.btn-camera,
.btn-gummy-green {
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #8ee7b2 0%, #35bf7a 48%, #159a5b 100%);
  color: #ffffff;
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.35),
    inset 0 -6rpx 12rpx rgba(8, 122, 73, 0.18),
    var(--shadow-button-green);
}

.btn-scan,
.btn-gummy-honey {
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffe08b 0%, #ffb13d 55%, #f48a22 100%);
  color: #ffffff;
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.35),
    inset 0 -6rpx 12rpx rgba(200, 111, 19, 0.16),
    var(--shadow-button-honey);
}

.btn-secondary,
.btn-soft-white {
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: var(--radius-pill, 999rpx);
  background: linear-gradient(180deg, #ffffff 0%, #eafbf1 100%);
  color: var(--mint-700, #087a49);
  box-shadow: 0 8rpx 18rpx rgba(82, 124, 94, 0.10);
}

.btn-danger {
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffad96 0%, #ff8d76 54%, #e85242 100%);
  color: #ffffff;
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.28),
    0 10rpx 20rpx rgba(232, 82, 66, 0.22);
}

.tag,
.tag-fresh,
.tag-expiring,
.tag-expired,
.tag-temp {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill, 999rpx);
  font-size: var(--font-sm, 24rpx);
  font-weight: 900;
  line-height: 1;
}

.tag {
  padding: 6rpx 14rpx;
  background: var(--mint-50, #effcf3);
  color: var(--mint-700, #087a49);
}

.tag-fresh {
  background: var(--mint-100, #ddf8e8);
  color: var(--mint-600, #159a5b);
}

.tag-expiring {
  background: var(--honey-100, #fff1c9);
  color: var(--honey-700, #c86f13);
}

.tag-expired {
  background: var(--coral-100, #ffe8df);
  color: var(--coral-600, #e85242);
}

.tag-temp {
  padding: 4rpx 12rpx;
  background: rgba(228, 247, 255, 0.9);
  color: var(--ice-700, #22789e);
  font-size: var(--font-xs, 20rpx);
}

.modal-card {
  border-radius: 40rpx;
  background: linear-gradient(180deg, #fffef8 0%, #fff4de 100%);
  box-shadow: var(--shadow-float);
}

.cute-empty {
  border: 2rpx dashed rgba(21, 154, 91, 0.22);
  border-radius: var(--radius-lg, 38rpx);
  background: linear-gradient(180deg, #fffef8 0%, #fff4de 100%);
  color: var(--text-sub, #6d7e76);
}

.mock-alert {
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(255, 177, 61, 0.16);
  border-radius: var(--radius-lg, 38rpx);
  background:
    radial-gradient(circle at 88% 18%, rgba(255, 209, 106, 0.22), rgba(255, 209, 106, 0) 140rpx),
    linear-gradient(135deg, #fffef8 0%, #fff1c9 100%);
  box-shadow: var(--shadow-soft);
}

.mock-alert-title {
  display: block;
  color: var(--text-main, #24352f);
  font-weight: 900;
}

.mock-alert-desc {
  display: block;
  color: #8a6a2f;
  line-height: 1.6;
}
