.cute-card,
.cream-card,
.fridge-card {
  border-radius: var(--radius-lg, 38rpx);
  background: var(--cream-surface, #fffef8);
}

.cute-card {
  border: 2rpx solid rgba(241, 222, 192, 0.72);
  box-shadow: var(--shadow-card);
}

.cream-card {
  border: 2rpx solid rgba(241, 222, 192, 0.72);
  background: linear-gradient(
    180deg,
    var(--cream-surface, #fffef8) 0%,
    var(--cream-bg, #fff6e8) 100%
  );
  box-shadow: var(--shadow-soft);
}

.fridge-card {
  border: 3rpx solid rgba(255, 255, 255, 0.86);
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.92) 0, rgba(255, 255, 255, 0) 150rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(199, 237, 252, 0.58) 100%);
  box-shadow:
    inset 0 8rpx 16rpx rgba(255, 255, 255, 0.94),
    inset 0 -10rpx 22rpx rgba(56, 166, 215, 0.12),
    var(--shadow-ice);
}

.btn-primary,
.btn-camera,
.btn-scan,
.btn-secondary,
.btn-danger,
.btn-gummy-green,
.btn-gummy-honey,
.btn-soft-white {
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  line-height: 1;
}

.btn-primary,
.btn-camera,
.btn-gummy-green {
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, var(--brand-mint-soft, #EAF8EE) 100%);
  color: var(--brand-mint-deep, #087A49);
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.58),
    inset 0 -6rpx 12rpx rgba(40, 185, 120, 0.08),
    var(--shadow-button-green);
}

.btn-scan,
.btn-gummy-honey {
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  background: linear-gradient(180deg, var(--honey-soft, #FFE7B2) 0%, var(--honey-mid, #FFC76B) 100%);
  color: #8A520E;
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.42),
    inset 0 -6rpx 12rpx rgba(185, 106, 18, 0.08),
    var(--shadow-button-honey);
}

.btn-secondary,
.btn-soft-white {
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: var(--radius-pill, 999rpx);
  background: linear-gradient(180deg, #ffffff 0%, var(--ice-100, #ddf4ff) 100%);
  color: var(--ice-700, #1f6d89);
  box-shadow: 0 8rpx 18rpx rgba(82, 124, 94, 0.10);
}

.btn-danger {
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, var(--coral-bg, #FFECE6) 100%);
  color: var(--coral-deep, #C94238);
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.52),
    0 8rpx 16rpx rgba(243, 108, 91, 0.14);
}

.tag,
.tag-fresh,
.tag-expiring,
.tag-expired,
.tag-temp {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-pill, 999rpx);
  font-size: var(--font-sm, 24rpx);
  font-weight: 800;
  line-height: 1;
}

.tag {
  padding: 6rpx 14rpx;
  background: var(--ice-100, #ddf4ff);
  color: var(--ice-700, #1f6d89);
}

.tag-fresh {
  background: var(--mint-100, #eaf8ee);
  color: var(--mint-600, #087a49);
}

.tag-expiring {
  background: var(--honey-100, #fff4d7);
  color: var(--honey-700, #c86f13);
}

.tag-expired {
  background: var(--coral-100, #ffe8df);
  color: var(--coral-600, #e85242);
}

.tag-temp {
  padding: 4rpx 12rpx;
  background: rgba(228, 247, 255, 0.9);
  color: var(--ice-700, #22789e);
  font-size: var(--font-xs, 20rpx);
}

.modal-card {
  border-radius: 40rpx;
  background: linear-gradient(
    180deg,
    var(--cream-surface, #fffef8) 0%,
    var(--cream-bg, #fff6e8) 100%
  );
  box-shadow: var(--shadow-float);
}

.cute-empty {
  border: 2rpx dashed rgba(234, 219, 196, 0.9);
  border-radius: var(--radius-lg, 38rpx);
  background: linear-gradient(
    180deg,
    var(--cream-surface, #fffef8) 0%,
    var(--cream-bg, #fff6e8) 100%
  );
  color: var(--text-sub, #6d7e76);
}

.mock-alert {
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(255, 177, 61, 0.16);
  border-radius: var(--radius-lg, 38rpx);
  background:
    radial-gradient(circle at 88% 18%, rgba(255, 178, 62, 0.22), rgba(255, 178, 62, 0) 140rpx),
    linear-gradient(135deg, var(--cream-surface, #fffef8) 0%, var(--honey-100, #fff4d7) 100%);
  box-shadow: var(--shadow-soft);
}

.mock-alert-title {
  display: block;
  color: var(--text-main, #24352f);
  font-weight: 800;
}

.mock-alert-desc {
  display: block;
  color: #8a6a2f;
  line-height: 1.6;
}
