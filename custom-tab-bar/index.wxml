<view class="tabbar">
  <view
    class="tab-item {{selected === index ? 'on' : ''}}"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <image class="tab-ic" src="{{selected === index ? item.active : item.icon}}" mode="aspectFit" />
    <text class="tab-txt">{{item.text}}</text>
  </view>
</view>
