<view class="tabbar {{hidden ? 'hidden' : ''}}">
  <view
    class="tab-item {{selected === index ? 'on' : ''}}"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
    aria-role="button"
    aria-label="{{item.text}}{{selected === index ? '，已选中' : ''}}"
  >
    <image class="tab-ic" src="{{selected === index ? item.active : item.icon}}" mode="aspectFit" aria-hidden="true" />
    <text class="tab-txt">{{item.text}}</text>
  </view>
</view>
