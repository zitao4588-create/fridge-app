.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  background: #ffffff;
  box-shadow: 0 -2rpx 16rpx rgba(124, 138, 112, 0.10);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tabbar.hidden {
  display: none;
}

.tab-item {
  flex: 1;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-ic {
  width: 54rpx;
  height: 54rpx;
}

.tab-txt {
  font-size: 24rpx;
  color: #9aa9a1;
}

.tab-item.on .tab-txt {
  color: #087a49;
  font-weight: 700;
}
