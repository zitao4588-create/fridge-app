.fridge-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 0 30rpx 18rpx;
  padding-bottom: calc(18rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
}

.fridge-tabbar-dock {
  height: 120rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  align-items: center;
  gap: 8rpx;
  padding: 12rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 46rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 249, 237, 0.96) 100%);
  box-shadow:
    inset 0 3rpx 8rpx rgba(255, 255, 255, 0.94),
    0 18rpx 46rpx rgba(82, 124, 94, 0.2);
}

.tab-item {
  position: relative;
  min-width: 0;
  height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: 34rpx;
  color: #778781;
}

.tab-item.active {
  background:
    linear-gradient(180deg, rgba(207, 245, 220, 0.98) 0%, rgba(239, 255, 245, 0.9) 100%);
  color: #1f9f73;
  box-shadow:
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.92),
    0 10rpx 22rpx rgba(88, 201, 139, 0.24);
  transform: translateY(-7rpx);
}

.tab-item-pressed {
  transform: scale(0.97);
}

.tab-icon {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: inset 0 2rpx 8rpx rgba(80, 130, 100, 0.08);
}

.tab-item.active .tab-icon {
  background: linear-gradient(180deg, #ffffff 0%, #aeecc9 100%);
  box-shadow:
    inset 0 3rpx 8rpx rgba(255, 255, 255, 0.92),
    0 10rpx 22rpx rgba(88, 201, 139, 0.24);
}

.tab-icon-mark {
  position: relative;
  color: currentColor;
}

.tab-icon.fridge .tab-icon-mark {
  width: 26rpx;
  height: 32rpx;
  border: 4rpx solid currentColor;
  border-radius: 11rpx;
}

.tab-icon.fridge .tab-icon-mark::before {
  content: "";
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  top: 12rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: currentColor;
  opacity: 0.7;
}

.tab-icon.fridge .tab-icon-mark::after {
  content: "";
  position: absolute;
  right: 3rpx;
  top: 4rpx;
  width: 4rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: currentColor;
  opacity: 0.75;
}

.tab-icon.calendar .tab-icon-mark {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
}

.tab-icon.calendar .tab-icon-mark::before {
  content: "";
  position: absolute;
  left: -4rpx;
  right: -4rpx;
  top: 6rpx;
  height: 4rpx;
  background: currentColor;
  opacity: 0.65;
}

.tab-icon.calendar .tab-icon-mark::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 15rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.tab-icon.recipe .tab-icon-mark {
  width: 32rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 18rpx 18rpx;
}

.tab-icon.recipe .tab-icon-mark::before {
  content: "";
  position: absolute;
  left: -4rpx;
  right: -4rpx;
  top: -8rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.tab-icon.recipe .tab-icon-mark::after {
  content: "";
  position: absolute;
  right: -12rpx;
  top: 2rpx;
  width: 10rpx;
  height: 10rpx;
  border: 4rpx solid currentColor;
  border-left: 0;
  border-bottom: 0;
  border-radius: 0 10rpx 0 0;
}

.tab-label {
  max-width: 100%;
  overflow: hidden;
  color: currentColor;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  text-overflow: ellipsis;
  white-space: nowrap;
}
