@import "styles/tokens.wxss";
@import "styles/components.wxss";
@import "styles/fridge-theme.wxss";

page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 2%, rgba(221, 248, 232, 0.9) 0, rgba(221, 248, 232, 0) 260rpx),
    radial-gradient(circle at 88% 8%, rgba(255, 209, 106, 0.18) 0, rgba(255, 209, 106, 0) 220rpx),
    linear-gradient(180deg, #fff9ea 0%, #fff4de 46%, #f4fff7 100%);
  color: var(--text-main, #24352f);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  border-radius: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 900;
  letter-spacing: 0;
  color: var(--color-text-title, #24352f);
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--color-text-sub, #778781);
}

.card {
  border: 2rpx solid var(--color-line, rgba(241, 222, 192, 0.72));
  border-radius: var(--radius-lg, 36rpx);
  background: var(--color-surface, rgba(255, 254, 248, 0.94));
  box-shadow: var(--shadow-card, 0 12rpx 28rpx rgba(82, 124, 94, 0.12));
}

.primary-button {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  background: linear-gradient(180deg, #8ee7b2 0%, #35bf7a 48%, #159a5b 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.35),
    inset 0 -6rpx 12rpx rgba(8, 122, 73, 0.18),
    var(--shadow-button-green, 0 10rpx 20rpx rgba(21, 154, 91, 0.24));
}

.secondary-button {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eafbf1 100%);
  color: var(--mint-700, #087a49);
  font-size: 30rpx;
  font-weight: 900;
}

.danger-button {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  background: linear-gradient(180deg, #ffad96 0%, #ff8d76 54%, #e85242 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.28),
    0 10rpx 20rpx rgba(232, 82, 66, 0.22);
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: var(--color-text-title, #24352f);
}

.input,
.textarea,
.picker-field {
  width: 100%;
  min-height: 88rpx;
  border: 2rpx solid var(--color-line, rgba(241, 222, 192, 0.72));
  border-radius: 28rpx;
  background: rgba(255, 254, 248, 0.94);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--color-text-title, #24352f);
  box-shadow: inset 0 2rpx 8rpx rgba(80, 130, 100, 0.04);
}

.textarea {
  min-height: 150rpx;
  padding-top: 20rpx;
  line-height: 1.5;
}

.picker-field {
  display: flex;
  align-items: center;
}

.muted-text {
  color: #778781;
}

.empty {
  padding: 72rpx 32rpx;
  border: 2rpx dashed rgba(21, 154, 91, 0.18);
  border-radius: var(--radius-lg, 36rpx);
  background: linear-gradient(180deg, #fffef8 0%, #fff4de 100%);
  text-align: center;
  color: var(--color-text-sub, #778781);
  font-weight: 800;
}

.status-overdue {
  background: var(--coral-100, #ffe8df);
  color: var(--coral-600, #e85242);
}

.status-critical {
  background: var(--honey-100, #fff1c9);
  color: var(--honey-700, #c86f13);
}

.status-warning {
  background: var(--honey-100, #fff1c9);
  color: var(--honey-700, #c86f13);
}

.status-soon {
  background: var(--ice-100, #e4f7ff);
  color: var(--ice-700, #22789e);
}

.status-normal {
  background: var(--mint-100, #ddf8e8);
  color: var(--mint-600, #159a5b);
}
