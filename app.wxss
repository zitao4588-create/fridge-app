@import "styles/tokens.wxss";
@import "styles/components.wxss";
@import "styles/fridge-theme.wxss";

page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 0%, rgba(221, 248, 232, 0.72), rgba(221, 248, 232, 0) 260rpx),
    linear-gradient(180deg, var(--color-bg-soft, #f7fff6) 0%, var(--color-bg, #fff9ed) 58%, #ffffff 100%);
  color: var(--color-text-main, #24352f);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  border-radius: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 900;
  letter-spacing: 0;
  color: var(--color-text-title, #24352f);
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--color-text-sub, #778781);
}

.card {
  border: 2rpx solid var(--color-line, rgba(88, 201, 139, 0.13));
  border-radius: var(--radius-lg, 36rpx);
  background: var(--color-surface, rgba(255, 255, 255, 0.9));
  box-shadow: var(--shadow-card, 0 12rpx 30rpx rgba(80, 130, 100, 0.11));
}

.primary-button {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #73dca2 0%, #1f9f73 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: var(--shadow-button, 0 8rpx 18rpx rgba(88, 201, 139, 0.28));
}

.secondary-button {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(88, 201, 139, 0.22);
  border-radius: 999rpx;
  background: #ffffff;
  color: #1f9f73;
  font-size: 30rpx;
  font-weight: 900;
}

.danger-button {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ff9b82 0%, #ff7d73 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.22);
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 900;
  color: var(--color-text-title, #24352f);
}

.input,
.textarea,
.picker-field {
  width: 100%;
  min-height: 88rpx;
  border: 2rpx solid var(--color-line, rgba(88, 201, 139, 0.13));
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--color-text-title, #24352f);
  box-shadow: inset 0 2rpx 8rpx rgba(80, 130, 100, 0.04);
}

.textarea {
  min-height: 150rpx;
  padding-top: 20rpx;
  line-height: 1.5;
}

.picker-field {
  display: flex;
  align-items: center;
}

.muted-text {
  color: #778781;
}

.empty {
  padding: 72rpx 32rpx;
  border: 2rpx dashed rgba(88, 201, 139, 0.18);
  border-radius: var(--radius-lg, 36rpx);
  background: linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  text-align: center;
  color: var(--color-text-sub, #778781);
  font-weight: 800;
}

.status-overdue {
  background: #ffe7e3;
  color: #ff7d73;
}

.status-critical {
  background: #fff0d6;
  color: #c97922;
}

.status-warning {
  background: #fff0d6;
  color: #c97922;
}

.status-soon {
  background: #ddf3ff;
  color: #3a91b6;
}

.status-normal {
  background: #def7e9;
  color: #1f9f73;
}
