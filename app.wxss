@import "styles/tokens.wxss";
@import "styles/tdesign-theme.wxss";

page {
  min-height: 100vh;
  background:
    linear-gradient(
      180deg,
      var(--cream-bg-2, #fffaf0) 0%,
      var(--cream-bg, #fff6e8) 58%,
      #fffaf0 100%
    );
  color: var(--text-main, #24352f);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  border-radius: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
}
