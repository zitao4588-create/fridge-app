@import "styles/tokens.wxss";
@import "styles/components.wxss";
@import "styles/fridge-theme.wxss";

page {
  min-height: 100vh;
  background:
    linear-gradient(
      180deg,
      var(--cream-bg-2, #fffaf0) 0%,
      var(--cream-bg, #fff6e8) 58%,
      #fffaf0 100%
    );
  color: var(--text-main, #24352f);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  border-radius: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 0;
  color: var(--color-text-title, #24352f);
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--color-text-sub, #778781);
}

.card {
  border: 2rpx solid var(--color-line, rgba(241, 222, 192, 0.72));
  border-radius: var(--radius-lg, 36rpx);
  background: var(--color-surface, rgba(255, 254, 248, 0.94));
  box-shadow: var(--shadow-card, 0 12rpx 28rpx rgba(82, 124, 94, 0.12));
}

.primary-button {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  background: linear-gradient(180deg, #ffffff 0%, var(--brand-mint-soft, #EAF8EE) 100%);
  color: var(--brand-mint-deep, #087A49);
  font-size: 30rpx;
  font-weight: 800;
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.58),
    inset 0 -6rpx 12rpx rgba(40, 185, 120, 0.08),
    var(--shadow-button-green, 0 8rpx 16rpx rgba(40, 185, 120, 0.16));
}

.secondary-button {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff 0%, var(--ice-100, #ddf4ff) 100%);
  color: var(--ice-700, #1f6d89);
  font-size: 30rpx;
  font-weight: 800;
}

.danger-button {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  background: linear-gradient(180deg, #ffffff 0%, var(--coral-bg, #FFECE6) 100%);
  color: var(--coral-deep, #C94238);
  font-size: 30rpx;
  font-weight: 800;
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.52),
    0 8rpx 16rpx rgba(243, 108, 91, 0.14);
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: var(--color-text-title, #24352f);
}

.input,
.textarea,
.picker-field {
  width: 100%;
  min-height: 88rpx;
  border: 2rpx solid var(--color-line, rgba(234, 219, 196, 0.78));
  border-radius: 28rpx;
  background: rgba(255, 254, 248, 0.94);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--color-text-title, #24352f);
  box-shadow: inset 0 2rpx 8rpx rgba(80, 130, 100, 0.04);
}

.textarea {
  min-height: 150rpx;
  padding-top: 20rpx;
  line-height: 1.5;
}

.picker-field {
  display: flex;
  align-items: center;
}

.muted-text {
  color: #778781;
}

.empty {
  padding: 72rpx 32rpx;
  border: 2rpx dashed rgba(234, 219, 196, 0.9);
  border-radius: var(--radius-lg, 36rpx);
  background: linear-gradient(
    180deg,
    var(--cream-surface, #fffef8) 0%,
    var(--cream-bg, #fff6e8) 100%
  );
  text-align: center;
  color: var(--color-text-sub, #778781);
  font-weight: 600;
}

.status-overdue {
  background: var(--coral-100, #ffe8df);
  color: var(--coral-600, #e85242);
}

.status-critical {
  background: var(--honey-100, #fff4d7);
  color: var(--honey-700, #c86f13);
}

.status-warning {
  background: var(--honey-100, #fff4d7);
  color: var(--honey-700, #c86f13);
}

.status-soon {
  background: var(--ice-100, #ddf4ff);
  color: var(--ice-700, #1f6d89);
}

.status-normal {
  background: var(--mint-100, #eaf8ee);
  color: var(--mint-600, #087a49);
}
