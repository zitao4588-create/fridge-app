<view class="page index-page">
  <view class="hero {{allItems.length > 0 ? homeRadar.levelClass : ''}}" bindtap="handleRadarTap" aria-role="button" aria-label="查看开饭雷达">
    <image class="hero-spark" src="/images/decor/sparkle.png" mode="aspectFit" aria-hidden="true" />
    <image class="hero-mascot" src="{{homeMood.mascot}}" mode="aspectFit" aria-hidden="true" />
    <view class="hero-copy">
      <view class="hero-text">
        <block wx:if="{{allItems.length > 0}}">
          <text class="hero-kicker">{{homeRadar.kicker || '开饭小雷达'}}</text>
          <text class="hero-title">{{homeRadar.title}}</text>
          <text class="hero-desc hero-target">{{homeRadar.actionText}}</text>
        </block>
        <block wx:else>
          <text class="hero-title">{{homeMood.title}}</text>
          <text class="hero-desc">{{homeMood.desc}}</text>
        </block>
      </view>
      <view wx:if="{{homeRadar.canProcess}}" class="hero-process" catchtap="handleRadarProcess" aria-role="button">
        {{homeRadar.processText}}
      </view>
      <text wx:if="{{allItems.length > 0}}" class="hero-arrow" aria-hidden="true">›</text>
    </view>
  </view>

  <view wx:if="{{allItems.length === 0}}" class="starter-card">
    <view class="starter-head">
      <view>
        <text class="starter-title">30 秒装满样板冰箱</text>
        <text class="starter-sub">先选几样常吃的，系统会自动填好品类、保质期和分区。</text>
      </view>
      <view class="starter-save {{selectedStarterKeys.length > 0 ? 'active' : ''}}" bindtap="handleStarterSave" aria-role="button">
        添加 {{selectedStarterKeys.length}}
      </view>
    </view>
    <view class="starter-grid">
      <view
        wx:for="{{starterFoods}}"
        wx:key="key"
        class="starter-chip {{item.selected ? 'selected' : ''}}"
        data-key="{{item.key}}"
        bindtap="handleStarterTap"
        aria-role="button"
      >
        <text class="starter-name">{{item.name}}</text>
        <text class="starter-meta">{{item.meta}}</text>
      </view>
    </view>
  </view>

  <view class="search-bar">
    <text class="search-ic" bindtap="handleSearchConfirm" aria-role="button" aria-label="搜索">🔍</text>
    <input
      class="search-input"
      placeholder="搜索食材名称"
      aria-label="搜索食材名称"
      confirm-type="search"
      value="{{searchKeyword}}"
      bindinput="handleSearchInput"
      bindconfirm="handleSearchConfirm"
    />
  </view>

  <view class="zone-list">
    <view class="zone-card {{zone.theme}}" wx:for="{{homeZones}}" wx:for-item="zone" wx:key="key">
      <view class="zone-head">
        <view class="zone-title-wrap">
          <text class="zone-icon">{{zone.icon}}</text>
          <text class="zone-title">{{zone.name}}</text>
          <text class="zone-temp">{{zone.temperature}}</text>
        </view>
        <view class="zone-add" data-location="{{zone.location}}" catchtap="handleZoneAdd" aria-role="button" aria-label="加食材">
          <text class="zone-add-ic" aria-hidden="true">＋</text>
          <text class="zone-add-txt">加食材</text>
        </view>
      </view>

      <view wx:if="{{zone.itemCount > 0}}" class="zone-summary">
        <text class="sum-item"><text class="sum-num">{{zone.itemCount}}</text> 库存</text>
        <text class="sum-dot">·</text>
        <text class="sum-item warning"><text class="sum-num">{{zone.expiring}}</text> 临期</text>
        <text class="sum-dot">·</text>
        <text class="sum-item danger"><text class="sum-num">{{zone.overdue}}</text> 过期</text>
      </view>

      <scroll-view wx:if="{{zone.items.length > 0}}" class="food-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="food-track">
          <view class="food-chip" wx:for="{{zone.items}}" wx:for-item="food" wx:key="_id" data-id="{{food._id}}" catchtap="handleFoodTap" aria-role="button">
            <image class="food-img" src="{{food.thumbImage || '/images/foods/default.png'}}" mode="aspectFit" aria-hidden="true" />
            <text class="food-name">{{food.name}}</text>
            <text class="food-tag {{food.bucket}}">{{food.statusLabel}}</text>
          </view>
        </view>
      </scroll-view>

      <view wx:else class="zone-empty">这一格还空着，点右上角「＋ 加食材」</view>
    </view>
  </view>

  <view class="danger-zone">
    <text class="danger-tip">清空后所有食品记录将无法恢复</text>
    <view class="danger-clear" bindtap="handleClearAll" aria-role="button">清空全部食品数据</view>
  </view>

  <view wx:if="{{noticeMessage}}" class="notice">{{noticeMessage}}</view>
</view>

<!-- 通用列表面板：分区清单 / 搜索结果 -->
<view wx:if="{{listPanelVisible}}" class="mask" bindtap="handleCloseListPanel">
  <view class="sheet" catchtap="noop">
    <view class="sheet-head">
      <view>
        <text class="sheet-title">{{listPanelTitle}}</text>
        <text class="sheet-sub">{{listPanelSubtitle}}</text>
      </view>
      <view class="sheet-close" bindtap="handleCloseListPanel" aria-role="button">关闭</view>
    </view>
    <scroll-view class="sheet-body" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:if="{{listPanelEmpty}}" class="sheet-empty">{{listPanelEmpty}}</view>
      <view wx:else>
        <view class="group" wx:for="{{listPanelGroups}}" wx:for-item="group" wx:key="category">
          <text class="group-name">{{group.category}}</text>
          <view class="list-row" wx:for="{{group.items}}" wx:for-item="food" wx:key="_id">
            <view class="list-main">
              <text class="list-name">{{food.name}}</text>
              <text class="list-meta">到期 {{food.expireDateText}}</text>
            </view>
            <text class="tag-inline {{food.bucket}}">{{food.statusHint}}</text>
            <view class="row-actions">
              <view class="row-btn" data-id="{{food._id}}" catchtap="handleEdit" aria-role="button">编辑</view>
              <view class="row-btn danger" data-id="{{food._id}}" data-name="{{food.name}}" catchtap="handleDelete" aria-role="button">删除</view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

<!-- 食品详情 -->
<view wx:if="{{foodDetailVisible}}" class="mask" bindtap="handleCloseFoodDetail">
  <view class="sheet detail" catchtap="noop">
    <image class="detail-img" src="{{selectedFood.thumbImage || '/images/foods/default.png'}}" mode="aspectFit" aria-hidden="true" />
    <text class="detail-name">{{selectedFood.name}}</text>
    <view class="detail-meta">
      <text>到期：{{selectedFood.expireDateText}}</text>
      <text class="tag-inline {{selectedFood.bucket}}">{{selectedFood.statusHint}}</text>
    </view>
    <view wx:if="{{selectedFood.note}}" class="detail-note">
      <text class="detail-note-label">备注</text>
      <text class="detail-note-text">{{selectedFood.note}}</text>
    </view>
    <view class="detail-actions">
      <view class="detail-btn" bindtap="handleEdit" aria-role="button">编辑</view>
      <view class="detail-btn danger" bindtap="handleDelete" aria-role="button">删除</view>
    </view>
  </view>
</view>
