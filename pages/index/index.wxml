<view class="page index-page">
  <view class="home-head">
    <text class="brand">冰箱小雷达</text>
    <view class="head-actions">
      <view class="head-btn" bindtap="handleOpenZoneConfig">分区</view>
      <view class="head-btn" bindtap="handleOpenSettings">设置</view>
    </view>
  </view>

  <view class="hero">
    <image class="hero-mascot" src="{{homeMood.mascot}}" mode="aspectFit" />
    <view class="hero-copy">
      <text class="hero-title">{{homeMood.title}}</text>
      <text class="hero-desc">{{homeMood.desc}}</text>
    </view>
  </view>

  <view class="stat-row">
    <view class="stat-card" data-type="total" bindtap="handleStatsTap">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-name">总库存</text>
    </view>
    <view class="stat-card warning" data-type="expiring" bindtap="handleStatsTap">
      <text class="stat-num">{{stats.expiring}}</text>
      <text class="stat-name">临期</text>
    </view>
    <view class="stat-card danger" data-type="overdue" bindtap="handleStatsTap">
      <text class="stat-num">{{stats.overdue}}</text>
      <text class="stat-name">已过期</text>
    </view>
  </view>

  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索食材名称"
      confirm-type="search"
      value="{{searchKeyword}}"
      bindinput="handleSearchInput"
      bindconfirm="handleSearchConfirm"
    />
    <view class="search-btn" bindtap="handleSearchConfirm">搜索</view>
  </view>

  <view class="zone-list">
    <view class="zone-card {{zone.theme}}" wx:for="{{homeZones}}" wx:for-item="zone" wx:key="key">
      <view class="zone-head">
        <view class="zone-title-wrap">
          <text class="zone-title">{{zone.name}}</text>
          <text class="zone-temp">{{zone.temperature}}</text>
        </view>
        <view class="zone-add" data-location="{{zone.location}}" catchtap="handleZoneAdd">＋</view>
      </view>

      <view class="zone-stats">
        <view class="zone-stat" data-key="{{zone.key}}" data-filter="total" catchtap="handleZoneStatTap">
          <text class="zone-stat-num">{{zone.itemCount}}</text>
          <text class="zone-stat-name">库存</text>
        </view>
        <view class="zone-stat warning" data-key="{{zone.key}}" data-filter="expiring" catchtap="handleZoneStatTap">
          <text class="zone-stat-num">{{zone.expiring}}</text>
          <text class="zone-stat-name">临期</text>
        </view>
        <view class="zone-stat danger" data-key="{{zone.key}}" data-filter="overdue" catchtap="handleZoneStatTap">
          <text class="zone-stat-num">{{zone.overdue}}</text>
          <text class="zone-stat-name">过期</text>
        </view>
      </view>

      <scroll-view wx:if="{{zone.items.length > 0}}" class="food-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="food-track">
          <view class="food-chip" wx:for="{{zone.items}}" wx:for-item="food" wx:key="_id" data-id="{{food._id}}" catchtap="handleFoodTap">
            <image class="food-img" src="{{food.thumbImage || '/images/foods/default.png'}}" mode="aspectFit" />
            <text class="food-name">{{food.name}}</text>
            <text class="food-tag {{food.bucket}}">{{food.statusLabel}}</text>
          </view>
        </view>
      </scroll-view>

      <view wx:else class="zone-empty">这一格还空着，点右上角 ＋ 添加</view>
    </view>
  </view>

  <view wx:if="{{noticeMessage}}" class="notice">{{noticeMessage}}</view>
</view>

<!-- 通用列表面板：分区清单 / 统计清单 / 搜索结果 -->
<view wx:if="{{listPanelVisible}}" class="mask" bindtap="handleCloseListPanel">
  <view class="sheet" catchtap="noop">
    <view class="sheet-head">
      <view>
        <text class="sheet-title">{{listPanelTitle}}</text>
        <text class="sheet-sub">{{listPanelSubtitle}}</text>
      </view>
      <view class="sheet-close" bindtap="handleCloseListPanel">关闭</view>
    </view>
    <scroll-view class="sheet-body" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:if="{{listPanelEmpty}}" class="sheet-empty">{{listPanelEmpty}}</view>
      <view wx:else>
        <view class="group" wx:for="{{listPanelGroups}}" wx:for-item="group" wx:key="category">
          <text class="group-name">{{group.category}}</text>
          <view class="list-row" wx:for="{{group.items}}" wx:for-item="food" wx:key="_id">
            <view class="list-main">
              <text class="list-name">{{food.name}} · {{food.amountText}}</text>
              <text class="list-meta">到期 {{food.expireDateText}}</text>
            </view>
            <text class="tag-inline {{food.bucket}}">{{food.statusHint}}</text>
            <view class="row-actions">
              <view class="row-btn" data-id="{{food._id}}" catchtap="handleEdit">编辑</view>
              <view class="row-btn danger" data-id="{{food._id}}" data-name="{{food.name}}" catchtap="handleDelete">删除</view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

<!-- 食品详情 -->
<view wx:if="{{foodDetailVisible}}" class="mask" bindtap="handleCloseFoodDetail">
  <view class="sheet detail" catchtap="noop">
    <image class="detail-img" src="{{selectedFood.thumbImage || '/images/foods/default.png'}}" mode="aspectFit" />
    <text class="detail-name">{{selectedFood.name}}</text>
    <view class="detail-meta">
      <text>数量：{{selectedFood.amountText}}</text>
      <text>分区：{{selectedFood.storageLocation}}</text>
      <text>到期：{{selectedFood.expireDateText}}</text>
      <text class="tag-inline {{selectedFood.bucket}}">{{selectedFood.statusHint}}</text>
    </view>
    <view class="detail-actions">
      <view class="detail-btn" bindtap="handleEdit">编辑</view>
      <view class="detail-btn danger" bindtap="handleDelete">删除</view>
    </view>
  </view>
</view>

<!-- 分区管理 -->
<view wx:if="{{zoneConfigVisible}}" class="mask" bindtap="handleCloseZoneConfig">
  <view class="sheet" catchtap="noop">
    <view class="sheet-head">
      <view>
        <text class="sheet-title">分区管理</text>
        <text class="sheet-sub">启用 / 停用分区，调整显示顺序</text>
      </view>
    </view>
    <view class="zone-config-list">
      <view class="zone-config-row" wx:for="{{zoneConfigDraft}}" wx:for-item="zone" wx:key="key">
        <view class="zc-main">
          <text class="zc-name {{zone.enabled ? '' : 'off'}}">{{zone.name}}</text>
          <text class="zc-hint">{{zone.temperature}} · {{zone.hint}}</text>
        </view>
        <view class="zc-actions">
          <view class="zc-move" data-index="{{index}}" data-dir="-1" bindtap="handleZoneMove">↑</view>
          <view class="zc-move" data-index="{{index}}" data-dir="1" bindtap="handleZoneMove">↓</view>
          <view class="zc-toggle {{zone.enabled ? 'on' : ''}}" data-index="{{index}}" bindtap="handleZoneToggle">{{zone.enabled ? '已启用' : '已停用'}}</view>
        </view>
      </view>
    </view>
    <view class="sheet-foot">
      <view class="foot-btn primary {{zoneConfigSaving ? 'disabled' : ''}}" bindtap="handleSaveZoneConfig">保存</view>
    </view>
  </view>
</view>

<!-- 设置 / 隐私 -->
<view wx:if="{{settingsVisible}}" class="mask" bindtap="handleCloseSettings">
  <view class="sheet" catchtap="noop">
    <view class="sheet-head">
      <text class="sheet-title">设置</text>
      <view class="sheet-close" bindtap="handleCloseSettings">关闭</view>
    </view>
    <view class="settings-block">
      <text class="settings-text">冰箱小雷达只保存你录入的食品信息，数据按当前微信账号隔离存储在微信云开发，仅你自己可见。</text>
      <view class="settings-link" bindtap="handleOpenPrivacy">查看隐私保护指引 ›</view>
    </view>
    <view class="foot-btn danger-outline" bindtap="handleClearAll">清空全部食品数据</view>
  </view>
</view>
