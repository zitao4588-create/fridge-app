.index-page {
  width: 100%;
  max-width: 100%;
  height: 100vh;
  min-height: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 14rpx 16rpx 18rpx;
}

.fridge-panel {
  min-height: 0;
  flex: 1 1 auto;
  display: flex;
  flex-direction: column;
  margin-top: 0;
  padding: 10rpx 12rpx 12rpx;
}

.fridge-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.fridge-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.fridge-template-stage {
  position: relative;
  overflow: hidden;
  min-height: 0;
  flex: 1 1 auto;
  margin-top: 4rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.fridge-template-content {
  position: absolute;
  left: 0;
  top: -8%;
  width: 100%;
  height: 108%;
}

.fridge-template-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.fridge-hot-zones {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.fridge-zone-markers {
  position: absolute;
  inset: 0;
  z-index: 3;
}

.fridge-hot-zone {
  position: absolute;
  overflow: hidden;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0);
  transition: background 0.16s ease, border-color 0.16s ease;
}

.fridge-hot-zone.has-items {
  border-color: rgba(15, 118, 110, 0.08);
  background: rgba(240, 253, 250, 0.04);
}

.fridge-hot-zone.is-empty {
  border-color: transparent;
}

.fridge-hot-zone:active {
  border-color: rgba(15, 118, 110, 0.45);
  background: rgba(20, 184, 166, 0.18);
}

.zone-stat-marker {
  position: absolute;
  min-width: 136rpx;
  max-width: 194rpx;
  min-height: 64rpx;
  padding: 10rpx 12rpx;
  border: 1rpx solid rgba(15, 118, 110, 0.2);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.12);
  transform: translate(-50%, -50%);
  backdrop-filter: blur(8rpx);
}

.zone-stat-marker.normal {
  background: rgba(248, 250, 252, 0.82);
  border-color: rgba(148, 163, 184, 0.28);
}

.zone-stat-marker.warning {
  background: rgba(255, 251, 235, 0.88);
  border-color: rgba(217, 119, 6, 0.26);
}

.zone-stat-marker.danger {
  background: rgba(255, 241, 242, 0.9);
  border-color: rgba(190, 18, 60, 0.28);
}

.zone-stat-name {
  display: block;
  min-width: 0;
  color: #0f172a;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.zone-stat-values {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6rpx;
  margin-top: 9rpx;
}

.zone-stat-value {
  min-width: 0;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 900;
  white-space: nowrap;
}

.zone-stat-value.total {
  color: #16a34a;
}

.zone-stat-value.warning {
  color: #d97706;
}

.zone-stat-value.danger {
  color: #be123c;
}

.zone-panel-mask {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.38);
}

.zone-panel {
  width: 100%;
  max-height: 78vh;
  overflow-y: auto;
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  padding: 28rpx;
  box-shadow: 0 -18rpx 46rpx rgba(15, 23, 42, 0.18);
}

.zone-section-panel,
.stat-section-panel {
  height: 67vh;
  max-height: 82vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.zone-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.zone-panel-head-main {
  min-width: 0;
  flex: 1;
}

.zone-panel-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #0f172a;
}

.zone-panel-subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.zone-panel-close {
  flex-shrink: 0;
  width: 120rpx;
  height: 58rpx;
  border-radius: 14rpx;
  background: #f1f5f9;
  color: #334155;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 58rpx;
}

.zone-panel-tools {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.zone-local-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.zone-local-stat {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
  height: 58rpx;
  padding: 0 18rpx;
  border: 2rpx solid transparent;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.zone-local-stat.total {
  background: #f0fdf4;
  color: #16a34a;
}

.zone-local-stat.warning {
  background: #fffbeb;
  color: #d97706;
}

.zone-local-stat.danger {
  background: #fff1f2;
  color: #be123c;
}

.zone-local-stat.active {
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.1);
}

.zone-local-stat.total.active {
  border-color: rgba(22, 163, 74, 0.45);
}

.zone-local-stat.warning.active {
  border-color: rgba(217, 119, 6, 0.45);
}

.zone-local-stat.danger.active {
  border-color: rgba(190, 18, 60, 0.42);
}

.zone-local-stat:active {
  transform: scale(0.98);
}

.zone-panel-add {
  height: 72rpx;
  border-radius: 16rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 72rpx;
}

.zone-panel-add-top {
  flex-shrink: 0;
  width: 286rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 26rpx;
  line-height: 1;
}

.zone-panel-add::after,
.zone-panel-close::after,
.zone-item-edit::after,
.zone-item-delete::after,
.search-button::after {
  border: none;
}

.zone-section-scroll {
  min-height: 0;
  flex: 1;
  margin-top: 20rpx;
}

.stat-section-scroll {
  min-height: 0;
  flex: 1;
  margin-top: 22rpx;
}

.zone-panel-empty {
  margin-top: 24rpx;
  padding: 44rpx 24rpx;
  border: 1rpx dashed #cbd5e1;
  border-radius: 18rpx;
  background: #f8fafc;
  text-align: center;
}

.zone-panel-empty-title {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.zone-panel-empty-desc {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
}

.zone-category-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 24rpx;
}

.zone-section-scroll .zone-category-list,
.zone-section-scroll .zone-panel-empty,
.stat-section-scroll .stat-item-list,
.stat-section-scroll .zone-panel-empty {
  margin-top: 0;
}

.zone-category-group {
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  overflow: hidden;
  background: #ffffff;
}

.zone-category-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  background: #f8fafc;
}

.zone-category-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #0f172a;
}

.zone-category-count {
  color: #64748b;
  font-size: 23rpx;
  font-weight: 700;
}

.zone-item-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-top: 1rpx solid #e2e8f0;
}

.zone-item-main {
  min-width: 0;
  flex: 1;
}

.zone-item-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.zone-item-name {
  min-width: 0;
  flex: 1;
  font-size: 29rpx;
  font-weight: 800;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.zone-item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 23rpx;
}

.zone-item-edit {
  flex-shrink: 0;
  width: 108rpx;
  height: 50rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #eef7f6;
  color: #0f766e;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
}

.stats-grid {
  flex: 0 0 auto;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr);
  gap: 8rpx;
  width: 100%;
  max-width: 100%;
  margin-top: 0;
}

.stat-card {
  min-width: 0;
  height: 96rpx;
  width: 100%;
  margin: 0;
  padding: 12rpx 14rpx;
  border: 1rpx solid transparent;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.stat-card.total {
  border-color: rgba(22, 163, 74, 0.2);
  background: #f0fdf4;
}

.stat-card.warning {
  border-color: rgba(217, 119, 6, 0.22);
  background: #fffbeb;
}

.stat-card.danger {
  border-color: rgba(190, 18, 60, 0.2);
  background: #fff1f2;
}

.stat-card:active {
  transform: scale(0.98);
}

.stat-label {
  display: block;
  font-size: 23rpx;
  line-height: 1;
  font-weight: 800;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 900;
  color: #0f172a;
}

.stat-value.total {
  color: #16a34a;
}

.stat-value.warning {
  color: #d97706;
}

.stat-value.danger {
  color: #be123c;
}

.search-card {
  flex: 0 0 auto;
  display: flex;
  gap: 10rpx;
  margin-top: 0;
  padding: 8rpx;
}

.search-input {
  min-width: 0;
  flex: 1;
  height: 58rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  padding: 0 20rpx;
  font-size: 25rpx;
}

.search-button {
  flex-shrink: 0;
  width: 76rpx;
  min-width: 0;
  height: 58rpx;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #0f766e;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
}

.stat-item-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.stat-item-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  background: #ffffff;
}

.stat-item-actions {
  flex-shrink: 0;
  width: 108rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.zone-item-delete {
  flex-shrink: 0;
  width: 108rpx;
  height: 50rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #fff1f2;
  color: #be123c;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
}

.notice-bar {
  position: fixed;
  z-index: 30;
  right: 20rpx;
  bottom: 22rpx;
  left: 20rpx;
  margin-top: 0;
  padding: 18rpx 22rpx;
  border: 1rpx solid #99f6e4;
  border-radius: 16rpx;
  background: #f0fdfa;
  color: #0f766e;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
}

.status-chip {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}
