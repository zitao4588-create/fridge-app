.index-page {
  position: relative;
  overflow-x: hidden;
  width: 100%;
  max-width: 100%;
  min-height: 100vh;
  padding: 20rpx 20rpx 72rpx;
  color: var(--text-main, #24352f);
  background:
    radial-gradient(circle at 12% 3%, rgba(221, 248, 232, 0.86) 0, rgba(221, 248, 232, 0) 260rpx),
    radial-gradient(circle at 90% 8%, rgba(255, 209, 106, 0.18) 0, rgba(255, 209, 106, 0) 220rpx),
    linear-gradient(180deg, #fff9ea 0%, #fff4de 56%, #f4fff7 100%);
}

.index-page button {
  margin: 0;
  padding: 0;
  line-height: 1;
}

.index-page button::after {
  border: 0;
}

.search-button:active,
.zone-config-entry:active,
.decision-sign:active,
.home-zone-add-mark:active,
.home-zone-stat:active,
.zone-add-card:active,
.zone-item-edit:active,
.zone-item-delete:active,
.detail-edit-button:active,
.detail-delete-button:active {
  transform: scale(0.98);
}

/* Top dashboard */
.home-dashboard {
  position: relative;
  overflow: hidden;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 42rpx;
  background:
    radial-gradient(circle at 84% 16%, rgba(255, 209, 106, 0.22), rgba(255, 209, 106, 0) 130rpx),
    linear-gradient(135deg, #fffef8 0%, #eefff3 100%);
  box-shadow:
    inset 0 5rpx 12rpx rgba(255, 255, 255, 0.96),
    0 16rpx 34rpx rgba(82, 124, 94, 0.14);
}

.home-dashboard::before,
.home-dashboard::after {
  content: "";
  position: absolute;
  pointer-events: none;
}

.home-dashboard::before {
  right: -38rpx;
  top: -50rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.52);
}

.home-dashboard::after {
  right: 30rpx;
  bottom: 22rpx;
  width: 66rpx;
  height: 66rpx;
  background: url("/images/decor/sparkle.png") center / contain no-repeat;
  opacity: 0.68;
}

.home-dashboard-shine {
  position: absolute;
  left: 28rpx;
  right: 92rpx;
  top: 10rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.86), rgba(255, 255, 255, 0));
}

.home-dashboard-head,
.home-hero,
.search-card,
.decision-guide {
  position: relative;
  z-index: 1;
}

.home-dashboard-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 10rpx;
}

.home-brand-lockup {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.home-brand-name {
  min-width: 0;
  overflow: hidden;
  color: var(--mint-700, #087a49);
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
  text-overflow: ellipsis;
  text-shadow:
    0 3rpx 0 #ffffff,
    0 8rpx 18rpx rgba(21, 154, 91, 0.16);
  white-space: nowrap;
}

.zone-config-entry {
  flex-shrink: 0;
  min-width: 132rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eafbf1 100%);
  color: var(--mint-700, #087a49);
  font-size: 23rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(82, 124, 94, 0.10);
}

.home-hero {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 140rpx;
  margin-top: 6rpx;
}

.home-mascot {
  flex-shrink: 0;
  width: 126rpx;
  height: 126rpx;
  filter: drop-shadow(0 12rpx 18rpx rgba(82, 124, 94, 0.15));
}

.home-speech {
  min-width: 0;
  flex: 1;
  position: relative;
  padding: 22rpx 24rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 30rpx;
  background: rgba(255, 254, 248, 0.90);
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.86),
    0 10rpx 20rpx rgba(82, 124, 94, 0.10);
}

.home-speech::before {
  content: "";
  position: absolute;
  left: -12rpx;
  top: 42rpx;
  width: 24rpx;
  height: 24rpx;
  transform: rotate(45deg);
  border-left: 3rpx solid rgba(255, 255, 255, 0.92);
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 6rpx;
  background: rgba(255, 254, 248, 0.90);
}

.home-speech-title,
.home-speech-desc {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
}

.home-speech-title {
  color: var(--text-main, #24352f);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
  white-space: nowrap;
}

.home-speech-desc {
  margin-top: 8rpx;
  color: var(--text-sub, #6d7e76);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.35;
}

/* Search */
.search-card {
  display: flex;
  gap: 10rpx;
  margin: 14rpx 0 0;
  padding: 8rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow:
    inset 0 3rpx 8rpx rgba(255, 255, 255, 0.9),
    0 8rpx 18rpx rgba(82, 124, 94, 0.09);
}

.fridge-search-card {
  z-index: 2;
  margin: 10rpx 8rpx 18rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.88) 0%, rgba(245, 252, 255, 0.78) 100%);
  box-shadow:
    inset 0 4rpx 10rpx rgba(255, 255, 255, 0.92),
    0 10rpx 20rpx rgba(56, 166, 215, 0.12);
}

.fridge-search-card + .home-zone-list {
  margin-top: 0;
}

.search-input {
  min-width: 0;
  flex: 1;
  height: 60rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 254, 248, 0.94);
  color: var(--text-main, #24352f);
  font-size: 26rpx;
  font-weight: 800;
}

.search-button {
  flex-shrink: 0;
  width: 100rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #8ee7b2 0%, #35bf7a 48%, #159a5b 100%);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  box-shadow:
    inset 0 3rpx 8rpx rgba(255, 255, 255, 0.32),
    var(--shadow-button-green, 0 10rpx 20rpx rgba(21, 154, 91, 0.24));
}

/* Add guide */
.decision-guide {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 14rpx;
}

.decision-sign {
  position: relative;
  min-width: 0;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  padding: 17rpx 18rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.84);
  border-radius: 30rpx;
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.35),
    inset 0 -6rpx 12rpx rgba(8, 122, 73, 0.08),
    0 10rpx 20rpx rgba(82, 124, 94, 0.12);
}

.decision-sign.known {
  background: linear-gradient(180deg, #ffe08b 0%, #ffb13d 58%, #f48a22 100%);
}

.decision-sign.unknown {
  background: linear-gradient(180deg, #8ee7b2 0%, #35bf7a 52%, #159a5b 100%);
}

.decision-copy {
  min-width: 0;
  flex: 1;
}

.decision-title,
.decision-desc {
  display: block;
  overflow: hidden;
  color: #ffffff;
  text-overflow: ellipsis;
}

.decision-title {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
  text-shadow: 0 2rpx 6rpx rgba(80, 66, 38, 0.18);
}

.decision-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.25;
}

.decision-pointer {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.95);
}

.decision-pointer.down {
  width: 34rpx;
  height: 52rpx;
  flex-direction: column;
}

.decision-pointer.right {
  width: 54rpx;
  height: 34rpx;
}

.pointer-line {
  border-radius: 999rpx;
  background: currentColor;
}

.decision-pointer.down .pointer-line {
  width: 6rpx;
  height: 26rpx;
}

.decision-pointer.right .pointer-line {
  width: 28rpx;
  height: 6rpx;
}

.pointer-head {
  width: 0;
  height: 0;
}

.decision-pointer.down .pointer-head {
  border-left: 11rpx solid transparent;
  border-right: 11rpx solid transparent;
  border-top: 16rpx solid currentColor;
}

.decision-pointer.right .pointer-head {
  border-top: 11rpx solid transparent;
  border-bottom: 11rpx solid transparent;
  border-left: 16rpx solid currentColor;
}

/* Fridge shell */
.fridge-panel.card {
  position: relative;
  overflow: hidden;
  margin-top: 18rpx;
  padding: 20rpx 18rpx 34rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 68rpx;
  background: linear-gradient(180deg, #f7fff8 0%, #bdefd2 100%);
  box-shadow:
    inset 0 8rpx 14rpx rgba(255, 255, 255, 0.95),
    inset 16rpx 0 24rpx rgba(21, 154, 91, 0.10),
    inset -16rpx 0 24rpx rgba(21, 154, 91, 0.08),
    0 24rpx 48rpx rgba(82, 124, 94, 0.18);
}

.fridge-panel.card::before,
.fridge-panel.card::after {
  content: "";
  position: absolute;
  pointer-events: none;
}

.fridge-panel.card::before {
  left: 18rpx;
  right: 18rpx;
  top: 16rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0));
}

.fridge-panel.card::after {
  left: 104rpx;
  right: 104rpx;
  bottom: 16rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0));
}

.fridge-panel-light,
.fridge-panel-hinge {
  position: absolute;
  pointer-events: none;
}

.fridge-panel-light {
  z-index: 0;
  left: 64rpx;
  right: 64rpx;
  top: 22rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0));
}

.fridge-panel-hinge {
  z-index: 1;
  right: 18rpx;
  top: 150rpx;
  width: 10rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(21, 154, 91, 0.16), rgba(255, 255, 255, 0.86));
}

.home-zone-list {
  position: relative;
  z-index: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 24rpx;
  padding: 46rpx 22rpx 54rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 58rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.95) 0, rgba(255, 255, 255, 0) 180rpx),
    linear-gradient(180deg, #f8fdff 0%, #ddf4ff 52%, #eafbff 100%);
  box-shadow:
    inset 0 12rpx 24rpx rgba(255, 255, 255, 0.95),
    inset 0 -18rpx 32rpx rgba(56, 166, 215, 0.16),
    var(--shadow-ice);
}

.home-zone-list::before,
.home-zone-list::after,
.fridge-shell-backlight,
.fridge-shell-top,
.fridge-shell-side,
.fridge-shell-frost,
.fridge-shell-bottom {
  position: absolute;
  pointer-events: none;
}

.home-zone-list::before {
  content: "";
  left: 62rpx;
  right: 62rpx;
  top: 22rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), #ffffff, rgba(255, 255, 255, 0));
}

.home-zone-list::after {
  content: "";
  left: 20rpx;
  top: 84rpx;
  bottom: 86rpx;
  width: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(145, 212, 236, 0.28), rgba(255, 255, 255, 0.8));
  box-shadow: 624rpx 0 0 rgba(255, 255, 255, 0.24);
}

.fridge-shell-backlight {
  z-index: 0;
  left: 44rpx;
  right: 44rpx;
  top: 54rpx;
  bottom: 54rpx;
  border-radius: 52rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.46), rgba(255, 255, 255, 0)),
    radial-gradient(circle at 50% 20%, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0) 260rpx);
}

.fridge-shell-top {
  z-index: 1;
  left: 90rpx;
  right: 90rpx;
  top: 14rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff, rgba(145, 212, 236, 0.30));
}

.fridge-shell-side {
  z-index: 1;
  top: 62rpx;
  bottom: 68rpx;
  width: 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(145, 212, 236, 0.22), rgba(255, 255, 255, 0.72));
}

.fridge-shell-side.left {
  left: 14rpx;
}

.fridge-shell-side.right {
  right: 14rpx;
}

.fridge-shell-frost {
  z-index: 3;
  height: 16rpx;
  border-radius: 0 0 18rpx 18rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(199, 237, 252, 0.22));
}

.fridge-shell-frost.frost-a {
  right: 58rpx;
  top: 258rpx;
  width: 136rpx;
}

.fridge-shell-frost.frost-b {
  left: 60rpx;
  bottom: 230rpx;
  width: 124rpx;
}

.fridge-shell-bottom {
  z-index: 1;
  left: 76rpx;
  right: 76rpx;
  bottom: 24rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(145, 212, 236, 0.28));
}

/* Fridge zones */
.home-zone-card {
  position: relative;
  z-index: 2;
  min-height: 260rpx;
  overflow: hidden;
  padding: 30rpx 22rpx 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 42rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(210, 240, 252, 0.72) 100%);
  box-shadow:
    inset 0 8rpx 18rpx rgba(255, 255, 255, 0.98),
    inset 0 -14rpx 26rpx rgba(56, 166, 215, 0.14),
    0 12rpx 26rpx rgba(56, 166, 215, 0.16);
}

.home-zone-card::before,
.home-zone-card::after {
  content: "";
  position: absolute;
  pointer-events: none;
}

.home-zone-card::before {
  left: 44rpx;
  right: 44rpx;
  top: 14rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
}

.home-zone-card::after {
  left: -16rpx;
  right: -16rpx;
  bottom: -22rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(145, 212, 236, 0.26));
}

.home-zone-card.freeze {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(198, 230, 255, 0.76) 100%);
}

.home-zone-card.produce,
.home-zone-card.door {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(197, 241, 216, 0.72) 100%);
}

.home-zone-card.temp {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(255, 225, 165, 0.68) 100%);
}

.home-zone-glass,
.home-zone-handle {
  position: absolute;
  pointer-events: none;
}

.home-zone-glass {
  z-index: 0;
  left: 12rpx;
  right: 12rpx;
  top: 12rpx;
  bottom: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 36rpx;
  background:
    linear-gradient(120deg, rgba(255, 255, 255, 0.38) 0, rgba(255, 255, 255, 0.10) 38%, rgba(255, 255, 255, 0) 39%);
}

.home-zone-handle {
  z-index: 1;
  left: 110rpx;
  right: 110rpx;
  bottom: -8rpx;
  height: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff, rgba(145, 212, 236, 0.35));
}

.home-zone-head,
.home-zone-stats,
.food-card-scroll,
.home-zone-empty {
  position: relative;
  z-index: 2;
}

.home-zone-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.home-zone-title-group {
  min-width: 0;
  flex: 1;
}

.home-zone-title-row {
  max-width: 100%;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.home-zone-title {
  min-width: 0;
  overflow: hidden;
  color: var(--text-main, #24352f);
  font-size: 34rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  text-shadow: 0 3rpx 0 rgba(255, 255, 255, 0.74);
  white-space: nowrap;
}

.home-zone-temp {
  flex-shrink: 0;
  height: 42rpx;
  display: inline-flex;
  align-items: center;
  padding: 0 16rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #91d4ec 0%, #38a6d7 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
  box-shadow:
    inset 0 3rpx 6rpx rgba(255, 255, 255, 0.28),
    0 8rpx 14rpx rgba(56, 166, 215, 0.18);
}

.home-zone-add-mark {
  flex-shrink: 0;
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.84);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #8ee7b2 0%, #35bf7a 48%, #159a5b 100%);
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 900;
  box-shadow:
    inset 0 3rpx 8rpx rgba(255, 255, 255, 0.34),
    var(--shadow-button-green);
}

.home-zone-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.home-zone-stat {
  min-width: 0;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 12rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.66);
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.home-zone-stat.total {
  background: rgba(221, 248, 232, 0.92);
  color: var(--mint-700, #087a49);
}

.home-zone-stat.warning {
  background: rgba(255, 241, 201, 0.92);
  color: var(--honey-700, #c86f13);
}

.home-zone-stat.danger {
  background: rgba(255, 232, 223, 0.92);
  color: var(--coral-600, #e85242);
}

/* Food cards */
.food-card-scroll {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.food-card-track {
  display: flex;
  gap: 18rpx;
  padding: 2rpx 4rpx 8rpx;
}

.food-card {
  flex: 0 0 auto;
  width: 180rpx;
  min-height: 218rpx;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.95);
  border-radius: 34rpx;
  background: #fffef8;
  box-shadow:
    inset 0 4rpx 8rpx rgba(255, 255, 255, 0.9),
    0 12rpx 24rpx rgba(82, 124, 94, 0.14);
}

.food-image-wrap {
  height: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at 50% 30%, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0) 58%),
    linear-gradient(180deg, #f8fffa 0%, #ffffff 100%);
}

.food-image {
  width: 118rpx;
  height: 118rpx;
}

.food-image.photo {
  width: 100%;
  height: 100%;
}

.food-info {
  padding: 14rpx 14rpx 16rpx;
  background: #ffffff;
}

.food-info.normal {
  background: #f8fffa;
}

.food-info.warning {
  background: #fff7e5;
}

.food-info.danger {
  background: #fff0ea;
}

.food-name,
.food-status {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-name {
  color: var(--text-main, #24352f);
  font-size: 26rpx;
  font-weight: 900;
}

.food-status {
  margin-top: 8rpx;
  font-size: 21rpx;
  font-weight: 900;
}

.food-info.normal .food-status {
  color: var(--mint-600, #159a5b);
}

.food-info.warning .food-status {
  color: var(--honey-700, #c86f13);
}

.food-info.danger .food-status {
  color: var(--coral-600, #e85242);
}

.home-zone-empty {
  min-height: 122rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 24rpx 26rpx;
  border: 4rpx dashed rgba(255, 255, 255, 0.86);
  border-radius: 34rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.64), rgba(255, 255, 255, 0.26));
  text-align: left;
}

.home-zone-empty-icon {
  flex-shrink: 0;
  width: 70rpx;
  height: 70rpx;
  background: url("/images/mascot/fridge-empty.png") center / contain no-repeat;
  filter: drop-shadow(0 8rpx 12rpx rgba(82, 124, 94, 0.12));
}

.home-zone-empty-copy {
  min-width: 0;
  flex: 1;
}

.home-zone-empty-title {
  display: block;
  overflow: hidden;
  color: var(--text-main, #24352f);
  font-size: 27rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Bottom panels */
.zone-panel-mask {
  position: fixed;
  z-index: 80;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(38, 50, 56, 0.34);
}

.zone-panel {
  width: 100%;
  max-height: 82vh;
  overflow: hidden;
  padding: 30rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 44rpx 44rpx 0 0;
  background: linear-gradient(180deg, #fffef8 0%, #fff9ea 58%, #fff4de 100%);
  box-shadow: 0 -18rpx 48rpx rgba(80, 130, 100, 0.18);
}

.zone-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.zone-panel-head-main {
  min-width: 0;
  flex: 1;
}

.zone-panel-title {
  overflow: hidden;
  color: var(--text-main, #24352f);
  font-size: 34rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.zone-panel-kicker {
  margin-bottom: 8rpx;
  color: var(--mint-700, #087a49);
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1;
}

.zone-panel-subtitle {
  max-width: 100%;
  margin-top: 8rpx;
  overflow: hidden;
  color: var(--text-sub, #6d7e76);
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.zone-section-scroll,
.stat-section-scroll {
  max-height: 60vh;
  margin-top: 22rpx;
}

/* Add action panel */
.zone-add-grid,
.action-grid {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 24rpx;
}

.add-action-panel .zone-add-card {
  position: relative;
  align-self: stretch;
  min-width: 0;
  width: 100%;
  max-width: none;
  min-height: 116rpx;
  margin: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 30rpx;
  text-align: left;
  box-shadow:
    inset 0 5rpx 10rpx rgba(255, 255, 255, 0.35),
    0 10rpx 22rpx rgba(80, 130, 100, 0.10);
}

.add-action-panel .zone-add-card.photo {
  background: linear-gradient(180deg, #8ee7b2 0%, #35bf7a 52%, #159a5b 100%);
}

.add-action-panel .zone-add-card.package {
  background: linear-gradient(180deg, #ffe08b 0%, #ffb13d 58%, #f48a22 100%);
}

.add-action-panel .zone-add-card.manual {
  background: linear-gradient(180deg, #ffffff 0%, #e4f7ff 100%);
}

.zone-add-icon {
  flex-shrink: 0;
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  color: var(--mint-700, #087a49);
  font-size: 26rpx;
  font-weight: 900;
  box-shadow:
    inset 0 3rpx 8rpx rgba(255, 255, 255, 0.9),
    0 8rpx 16rpx rgba(80, 130, 100, 0.1);
}

.zone-add-card.package .zone-add-icon {
  color: var(--honey-700, #c86f13);
}

.zone-add-card.manual .zone-add-icon {
  color: var(--ice-700, #22789e);
}

.zone-add-copy {
  min-width: 0;
  flex: 1;
}

.zone-add-title,
.zone-add-desc {
  display: block;
  overflow: hidden;
  max-width: 100%;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.zone-add-title {
  color: var(--text-main, #24352f);
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1;
}

.zone-add-card.photo .zone-add-title,
.zone-add-card.package .zone-add-title {
  color: #ffffff;
}

.zone-add-desc {
  margin-top: 8rpx;
  color: var(--text-sub, #6d7e76);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}

.zone-add-card.photo .zone-add-desc,
.zone-add-card.package .zone-add-desc {
  color: rgba(255, 255, 255, 0.86);
}

.zone-add-arrow {
  flex-shrink: 0;
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: rgba(36, 53, 47, 0.42);
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

/* Zone and stat lists */
.zone-panel-empty {
  padding: 44rpx 28rpx;
  border: 2rpx dashed rgba(21, 154, 91, 0.18);
  border-radius: 28rpx;
  background: rgba(255, 254, 248, 0.78);
  text-align: center;
}

.zone-panel-empty-title {
  color: var(--text-main, #24352f);
  font-size: 28rpx;
  font-weight: 900;
}

.zone-panel-empty-desc {
  margin-top: 12rpx;
  color: var(--text-sub, #6d7e76);
  font-size: 24rpx;
  line-height: 1.45;
}

.zone-category-list,
.stat-item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.zone-category-group,
.stat-item-row,
.zone-config-row {
  border: 2rpx solid rgba(241, 222, 192, 0.68);
  border-radius: 28rpx;
  background: rgba(255, 254, 248, 0.86);
}

.zone-category-head {
  padding: 18rpx 20rpx;
  border-radius: 26rpx 26rpx 0 0;
  background: var(--mint-50, #effcf3);
}

.zone-category-name {
  color: var(--text-main, #24352f);
  font-size: 26rpx;
  font-weight: 900;
}

.zone-item-row,
.stat-item-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
}

.zone-category-group .zone-item-row + .zone-item-row {
  border-top: 1rpx solid rgba(241, 222, 192, 0.72);
}

.zone-item-main {
  min-width: 0;
  flex: 1;
}

.zone-item-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.zone-item-name {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: var(--text-main, #24352f);
  font-size: 29rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.zone-item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
  color: var(--text-sub, #6d7e76);
  font-size: 23rpx;
  font-weight: 800;
}

.stat-item-actions {
  flex-shrink: 0;
  width: 108rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.zone-item-edit,
.zone-item-delete {
  width: 108rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.zone-item-edit {
  background: var(--mint-100, #ddf8e8);
  color: var(--mint-700, #087a49);
}

.zone-item-delete {
  background: var(--coral-100, #ffe8df);
  color: var(--coral-600, #e85242);
}

/* Food detail */
.food-detail-hero {
  height: 320rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 50% 34%, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0) 58%),
    linear-gradient(180deg, #f5fcff 0%, #ffffff 100%);
}

.food-detail-image {
  width: 240rpx;
  height: 240rpx;
}

.food-detail-image.photo {
  width: 100%;
  height: 100%;
}

.food-detail-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.food-detail-title {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  color: var(--text-main, #24352f);
  font-size: 36rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-detail-status {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.food-detail-status.normal {
  background: var(--mint-100, #ddf8e8);
  color: var(--mint-700, #087a49);
}

.food-detail-status.warning {
  background: var(--honey-100, #fff1c9);
  color: var(--honey-700, #c86f13);
}

.food-detail-status.danger {
  background: var(--coral-100, #ffe8df);
  color: var(--coral-600, #e85242);
}

.food-detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
  color: var(--text-sub, #6d7e76);
  font-size: 24rpx;
  font-weight: 800;
}

.food-detail-note {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: var(--mint-50, #effcf3);
  color: var(--text-sub, #6d7e76);
  font-size: 25rpx;
  line-height: 1.5;
}

.food-detail-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.detail-edit-button,
.detail-delete-button {
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.detail-edit-button {
  background: var(--mint-100, #ddf8e8);
  color: var(--mint-700, #087a49);
}

.detail-delete-button {
  background: var(--coral-100, #ffe8df);
  color: var(--coral-600, #e85242);
}

/* Zone config */
.zone-config-panel {
  min-height: 82vh;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
}

.zone-config-desc {
  margin-top: 14rpx;
  color: var(--text-sub, #6d7e76);
  font-size: 24rpx;
  line-height: 1.5;
}

.zone-config-list {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 18rpx;
  margin-top: 28rpx;
  max-height: none;
  overflow: visible;
}

.zone-config-row {
  position: relative;
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
}

.zone-config-row.disabled {
  opacity: 0.55;
}

.zone-config-row.dragging {
  transform: scale(1.01);
  box-shadow:
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.9),
    0 18rpx 34rpx rgba(80, 130, 100, 0.16);
}

.zone-config-drag {
  flex-shrink: 0;
  width: 82rpx;
  height: 74rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f5fcff 100%);
  color: var(--text-sub, #6d7e76);
  font-size: 20rpx;
  font-weight: 900;
}

.zone-config-grip {
  width: 34rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: var(--ice-500, #38a6d7);
  box-shadow:
    0 10rpx 0 var(--ice-500, #38a6d7),
    0 -10rpx 0 var(--ice-500, #38a6d7);
}

.zone-config-main {
  min-width: 0;
  flex: 1;
}

.zone-config-name {
  display: block;
  overflow: hidden;
  color: var(--text-main, #24352f);
  font-size: 27rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.zone-config-hint {
  display: block;
  margin-top: 8rpx;
  color: var(--text-sub, #6d7e76);
  font-size: 22rpx;
  line-height: 1.35;
}

.zone-config-actions {
  flex-shrink: 0;
  width: 112rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.zone-config-show,
.zone-config-delete {
  width: 100%;
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.zone-config-show {
  background: var(--mint-100, #ddf8e8);
  color: var(--mint-700, #087a49);
}

.zone-config-show.active {
  background: linear-gradient(180deg, #8ee7b2 0%, #35bf7a 48%, #159a5b 100%);
  color: #ffffff;
}

.zone-config-delete {
  background: var(--coral-100, #ffe8df);
  color: var(--coral-600, #e85242);
}

.zone-config-save {
  align-self: center;
  width: 440rpx;
  max-width: 100%;
  height: 76rpx;
  margin-top: auto;
  margin-right: auto;
  margin-left: auto;
  transform: translateY(30rpx);
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #8ee7b2 0%, #35bf7a 48%, #159a5b 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  box-shadow: var(--shadow-button-green);
}

.zone-config-save::after {
  border: 0;
}

/* Notice */
.notice-bar {
  position: fixed;
  z-index: 120;
  right: 24rpx;
  bottom: 42rpx;
  left: 24rpx;
  padding: 18rpx 22rpx;
  border: 2rpx solid rgba(21, 154, 91, 0.22);
  border-radius: 28rpx;
  background: var(--mint-50, #effcf3);
  color: var(--mint-700, #087a49);
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.5;
  text-align: center;
  box-shadow: var(--shadow-card);
}
