.index-page {
  padding: 24rpx 28rpx 64rpx;
}

/* 顶部 */
.home-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.brand {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.head-actions {
  display: flex;
  gap: 14rpx;
}

.head-btn {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

/* 吉祥物 */
.hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, var(--cream-surface, #fffef8) 100%);
  border: 2rpx solid var(--cream-line, #eadbc4);
  box-shadow: var(--shadow-soft, 0 10rpx 22rpx rgba(135, 105, 64, 0.08));
}

.hero-mascot {
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.hero-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.hero-desc {
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
}

/* 全局统计 */
.stat-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 22rpx 0;
  border-radius: 24rpx;
  background: var(--cream-surface, #fffef8);
  border: 2rpx solid var(--cream-line, #eadbc4);
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--brand-mint-deep, #087a49);
}

.stat-card.warning .stat-num {
  color: var(--honey-deep, #b96a12);
}

.stat-card.danger .stat-num {
  color: var(--coral-deep, #c94238);
}

.stat-name {
  font-size: 22rpx;
  color: var(--text-sub, #6f7c74);
}

/* 搜索 */
.search-bar {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.search-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  background: var(--cream-surface, #fffef8);
  border: 2rpx solid var(--cream-line, #eadbc4);
}

.search-btn {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  background: var(--brand-mint, #28b978);
}

/* 分区卡片 */
.zone-list {
  margin-top: 24rpx;
}

.zone-card {
  margin-bottom: 20rpx;
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  background: var(--cream-surface, #fffef8);
  border: 2rpx solid var(--cream-line, #eadbc4);
  box-shadow: var(--shadow-soft, 0 10rpx 22rpx rgba(135, 105, 64, 0.08));
}

.zone-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.zone-title-wrap {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.zone-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.zone-temp {
  font-size: 22rpx;
  color: var(--text-light, #9aa9a1);
}

.zone-add {
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 40rpx;
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.zone-stats {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.zone-stat {
  flex: 1;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  padding: 14rpx 0;
  border-radius: 16rpx;
  background: var(--cream-bg, #fff6e8);
}

.zone-stat-num {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.zone-stat.warning .zone-stat-num {
  color: var(--honey-deep, #b96a12);
}

.zone-stat.danger .zone-stat-num {
  color: var(--coral-deep, #c94238);
}

.zone-stat-name {
  font-size: 22rpx;
  color: var(--text-sub, #6f7c74);
}

/* 食材横滑 */
.food-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.food-track {
  display: flex;
  gap: 16rpx;
}

.food-chip {
  width: 132rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  background: var(--cream-bg, #fff6e8);
}

.food-img {
  width: 84rpx;
  height: 84rpx;
}

.food-name {
  max-width: 116rpx;
  font-size: 22rpx;
  color: var(--text-main, #253730);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.food-tag {
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
}

.food-tag.normal {
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.food-tag.expiring {
  color: var(--honey-deep, #b96a12);
  background: var(--honey-bg, #fff5dc);
}

.food-tag.overdue {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

.zone-empty {
  margin-top: 18rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light, #9aa9a1);
  border: 2rpx dashed var(--cream-line, #eadbc4);
  border-radius: 20rpx;
}

/* 顶部提示 */
.notice {
  position: fixed;
  left: 50%;
  bottom: 80rpx;
  transform: translateX(-50%);
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #ffffff;
  background: rgba(37, 55, 48, 0.92);
  z-index: 60;
}

/* 通用底部弹层 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(37, 55, 48, 0.35);
  z-index: 50;
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  max-height: 78vh;
  padding: 28rpx 28rpx 48rpx;
  border-radius: 36rpx 36rpx 0 0;
  background: var(--cream-bg-2, #fffaf0);
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.sheet-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
}

.sheet-close {
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
  background: var(--cream-surface, #fffef8);
}

.sheet-body {
  max-height: 60vh;
}

.sheet-empty {
  padding: 60rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light, #9aa9a1);
}

.group {
  margin-bottom: 20rpx;
}

.group-name {
  display: block;
  margin: 8rpx 0 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-sub, #6f7c74);
}

.list-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  background: var(--cream-surface, #fffef8);
  border: 2rpx solid var(--cream-line, #eadbc4);
}

.list-main {
  flex: 1;
  min-width: 0;
}

.list-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main, #253730);
}

.list-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-sub, #6f7c74);
}

.tag-inline {
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.tag-inline.normal {
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.tag-inline.expiring {
  color: var(--honey-deep, #b96a12);
  background: var(--honey-bg, #fff5dc);
}

.tag-inline.overdue {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

.row-actions {
  display: flex;
  gap: 10rpx;
}

.row-btn {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--ice-ink, #1f6d89);
  background: var(--ice-soft, #ddf4ff);
}

.row-btn.danger {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

/* 食品详情 */
.detail {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-img {
  width: 140rpx;
  height: 140rpx;
  margin: 8rpx 0 12rpx;
}

.detail-name {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.detail-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  margin: 20rpx 0 28rpx;
  font-size: 26rpx;
  color: var(--text-sub, #6f7c74);
}

.detail-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.detail-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ice-ink, #1f6d89);
  background: var(--ice-soft, #ddf4ff);
}

.detail-btn.danger {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

/* 分区管理 */
.zone-config-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  background: var(--cream-surface, #fffef8);
  border: 2rpx solid var(--cream-line, #eadbc4);
}

.zc-main {
  flex: 1;
  min-width: 0;
}

.zc-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main, #253730);
}

.zc-name.off {
  color: var(--text-light, #9aa9a1);
}

.zc-hint {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--text-light, #9aa9a1);
}

.zc-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.zc-move {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 14rpx;
  font-size: 30rpx;
  color: var(--text-sub, #6f7c74);
  background: var(--cream-bg, #fff6e8);
}

.zc-toggle {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-light, #9aa9a1);
  background: var(--cream-bg, #fff6e8);
}

.zc-toggle.on {
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.sheet-foot {
  margin-top: 20rpx;
}

.foot-btn {
  text-align: center;
  padding: 24rpx 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.foot-btn.primary {
  color: #ffffff;
  background: var(--brand-mint, #28b978);
}

.foot-btn.disabled {
  opacity: 0.6;
}

.foot-btn.danger-outline {
  margin-top: 28rpx;
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

/* 设置 */
.settings-block {
  padding: 22rpx;
  border-radius: 20rpx;
  background: var(--cream-surface, #fffef8);
  border: 2rpx solid var(--cream-line, #eadbc4);
}

.settings-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-sub, #6f7c74);
}

.settings-link {
  margin-top: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ice-ink, #1f6d89);
}
