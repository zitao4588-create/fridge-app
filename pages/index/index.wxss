.index-page {
  padding: 28rpx 28rpx calc(152rpx + env(safe-area-inset-bottom));
}

.family-entry {
  min-height: 86rpx;
  margin-top: 18rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  border-top: 2rpx solid rgba(234, 219, 196, 0.8);
  border-bottom: 2rpx solid rgba(234, 219, 196, 0.8);
}

.family-entry-icon {
  width: 54rpx;
  height: 54rpx;
  line-height: 54rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 850;
  color: #ffffff;
  background: #167a50;
}

.family-entry-copy {
  min-width: 0;
  flex: 1;
  margin-left: 16rpx;
}

.family-entry-title,
.family-entry-sub {
  display: block;
}

.family-entry-title {
  font-size: 26rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.family-entry-sub {
  margin-top: 2rpx;
  font-size: 21rpx;
  color: var(--text-sub, #647264);
}

.family-entry-arrow {
  font-size: 38rpx;
  color: var(--text-light, #647264);
}

/* 吉祥物气泡 */
.hero {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 26rpx;
  border-radius: 34rpx;
  background: var(--grad-hero);
  box-shadow: var(--shadow-1), var(--hi-inset);
  overflow: hidden;
}

.hero-spark {
  position: absolute;
  top: 16rpx;
  right: 18rpx;
  width: 52rpx;
  height: 52rpx;
  opacity: 0.85;
}

.hero-mascot {
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 6rpx 10rpx rgba(40, 120, 80, 0.16));
}

.hero-copy {
  position: relative;
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.85);
  box-shadow: var(--shadow-1);
}

.hero-text {
  flex: 1;
  min-width: 0;
}

.hero-kicker {
  display: block;
  margin-bottom: 4rpx;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
  color: var(--brand-mint-deep, #087a49);
}

.hero.medium .hero-kicker {
  color: var(--honey-deep, #b96a12);
}

.hero.low .hero-kicker {
  color: var(--coral-deep, #c94238);
}

.hero-arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  font-weight: 300;
  color: var(--text-light, #647264);
}

.hero.high:active,
.hero.medium:active,
.hero.low:active {
  transform: scale(0.99);
  transition: transform 0.08s ease;
}

.hero-copy::after {
  content: '';
  position: absolute;
  left: -12rpx;
  top: 50%;
  transform: translateY(-50%);
  border-width: 12rpx 14rpx 12rpx 0;
  border-style: solid;
  border-color: transparent rgba(255, 255, 255, 0.85) transparent transparent;
}

.hero-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.hero-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
}

/* 雷达目标食材：过长单行省略，完整清单在日历报告里看 */
.hero-target {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空冰箱样板快速添加 */
.starter-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: var(--grad-card);
  box-shadow: var(--shadow-1), var(--hi-inset);
}

.starter-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.starter-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.starter-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: var(--text-sub, #6f7c74);
}

.starter-save {
  flex-shrink: 0;
  min-width: 116rpx;
  min-height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  line-height: 58rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
  color: var(--text-light, #647264);
  background: var(--cream-bg, #fff6e8);
  border: 2rpx solid var(--cream-line, #eadbc4);
}

.starter-save.active {
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
  border-color: rgba(40, 185, 120, 0.28);
}

.starter-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.starter-chip {
  min-width: 0;
  padding: 16rpx 12rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.76);
  border: 2rpx solid rgba(234, 219, 196, 0.8);
  box-shadow: var(--hi-inset);
}

.starter-chip.selected {
  background: var(--brand-mint-soft, #eaf8ee);
  border-color: rgba(40, 185, 120, 0.4);
}

.starter-name {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 25rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.starter-meta {
  display: block;
  margin-top: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 20rpx;
  color: var(--text-sub, #6f7c74);
}

/* 搜索 */
.search-bar {
  position: relative;
  margin-top: 24rpx;
}

.search-ic {
  position: absolute;
  left: 6rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 18rpx;
  font-size: 30rpx;
  opacity: 0.55;
  z-index: 1;
}

.search-input {
  height: 88rpx;
  padding: 0 28rpx 0 70rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  background: #ffffff;
  box-shadow: var(--shadow-1);
}

/* 分区卡片 */
.zone-list {
  margin-top: 26rpx;
}

.zone-card {
  position: relative;
  margin-bottom: 22rpx;
  padding: 24rpx 22rpx;
  border-radius: 34rpx;
  background: var(--grad-card);
  box-shadow: var(--shadow-1), var(--hi-inset);
  overflow: hidden;
}

/* 分区左侧色条 */
.zone-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: var(--brand-mint, #28b978);
}

.zone-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.zone-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.zone-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 34rpx;
  border-radius: 20rpx;
  background: var(--brand-mint-soft, #eaf8ee);
}

.zone-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.zone-temp {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-sub, #6f7c74);
}

.zone-add {
  position: relative;
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.zone-add::after {
  content: '';
  position: absolute;
  inset: -16rpx;
}

.zone-add-ic {
  font-size: 32rpx;
  line-height: 1;
}

/* 分区彩色身份 */
.zone-card.cold::before { background: var(--zone-cold-accent); }
.zone-card.cold .zone-icon { background: var(--zone-cold-tint); }
.zone-card.cold .zone-temp { color: var(--zone-cold-ink); }

.zone-card.freeze::before { background: var(--zone-freeze-accent); }
.zone-card.freeze .zone-icon { background: var(--zone-freeze-tint); }
.zone-card.freeze .zone-temp { color: var(--zone-freeze-ink); }

.zone-card.door::before { background: var(--zone-door-accent); }
.zone-card.door .zone-icon { background: var(--zone-door-tint); }
.zone-card.door .zone-temp { color: var(--zone-door-ink); }

.zone-card.produce::before { background: var(--zone-produce-accent); }
.zone-card.produce .zone-icon { background: var(--zone-produce-tint); }
.zone-card.produce .zone-temp { color: var(--zone-produce-ink); }

.zone-card.temp::before { background: var(--zone-temp-accent); }
.zone-card.temp .zone-icon { background: var(--zone-temp-tint); }
.zone-card.temp .zone-temp { color: var(--zone-temp-ink); }

.zone-card.ambient::before { background: #d5a22f; }
.zone-card.ambient .zone-icon { background: #fff4c8; }
.zone-card.ambient .zone-temp { color: #775615; }

/* 分区统计：拍扁成内联汇总行，去卡片化以消除“可点”错觉 */
.zone-summary {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-sub, #6f7c74);
}

.sum-num {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.sum-item.warning .sum-num {
  color: var(--honey-deep, #b96a12);
}

.sum-item.danger .sum-num {
  color: var(--coral-deep, #c94238);
}

.sum-dot {
  color: var(--text-light, #647264);
}

/* 食材玻璃磁贴 */
.food-scroll {
  margin-top: 16rpx;
  white-space: nowrap;
}

.food-track {
  display: flex;
  gap: 16rpx;
  padding: 4rpx 2rpx 8rpx;
}

.food-chip {
  position: relative;
  width: 138rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 10rpx 16rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 50% 30%, #ffffff 0%, rgba(255, 255, 255, 0) 62%),
    linear-gradient(180deg, #ffffff 0%, #f7fbf8 100%);
  box-shadow: var(--shadow-1), var(--hi-inset);
}

.food-quantity {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  z-index: 2;
  min-width: 38rpx;
  padding: 3rpx 8rpx;
  border-radius: 10rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.25;
  color: #ffffff;
  background: #167a50;
}

.food-img {
  width: 92rpx;
  height: 92rpx;
  filter: drop-shadow(0 4rpx 6rpx rgba(60, 90, 70, 0.14));
}

.food-name {
  max-width: 118rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.25;
  text-align: center;
  color: var(--text-main, #253730);
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.food-tag {
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.food-tag.normal {
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.food-tag.expiring {
  color: var(--honey-deep, #b96a12);
  background: var(--honey-bg, #fff5dc);
}

.food-tag.overdue {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

.zone-empty {
  margin-top: 18rpx;
  padding: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light, #647264);
  border: 2rpx dashed var(--cream-line, #eadbc4);
  border-radius: 22rpx;
}

/* 顶部提示 */
.notice {
  position: fixed;
  left: 50%;
  bottom: calc(152rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  padding: 18rpx 36rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #ffffff;
  background: rgba(37, 55, 48, 0.92);
  box-shadow: var(--shadow-2);
  z-index: 110;
  display: flex;
  align-items: center;
  gap: 24rpx;
  max-width: 620rpx;
  white-space: nowrap;
}

.notice-undo {
  position: relative;
  flex-shrink: 0;
  padding-left: 24rpx;
  font-weight: 800;
  color: #8ef0bd;
}

.notice-undo::before {
  content: '';
  position: absolute;
  left: 0;
  top: 4rpx;
  bottom: 4rpx;
  width: 2rpx;
  background: rgba(255, 255, 255, 0.28);
}

.consume-layer {
  position: fixed;
  inset: 0;
  z-index: 100;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.15s ease;
}

.consume-layer.visible {
  opacity: 1;
  pointer-events: auto;
}

.consume-tray {
  position: absolute;
  left: 50%;
  bottom: calc(126rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%) translateY(16rpx);
  width: 230rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border: 4rpx solid #ffffff;
  border-radius: 56rpx;
  color: #315043;
  background: #f9fff9;
  box-shadow: 0 14rpx 34rpx rgba(37, 55, 48, 0.24);
  transition: transform 0.15s ease, background 0.15s ease;
}

.consume-tray.active {
  transform: translateX(-50%) translateY(0) scale(1.08);
  color: #ffffff;
  background: #167a50;
}

.consume-tray-icon {
  font-size: 44rpx;
}

.consume-tray-label {
  font-size: 27rpx;
  font-weight: 800;
}

.dragging-food {
  position: absolute;
  transform: translate(-50%, -58%);
  width: 126rpx;
  min-height: 126rpx;
  padding: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(37, 55, 48, 0.28);
}

.dragging-food-img {
  width: 72rpx;
  height: 72rpx;
}

.dragging-food-name {
  max-width: 110rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 21rpx;
  font-weight: 700;
  color: var(--text-main, #253730);
}

/* 通用底部弹层 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(37, 55, 48, 0.38);
  z-index: 50;
  display: flex;
  align-items: flex-end;
}

.sheet {
  position: relative;
  width: 100%;
  max-height: 78vh;
  padding: 32rpx 28rpx 48rpx;
  border-radius: 40rpx 40rpx 0 0;
  background: var(--cream-bg-2, #fffaf0);
  box-shadow: var(--shadow-2);
}

.sheet::before {
  content: '';
  position: absolute;
  top: 14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(37, 55, 48, 0.16);
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin: 12rpx 0 20rpx;
}

.sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.sheet-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
}

.sheet-close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--text-sub, #5c6a62);
  background: #ffffff;
  box-shadow: var(--shadow-1);
}

.sheet-body {
  max-height: 60vh;
}

.sheet-empty {
  padding: 60rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light, #647264);
}

.group {
  margin-bottom: 20rpx;
}

.group-name {
  display: block;
  margin: 8rpx 0 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-sub, #6f7c74);
}

.list-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 22rpx;
  background: var(--grad-card);
  box-shadow: var(--shadow-1);
}

.list-main {
  flex: 1;
  min-width: 0;
}

.list-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main, #253730);
}

.list-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-sub, #6f7c74);
}

.tag-inline {
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.tag-inline.normal {
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.tag-inline.expiring {
  color: var(--honey-deep, #b96a12);
  background: var(--honey-bg, #fff5dc);
}

.tag-inline.overdue {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

.row-actions {
  display: flex;
  gap: 16rpx;
}

.row-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--neutral-ink, #4d5a52);
  background: var(--neutral-soft, #eef0ec);
}

.row-btn.danger {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

/* 食品详情 */
.detail {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-img {
  width: 150rpx;
  height: 150rpx;
  margin: 8rpx 0 12rpx;
  filter: drop-shadow(0 6rpx 10rpx rgba(60, 90, 70, 0.16));
}

.detail-name {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.detail-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  margin: 20rpx 0 24rpx;
  font-size: 26rpx;
  color: var(--text-sub, #6f7c74);
}

.detail-note {
  width: 100%;
  margin-bottom: 28rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: var(--cream-bg, #fff6e8);
  text-align: left;
}

.detail-note-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-sub, #6f7c74);
}

.detail-note-text {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-main, #253730);
}

.detail-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.detail-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: var(--neutral-ink, #4d5a52);
  background: var(--neutral-soft, #eef0ec);
}

.detail-btn.danger {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

/* 按压反馈：能点的有反馈（与拍扁后的统计行区分开） */
.food-chip:active,
.zone-add:active,
.search-ic:active,
.row-btn:active,
.detail-btn:active,
.sheet-close:active,
.danger-clear:active {
  transform: scale(0.97);
  transition: transform 0.08s ease;
}

/* 底部危险区：清空全部数据（降权 + 二次确认） */
.danger-zone {
  margin-top: 48rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid var(--cream-line, #eadbc4);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.danger-tip {
  font-size: 22rpx;
  color: var(--text-light, #647264);
}

.danger-clear {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 36rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--coral-deep, #b3392f);
  background: transparent;
  border: 2rpx solid var(--coral-bg, #ffece6);
}
