.batch-page {
  overflow-x: hidden;
  background:
    linear-gradient(180deg, #fff8ea 0%, #f7fff6 58%, #ffffff 100%);
}

.batch-hero {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
  border-color: rgba(88, 201, 139, 0.14);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.94) 0%, rgba(255, 240, 214, 0.86) 50%, rgba(221, 248, 232, 0.82) 100%);
  box-shadow: var(--shadow-card, 0 12rpx 30rpx rgba(80, 130, 100, 0.11));
}

.batch-hero-mark {
  position: relative;
  flex-shrink: 0;
  width: 82rpx;
  height: 92rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff0d6 100%);
  box-shadow: inset 0 4rpx 10rpx rgba(255, 255, 255, 0.9);
}

.batch-hero-mark::before {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  top: 20rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #ffb85c;
  box-shadow: 0 17rpx 0 #58c98b, 0 34rpx 0 #67bce8;
}

.recognition-alert {
  position: relative;
  overflow: hidden;
  margin-top: 22rpx;
  padding: 24rpx 26rpx 24rpx 94rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.16);
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fffdf8 0%, #fff4d8 64%, #f7fff6 100%);
  box-shadow: 0 10rpx 26rpx rgba(144, 112, 58, 0.1);
}

.recognition-alert.real {
  border-color: rgba(88, 201, 139, 0.2);
  background: linear-gradient(135deg, #f7fff6 0%, #e7fff0 62%, #effaff 100%);
}

.recognition-alert.unknown {
  border-color: rgba(100, 181, 246, 0.2);
  background: linear-gradient(135deg, #f8fdff 0%, #eaf7ff 62%, #f7fff6 100%);
}

.recognition-alert::before {
  content: "";
  position: absolute;
  left: 24rpx;
  top: 26rpx;
  width: 48rpx;
  height: 54rpx;
  border: 3rpx solid rgba(36, 169, 107, 0.16);
  border-radius: 16rpx 16rpx 14rpx 14rpx;
  background: linear-gradient(180deg, #e8fff2 0%, #c5f4dc 100%);
  box-shadow: inset 0 3rpx 8rpx rgba(255, 255, 255, 0.9);
}

.recognition-alert.real::before {
  border-color: rgba(36, 169, 107, 0.22);
  background: linear-gradient(180deg, #f8fff9 0%, #bff2d6 100%);
}

.recognition-alert.unknown::before {
  border-color: rgba(64, 148, 220, 0.2);
  background: linear-gradient(180deg, #ffffff 0%, #d5efff 100%);
}

.recognition-alert::after {
  content: "";
  position: absolute;
  left: 40rpx;
  top: 56rpx;
  width: 20rpx;
  height: 8rpx;
  border-bottom: 4rpx solid #24352f;
  border-radius: 0 0 999rpx 999rpx;
}

.recognition-alert-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 28rpx;
  font-weight: 900;
}

.recognition-alert-desc {
  display: block;
  margin-top: 10rpx;
  color: #8a6a2f;
  font-size: 25rpx;
  line-height: 1.6;
}

.batch-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.12);
  border-radius: 32rpx;
  background:
    linear-gradient(135deg, rgba(221, 248, 232, 0.86) 0%, rgba(255, 248, 236, 0.94) 52%, rgba(237, 249, 255, 0.92) 100%);
  color: var(--color-text-title, #24352f);
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 30rpx rgba(80, 130, 100, 0.12);
}

.manual-add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 74rpx;
  margin-top: 18rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.2);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff 0%, #e9fff1 100%);
  color: var(--color-primary-deep, #1f9f73);
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
  box-shadow: 0 8rpx 18rpx rgba(88, 201, 139, 0.14);
}

.manual-add-button::after {
  border: none;
}

.batch-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 24rpx;
}

.batch-item {
  position: relative;
  overflow: hidden;
  padding: 26rpx;
  border: 2rpx solid rgba(100, 181, 246, 0.2);
  border-radius: 36rpx;
  background: linear-gradient(180deg, #ffffff 0%, rgba(237, 249, 255, 0.68) 100%);
  box-shadow:
    inset 0 3rpx 10rpx rgba(255, 255, 255, 0.9),
    var(--shadow-ice, 0 10rpx 28rpx rgba(92, 160, 190, 0.18));
}

.batch-item::before {
  content: "";
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 14rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96), rgba(100, 181, 246, 0.08));
}

.batch-item.disabled {
  opacity: 0.55;
  filter: grayscale(0.08);
}

.batch-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.batch-item-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 31rpx;
  font-weight: 900;
}

.batch-item-recommend {
  display: block;
  margin-top: 8rpx;
  color: var(--color-primary-deep, #1f9f73);
  font-size: 24rpx;
  font-weight: 700;
}

.batch-toggle {
  flex-shrink: 0;
  min-width: 116rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(122, 138, 138, 0.12);
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  font-weight: 800;
}

.batch-toggle.checked {
  border-color: rgba(88, 201, 139, 0.2);
  background: var(--color-mint, #def7e9);
  color: var(--color-primary-deep, #1f9f73);
  box-shadow: 0 6rpx 16rpx rgba(88, 201, 139, 0.16);
}

.two-col {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 180rpx;
  gap: 20rpx;
}

.required-date {
  color: var(--color-primary-deep, #1f9f73);
  font-weight: 700;
}

.recommend-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 70rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(221, 248, 232, 0.95) 0%, rgba(195, 241, 216, 0.95) 100%);
  color: var(--color-primary-deep, #1f9f73);
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
  box-shadow: 0 8rpx 18rpx rgba(88, 201, 139, 0.18);
}

.recommend-button::after {
  border: none;
}

.batch-save {
  margin-top: 28rpx;
  height: 92rpx;
  border-radius: 999rpx;
  font-weight: 900;
}

.input,
.picker-field {
  border-color: var(--color-line, rgba(88, 201, 139, 0.13));
  border-radius: 30rpx;
}
