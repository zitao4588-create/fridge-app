.stats-card {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 32rpx;
  padding: 26rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.12);
  border-radius: 36rpx;
  background:
    linear-gradient(135deg, rgba(221, 248, 232, 0.86) 0%, rgba(255, 248, 236, 0.94) 52%, rgba(237, 249, 255, 0.92) 100%);
  box-shadow: var(--shadow-card, 0 12rpx 32rpx rgba(80, 130, 100, 0.14));
}

.stat-label {
  display: block;
  color: var(--color-text-sub, #778781);
  font-size: 22rpx;
  font-weight: 800;
}

.stat-value {
  display: block;
  margin-top: 14rpx;
  color: var(--color-primary-deep, #1f9f73);
  font-size: 42rpx;
  font-weight: 900;
}

.stat-value.warning {
  color: #c46d17;
}

.stat-value.danger {
  color: var(--color-expired, #ff7d73);
}

.info-card {
  margin-top: 28rpx;
  padding: 30rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.12);
  border-radius: 36rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  box-shadow: 0 12rpx 28rpx rgba(120, 92, 60, 0.08);
}

.info-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 32rpx;
  font-weight: 900;
}

.info-text {
  display: block;
  margin-top: 14rpx;
  color: var(--color-text-sub, #778781);
  font-size: 26rpx;
  line-height: 1.7;
}

.clear-button {
  margin-top: 28rpx;
  border-radius: 999rpx;
}
