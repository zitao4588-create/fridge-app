.stats-card {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 32rpx;
  padding: 26rpx;
}

.stat-label {
  display: block;
  color: #64748b;
  font-size: 22rpx;
}

.stat-value {
  display: block;
  margin-top: 14rpx;
  color: #0f172a;
  font-size: 42rpx;
  font-weight: 700;
}

.stat-value.warning {
  color: #d97706;
}

.stat-value.danger {
  color: #be123c;
}

.info-card {
  margin-top: 28rpx;
  padding: 28rpx;
}

.settings-card {
  margin-top: 28rpx;
  padding: 28rpx;
}

.settings-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.settings-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.settings-desc {
  display: block;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.5;
}

.fridge-type-picker {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #f8fafc;
}

.fridge-type-name {
  display: block;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 700;
}

.fridge-type-desc {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.4;
}

.fridge-type-action {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef7f6;
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 700;
}

.info-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
}

.info-text {
  display: block;
  margin-top: 14rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.7;
}

.clear-button {
  margin-top: 28rpx;
}
