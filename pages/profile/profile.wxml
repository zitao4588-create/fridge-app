<view class="page profile-page">
  <view class="page-title">我的</view>
  <view class="page-subtitle">库存数据按当前微信用户隔离保存。</view>

  <view class="stats-card card">
    <view>
      <text class="stat-label">总食品数</text>
      <text class="stat-value">{{stats.total}}</text>
    </view>
    <view>
      <text class="stat-label">3天内过期</text>
      <text class="stat-value warning">{{stats.expiringSoon}}</text>
    </view>
    <view>
      <text class="stat-label">已过期</text>
      <text class="stat-value danger">{{stats.overdue}}</text>
    </view>
  </view>

  <view class="settings-card card">
    <view class="settings-head">
      <view>
        <text class="settings-title">冰箱类型</text>
        <text class="settings-desc">首页会按这里选择的冰箱模板展示分区。</text>
      </view>
    </view>

    <picker
      range="{{fridgeLayoutOptions}}"
      value="{{fridgeLayoutIndex}}"
      bindchange="handleFridgeLayoutChange"
    >
      <view class="fridge-type-picker">
        <view>
          <text class="fridge-type-name">{{selectedFridgeLayout.name}}</text>
          <text class="fridge-type-desc">{{selectedFridgeLayout.description}}</text>
        </view>
        <text class="fridge-type-action">更换</text>
      </view>
    </picker>
  </view>

  <view class="info-card card">
    <text class="info-title">关于冰箱管家</text>
    <text class="info-text">用于记录冰箱食品饮料库存，支持手动管理、到期日历、库存统计和菜谱建议。</text>
  </view>

  <button class="danger-button clear-button" bindtap="handleClearAll">清空全部食品数据</button>
</view>
