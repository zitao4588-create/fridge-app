<view class="page calendar-page">
  <view class="cal-card">
    <view class="month-row">
      <view class="month-nav" bindtap="handlePrevMonth">‹</view>
      <view class="month-center">
        <text class="month-title">{{monthTitle}}</text>
        <text class="today-btn" bindtap="handleToday">回到今天</text>
      </view>
      <view class="month-nav" bindtap="handleNextMonth">›</view>
    </view>

    <view class="week-grid">
      <text wx:for="{{weekLabels}}" wx:key="*this">{{item}}</text>
    </view>

    <view class="day-grid">
      <view
        wx:for="{{days}}"
        wx:key="date"
        data-date="{{item.date}}"
        bindtap="handleSelectDay"
        class="day-cell {{item.inCurrentMonth ? '' : 'muted'}} {{item.selected ? 'selected' : ''}} {{item.isToday ? 'today' : ''}}"
      >
        <text class="day-number">{{item.day}}</text>
        <text wx:if="{{item.hasEvents}}" class="day-dot"></text>
      </view>
    </view>
  </view>

  <view class="radar-card">
    <image class="radar-spark" src="/images/decor/sparkle.png" mode="aspectFit" />
    <view class="radar-head">
      <image class="radar-mascot" src="/images/mascot/fridge-chef.png" mode="aspectFit" />
      <text class="radar-title">开饭雷达检测报告</text>
      <text class="radar-badge">今日扫描完成</text>
    </view>

    <view class="radar-dial">
      <view class="radar-ring" style="background: conic-gradient(#3aafd8 {{radar.score}}%, #e3eef2 {{radar.score}}%);">
        <view class="radar-core">
          <text class="radar-core-label">可开饭指数</text>
          <text class="radar-core-score">{{radar.score}}<text class="radar-core-pct">%</text></text>
        </view>
      </view>
    </view>

    <view class="radar-level {{radar.levelClass}}">{{radar.levelTitle}}</view>
    <text class="radar-explain">{{radar.explanation}}</text>

    <view class="radar-priority">
      <text class="radar-priority-label">⭐ 今日优先用掉</text>
      <view wx:if="{{radar.priorityItems.length > 0}}" class="radar-chips">
        <text class="radar-chip" wx:for="{{radar.priorityItems}}" wx:key="_id">{{item.name}}</text>
      </view>
      <text wx:else class="radar-priority-empty">暂无临期压力，按心情安排一顿就好～</text>
    </view>
  </view>

  <view class="stat-row">
    <view class="stat-card" data-type="total" bindtap="handleStatsTap">
      <text class="stat-ic">🧺</text>
      <view class="stat-col">
        <text class="stat-num">{{stats.total}}</text>
        <text class="stat-name">总库存</text>
      </view>
    </view>
    <view class="stat-card warning" data-type="expiring" bindtap="handleStatsTap">
      <text class="stat-ic">⏰</text>
      <view class="stat-col">
        <text class="stat-num">{{stats.expiring}}</text>
        <text class="stat-name">临期</text>
      </view>
    </view>
    <view class="stat-card danger" data-type="overdue" bindtap="handleStatsTap">
      <text class="stat-ic">⚠️</text>
      <view class="stat-col">
        <text class="stat-num">{{stats.overdue}}</text>
        <text class="stat-name">已过期</text>
      </view>
    </view>
  </view>

  <view class="sel-head">
    <text class="sel-title">{{selectedDateText}} 到期</text>
    <text class="sel-count">{{selectedItems.length}} 项</text>
  </view>

  <view wx:if="{{selectedItems.length === 0}}" class="sel-empty">这一天没有食材到期</view>
  <view wx:else>
    <view class="list-row" wx:for="{{selectedItems}}" wx:key="_id">
      <view class="list-main">
        <text class="list-name">{{item.name}} · {{item.amountText}}</text>
        <text class="list-meta">{{item.category}} · {{item.storageLocation}}</text>
      </view>
      <text class="tag-inline {{item.bucket}}">{{item.statusLabel}}</text>
      <view class="row-actions">
        <view class="row-btn" data-id="{{item._id}}" bindtap="handleEdit">编辑</view>
        <view class="row-btn danger" data-id="{{item._id}}" data-name="{{item.name}}" bindtap="handleDelete">删除</view>
      </view>
    </view>
  </view>
</view>

<!-- 统计清单弹层 -->
<view wx:if="{{listPanelVisible}}" class="mask" bindtap="handleCloseListPanel">
  <view class="sheet" catchtap="noop">
    <view class="sheet-head">
      <view>
        <text class="sheet-title">{{listPanelTitle}}</text>
        <text class="sheet-sub">{{listPanelSubtitle}}</text>
      </view>
      <view class="sheet-close" bindtap="handleCloseListPanel">关闭</view>
    </view>
    <scroll-view class="sheet-body" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:if="{{listPanelEmpty}}" class="sel-empty">{{listPanelEmpty}}</view>
      <view wx:else>
        <view class="list-row" wx:for="{{listPanelItems}}" wx:key="_id">
          <view class="list-main">
            <text class="list-name">{{item.name}} · {{item.amountText}}</text>
            <text class="list-meta">到期 {{item.expireDateText}} · {{item.storageLocation}}</text>
          </view>
          <text class="tag-inline {{item.bucket}}">{{item.statusHint}}</text>
          <view class="row-actions">
            <view class="row-btn" data-id="{{item._id}}" catchtap="handleEdit">编辑</view>
            <view class="row-btn danger" data-id="{{item._id}}" data-name="{{item.name}}" catchtap="handleDelete">删除</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
