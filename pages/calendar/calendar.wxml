<view class="page calendar-page">
  <view class="calendar-card card">
    <view class="month-row">
      <view class="month-button prev" bindtap="handlePrevMonth">上月</view>
      <view class="month-title">{{monthTitle}}</view>
      <view class="month-button next" bindtap="handleNextMonth">下月</view>
    </view>

    <view class="week-grid">
      <text wx:for="{{weekLabels}}" wx:key="*this">{{item}}</text>
    </view>

    <view class="day-grid">
      <view
        wx:for="{{days}}"
        wx:key="date"
        data-date="{{item.date}}"
        bindtap="handleSelectDay"
        class="day-cell {{item.inCurrentMonth ? '' : 'muted'}} {{item.selected ? 'selected' : ''}} {{item.hasEvents ? 'marked' : ''}}"
      >
        <text class="day-number">{{item.day}}</text>
        <text wx:if="{{item.hasEvents}}" class="day-dot">{{item.eventCount}}</text>
      </view>
    </view>
  </view>

  <view class="calendar-stats-grid">
    <view class="calendar-stat-card total" data-type="total" bindtap="handleOpenCalendarStats">
      <text class="calendar-stat-label">库存</text>
      <text class="calendar-stat-value total">{{stats.total}}</text>
    </view>
    <view class="calendar-stat-card warning" data-type="expiring" bindtap="handleOpenCalendarStats">
      <text class="calendar-stat-label">临期</text>
      <text class="calendar-stat-value warning">{{stats.expiringSoon}}</text>
    </view>
    <view class="calendar-stat-card danger" data-type="overdue" bindtap="handleOpenCalendarStats">
      <text class="calendar-stat-label">过期</text>
      <text class="calendar-stat-value danger">{{stats.overdue}}</text>
    </view>
  </view>

  <view wx:if="{{selectedItems.length === 0}}" class="date-empty card">当天没有食品到期</view>
  <view wx:else class="selected-list">
    <view class="selected-item card" wx:for="{{selectedItems}}" wx:key="_id">
      <view>
        <text class="selected-name">{{item.name}}</text>
        <text class="selected-meta">{{item.quantity}}{{item.unit}} · {{item.category}} · {{item.storageLocation}}</text>
      </view>
      <text class="status-chip {{item.statusClass}}">{{item.statusLabel}}</text>
    </view>
  </view>

  <view class="expiry-card card">
    <view wx:if="{{expiryUsage.recommendations.length > 0}}" class="expiry-recipe-list">
      <text class="expiry-food-title">开饭雷达检测报告</text>
      <view
        class="expiry-recipe-card"
        wx:for="{{expiryUsage.recommendations}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="handleOpenRecipeDetail"
      >
        <view class="expiry-recipe-head">
          <view class="expiry-recipe-main">
            <text class="expiry-recipe-title">{{item.title}}</text>
          </view>
          <text class="expiry-recipe-action">查看做法</text>
        </view>

        <view class="expiry-match-grid">
          <view class="expiry-match-box">
            <text class="expiry-match-title">已有食材 {{item.availableItems.length}}</text>
            <view class="expiry-chip-row">
              <text wx:if="{{item.availableItems.length === 0}}" class="expiry-empty-chip">暂无</text>
              <text class="expiry-food-chip" wx:for="{{item.availableItems}}" wx:for-item="food" wx:key="id">{{food.name}}</text>
            </view>
          </view>
          <view class="expiry-match-box missing">
            <text class="expiry-match-title">缺少食材 {{item.missingItems.length}}</text>
            <view class="expiry-chip-row">
              <text wx:if="{{item.missingItems.length === 0}}" class="expiry-empty-chip">不缺</text>
              <text class="expiry-food-chip missing" wx:for="{{item.missingItems}}" wx:for-item="food" wx:key="*this">{{food}}</text>
            </view>
          </view>
        </view>

        <view wx:if="{{item.priorityItems.length > 0}}" class="expiry-priority-line">
          <text>建议优先用掉：</text>
            <text wx:for="{{item.priorityItems}}" wx:for-item="food" wx:for-index="priorityIndex" wx:key="id">{{food.name}}{{priorityIndex + 1 < item.priorityItems.length ? '、' : ''}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="expiry-empty">暂无可去化临期食材，AI 菜谱仍可给日常灵感。</view>

    <view wx:if="{{expiryUsage.safetyTips.length > 0}}" class="safety-box">
      <text class="safety-title">已过期提醒</text>
      <text class="safety-line" wx:for="{{expiryUsage.safetyTips}}" wx:key="id">{{item.text}}</text>
    </view>
  </view>

  <view wx:if="{{recipeDetailVisible}}" class="recipe-detail-mask" bindtap="handleCloseRecipeDetail">
    <view class="recipe-detail-panel card" catchtap="noop">
      <view class="recipe-detail-head">
        <view>
          <text class="recipe-detail-kicker">开饭雷达检测报告</text>
          <text class="recipe-detail-title">{{recipeDetail.title}}</text>
        </view>
        <text class="recipe-detail-close" bindtap="handleCloseRecipeDetail">×</text>
      </view>

      <view class="recipe-detail-summary">
        <text>{{recipeDetail.timeCost}}</text>
        <text>{{recipeDetail.difficulty}}</text>
        <text>{{recipeDetail.matchLabel}}</text>
      </view>

      <view class="recipe-detail-block">
        <text class="recipe-detail-block-title">食材匹配</text>
        <view class="recipe-detail-chip-row">
          <text wx:if="{{recipeDetail.availableItems.length === 0}}" class="expiry-empty-chip">暂无可用库存</text>
          <text class="expiry-food-chip" wx:for="{{recipeDetail.availableItems}}" wx:for-item="food" wx:key="id">{{food.name}}</text>
          <text class="expiry-food-chip missing" wx:for="{{recipeDetail.missingItems}}" wx:for-item="food" wx:key="*this">缺 {{food}}</text>
        </view>
      </view>

      <view class="recipe-detail-block">
        <text class="recipe-detail-block-title">做菜步骤</text>
        <view class="recipe-step" wx:for="{{recipeDetail.steps}}" wx:for-item="step" wx:for-index="stepIndex" wx:key="*this">
          <text class="recipe-step-number">{{stepIndex + 1}}</text>
          <text class="recipe-step-text">{{step}}</text>
        </view>
      </view>

      <view wx:if="{{recipeDetail.safetyNote}}" class="recipe-safety-note">{{recipeDetail.safetyNote}}</view>
    </view>
  </view>

  <view wx:if="{{inventoryPanelVisible}}" class="inventory-mask" bindtap="handleCloseInventoryPanel">
    <view class="inventory-panel card" catchtap="noop">
      <view class="inventory-head">
        <text class="inventory-title">{{inventoryPanelTitle}}</text>
        <text class="inventory-close" bindtap="handleCloseInventoryPanel">×</text>
      </view>

      <view wx:if="{{inventoryPanelItems.length === 0}}" class="inventory-empty">暂无食品</view>
      <view wx:else class="inventory-list">
        <view class="inventory-item" wx:for="{{inventoryPanelItems}}" wx:key="id">
          <view>
            <text class="inventory-name">{{item.name}}</text>
            <text class="inventory-meta">{{item.category}} · {{item.storageLocation}} · {{item.expiryHint}}</text>
          </view>
          <text class="status-chip {{item.statusClass}}">{{item.statusLabel}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
