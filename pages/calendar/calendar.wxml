<view class="page calendar-page">
  <view class="cal-card">
    <view class="month-row">
      <view class="month-nav" bindtap="handlePrevMonth" aria-role="button" aria-label="上个月">‹</view>
      <view class="month-center">
        <text class="month-title">{{monthTitle}}</text>
        <text class="today-btn" bindtap="handleToday" aria-role="button">回到今天</text>
      </view>
      <view class="month-nav" bindtap="handleNextMonth" aria-role="button" aria-label="下个月">›</view>
    </view>

    <view class="week-grid">
      <text wx:for="{{weekLabels}}" wx:key="*this">{{item}}</text>
    </view>

    <view class="day-grid">
      <view
        wx:for="{{days}}"
        wx:key="date"
        data-date="{{item.date}}"
        bindtap="handleSelectDay"
        aria-role="button"
        aria-label="{{item.day}}日{{item.hasEvents ? '，有食材到期' : ''}}"
        class="day-cell {{item.inCurrentMonth ? '' : 'muted'}} {{item.selected ? 'selected' : ''}} {{item.isToday ? 'today' : ''}}"
      >
        <text class="day-number">{{item.day}}</text>
        <text wx:if="{{item.hasEvents}}" class="day-dot" aria-hidden="true"></text>
      </view>
    </view>
  </view>

  <view class="stat-row">
    <view class="stat-card" data-type="total" bindtap="handleStatsTap" aria-role="button">
      <text class="stat-ic">🧺</text>
      <view class="stat-col">
        <text class="stat-num">{{stats.total}}</text>
        <text class="stat-name">总库存</text>
      </view>
    </view>
    <view class="stat-card warning" data-type="expiring" bindtap="handleStatsTap" aria-role="button">
      <text class="stat-ic">⏰</text>
      <view class="stat-col">
        <text class="stat-num">{{stats.expiring}}</text>
        <text class="stat-name">临期</text>
      </view>
    </view>
    <view class="stat-card danger" data-type="overdue" bindtap="handleStatsTap" aria-role="button">
      <text class="stat-ic">⚠️</text>
      <view class="stat-col">
        <text class="stat-num">{{stats.overdue}}</text>
        <text class="stat-name">已过期</text>
      </view>
    </view>
  </view>

  <view class="sel-head">
    <text class="sel-title">{{selectedDateText}} 到期</text>
    <text class="sel-count">{{selectedItems.length}} 项</text>
  </view>

  <view wx:if="{{selectedItems.length === 0}}" class="sel-empty">这一天没有食材到期</view>
  <view wx:else>
    <view class="list-row" wx:for="{{selectedItems}}" wx:key="_id">
      <view class="list-main">
        <text class="list-name">{{item.name}}</text>
        <text class="list-meta">{{item.category}} · {{item.storageLocation}}</text>
      </view>
      <text class="tag-inline {{item.bucket}}">{{item.statusLabel}}</text>
      <view class="row-actions">
        <view class="row-btn" data-id="{{item._id}}" bindtap="handleEdit" aria-role="button">编辑</view>
        <view class="row-btn danger" data-id="{{item._id}}" data-name="{{item.name}}" bindtap="handleDelete" aria-role="button">删除</view>
      </view>
    </view>
  </view>

  <view class="meal-radar-card card">
    <image class="meal-radar-decor sparkle" src="/images/decor/sparkle.png" mode="aspectFit" aria-hidden="true" />

    <view class="meal-radar-head">
      <view class="meal-radar-title-wrap">
        <image class="meal-radar-mascot" src="/images/mascot/fridge-chef.png" mode="aspectFit" aria-hidden="true" />
        <view class="meal-radar-title-block">
          <text class="meal-radar-title">开饭雷达检测报告</text>
          <text class="meal-radar-subtitle">{{radar.statusText}} · {{radar.timeText}}</text>
        </view>
      </view>
    </view>

    <view class="meal-radar-console">
      <view class="meal-radar-screen {{radar.levelClass}}">
        <view class="radar-orbit orbit-one"></view>
        <view class="radar-orbit orbit-two"></view>
        <view class="radar-orbit orbit-three"></view>
        <view class="radar-sweep"></view>
        <view class="radar-core">
          <text class="radar-score-label">可开饭指数</text>
          <text class="radar-score-value">{{radar.score}}</text>
        </view>
      </view>

      <view class="meal-radar-explain">
        <text class="meal-radar-verdict {{radar.levelClass}}">{{radar.levelTitle}}</text>
        <view class="meal-radar-ranges">
          <text class="{{radar.levelClass === 'high' ? 'on' : ''}}">高 80-99：适合开饭</text>
          <text class="{{radar.levelClass === 'medium' ? 'on' : ''}}">中 50-79：建议补 1-2 样</text>
          <text class="{{radar.levelClass === 'low' ? 'on' : ''}}">低 0-49：先处理风险或补货</text>
        </view>
      </view>
    </view>

    <view class="meal-radar-priority {{radar.priorityItems.length > 0 ? '' : 'empty'}}">
      <text class="meal-radar-priority-label">{{radar.priorityTitle}}</text>
      <view wx:if="{{radar.priorityItems.length > 0}}" class="meal-radar-priority-chips">
        <view class="meal-radar-priority-chip" wx:for="{{radar.priorityItems}}" wx:key="_id">
          <text class="meal-radar-priority-name">{{item.name}}</text>
        </view>
      </view>
      <text wx:else class="meal-radar-priority-empty">{{radar.priorityEmptyText}}</text>
    </view>
  </view>
</view>

<!-- 统计清单弹层 -->
<view wx:if="{{listPanelVisible}}" class="mask" bindtap="handleCloseListPanel">
  <view class="sheet" catchtap="noop">
    <view class="sheet-head">
      <view>
        <text class="sheet-title">{{listPanelTitle}}</text>
        <text class="sheet-sub">{{listPanelSubtitle}}</text>
      </view>
      <view class="sheet-close" bindtap="handleCloseListPanel" aria-role="button">关闭</view>
    </view>
    <scroll-view class="sheet-body" scroll-y enhanced show-scrollbar="{{false}}">
      <view wx:if="{{listPanelEmpty}}" class="sel-empty">{{listPanelEmpty}}</view>
      <view wx:else>
        <view class="list-row" wx:for="{{listPanelItems}}" wx:key="_id">
          <view class="list-main">
            <text class="list-name">{{item.name}}</text>
            <text class="list-meta">到期 {{item.expireDateText}} · {{item.storageLocation}}</text>
          </view>
          <text class="tag-inline {{item.bucket}}">{{item.statusHint}}</text>
          <view class="row-actions">
            <view class="row-btn" data-id="{{item._id}}" catchtap="handleEdit" aria-role="button">编辑</view>
            <view class="row-btn danger" data-id="{{item._id}}" data-name="{{item.name}}" catchtap="handleDelete" aria-role="button">删除</view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
