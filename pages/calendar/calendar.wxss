.calendar-page {
  padding-bottom: 72rpx;
  overflow-x: hidden;
  background:
    linear-gradient(180deg, var(--cream-bg-2, #fffaf0) 0%, var(--cream-bg, #fff6e8) 58%, #fffaf0 100%);
}

.calendar-card {
  position: relative;
  overflow: hidden;
  padding: 26rpx;
  border: 2rpx solid rgba(100, 181, 246, 0.2);
  border-radius: 42rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(237, 249, 255, 0.82) 100%);
  box-shadow:
    inset 0 4rpx 12rpx rgba(255, 255, 255, 0.92),
    var(--shadow-ice, 0 14rpx 30rpx rgba(58, 175, 216, 0.12));
}

.calendar-card::before {
  content: "";
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  top: 14rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.98), rgba(100, 181, 246, 0.1));
}

.month-row {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 88rpx minmax(0, 1fr) 88rpx;
  align-items: center;
  gap: 24rpx;
}

.month-button {
  width: 88rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--ice-700, #1f6d89);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(80, 130, 100, 0.12);
}

.month-title {
  min-width: 0;
  overflow: hidden;
  color: var(--color-text-title, #24352f);
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.week-grid,
.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-grid {
  margin-top: 28rpx;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.day-grid {
  gap: 8rpx;
  margin-top: 14rpx;
}

.day-cell {
  position: relative;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(100, 181, 246, 0.08);
  border-radius: 22rpx;
  color: var(--color-text-title, #24352f);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 -4rpx 10rpx rgba(100, 181, 246, 0.06);
}

.day-cell.muted {
  color: var(--color-text-light, #a5b1ad);
  background: rgba(255, 255, 255, 0.42);
}

.day-cell.selected {
  border-color: rgba(46, 156, 200, 0.18);
  background: linear-gradient(180deg, var(--ice-soft, #DDF4FF) 0%, var(--ice-mid, #A9DDF1) 100%);
  color: var(--ice-ink, #1F6D89);
  font-weight: 800;
  box-shadow: 0 6rpx 14rpx rgba(58, 175, 216, 0.14);
}

.day-cell.marked:not(.selected) {
  border-color: rgba(100, 181, 246, 0.16);
  background: var(--color-blue-ice, #ddf3ff);
  color: #3a91b6;
}

.day-number {
  font-size: 26rpx;
}

.day-dot {
  position: absolute;
  right: 8rpx;
  top: 6rpx;
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: var(--honey-mid, #FFC76B);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 10rpx rgba(255, 199, 107, 0.16);
}

.calendar-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.calendar-stat-card {
  position: relative;
  overflow: hidden;
  min-width: 0;
  height: 104rpx;
  padding: 14rpx 18rpx;
  border-radius: 34rpx;
  box-shadow:
    inset 0 4rpx 10rpx rgba(255, 255, 255, 0.9),
    0 12rpx 24rpx rgba(135, 105, 64, 0.08);
}

.calendar-stat-card::after {
  content: "";
  position: absolute;
  right: -18rpx;
  bottom: -20rpx;
  width: 82rpx;
  height: 82rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.38);
}

.calendar-stat-card.total {
  background: linear-gradient(180deg, #ffffff 0%, var(--ice-100, #ddf4ff) 100%);
}

.calendar-stat-card.warning {
  background: linear-gradient(180deg, #ffffff 0%, var(--honey-bg, #FFF5DC) 100%);
}

.calendar-stat-card.danger {
  background: linear-gradient(180deg, #ffffff 0%, var(--coral-bg, #FFECE6) 100%);
}

.calendar-stat-card:active,
.meal-recipe-card:active {
  transform: scale(0.985);
}

.calendar-stat-label {
  position: relative;
  z-index: 1;
  display: block;
  overflow: hidden;
  color: rgba(36, 53, 47, 0.68);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.calendar-stat-value {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1;
}

.calendar-stat-value.total {
  color: var(--ice-700, #1f6d89);
}

.calendar-stat-value.warning {
  color: #c97922;
}

.calendar-stat-value.danger {
  color: #d95d55;
}

.meal-radar-card {
  position: relative;
  overflow: hidden;
  margin-top: 22rpx;
  padding: 26rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 46rpx;
  background:
    linear-gradient(180deg, var(--cream-surface, #fffef8) 0%, var(--cream-bg, #fff6e8) 100%);
  box-shadow:
    inset 0 6rpx 14rpx rgba(255, 255, 255, 0.92),
    0 18rpx 42rpx rgba(135, 105, 64, 0.13);
}

.meal-radar-card::before {
  content: "";
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  top: 16rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0));
}

.meal-radar-decor {
  position: absolute;
  z-index: 0;
  pointer-events: none;
}

.meal-radar-decor.sparkle {
  left: 28rpx;
  bottom: 28rpx;
  width: 34rpx;
  height: 34rpx;
  opacity: 0.72;
}

.meal-radar-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 18rpx;
}

.meal-radar-title-wrap {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.meal-radar-mascot {
  width: 86rpx;
  height: 86rpx;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, var(--ice-100, #ddf4ff) 100%);
  box-shadow: 0 10rpx 22rpx rgba(46, 156, 200, 0.12);
}

.meal-radar-title-block {
  min-width: 0;
}

.meal-radar-title {
  display: block;
  margin-top: 0;
  overflow: hidden;
  color: var(--text-main, #24352f);
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.15;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meal-radar-console {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 246rpx minmax(0, 1fr);
  gap: 18rpx;
  margin-top: 22rpx;
  align-items: stretch;
}

.meal-radar-screen {
  position: relative;
  min-height: 246rpx;
  overflow: hidden;
  border: 5rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 38rpx;
  background:
    radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0) 76rpx),
    linear-gradient(180deg, var(--ice-50, #f5fcff) 0%, var(--ice-100, #e4f7ff) 42%, var(--ice-200, #c7edfc) 100%);
  box-shadow:
    inset 0 8rpx 18rpx rgba(255, 255, 255, 0.96),
    inset 0 -16rpx 28rpx rgba(58, 175, 216, 0.12),
    var(--shadow-ice, 0 14rpx 30rpx rgba(58, 175, 216, 0.12));
}

.meal-radar-screen.high .radar-score-value {
  color: var(--ice-700, #1f6d89);
}

.meal-radar-screen.medium .radar-score-value {
  color: var(--honey-700, #c86f13);
}

.meal-radar-screen.low .radar-score-value {
  color: var(--coral-600, #e85242);
}

.radar-orbit {
  position: absolute;
  left: 50%;
  top: 50%;
  border: 2rpx solid rgba(56, 166, 215, 0.22);
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.orbit-one {
  width: 202rpx;
  height: 202rpx;
}

.orbit-two {
  width: 142rpx;
  height: 142rpx;
}

.orbit-three {
  width: 80rpx;
  height: 80rpx;
}

.radar-sweep {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 116rpx;
  height: 116rpx;
  border-radius: 0 116rpx 0 0;
  background: linear-gradient(42deg, rgba(46, 156, 200, 0.32), rgba(46, 156, 200, 0));
  transform-origin: 0 0;
  animation: radarSweep 4s linear infinite;
}

.radar-core {
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  top: 50%;
  z-index: 1;
  padding: 18rpx 12rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.74);
  text-align: center;
  transform: translateY(-50%);
  backdrop-filter: blur(8rpx);
}

.radar-score-label {
  display: block;
  color: var(--ice-700, #22789e);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
}

.radar-score-value {
  display: block;
  margin-top: 14rpx;
  color: var(--ice-700, #1f6d89);
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1;
}

@keyframes radarSweep {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.meal-radar-explain {
  min-width: 0;
  padding: 20rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 4rpx 10rpx rgba(255, 255, 255, 0.9);
}

.meal-radar-explain-main {
  display: block;
  color: var(--text-main, #24352f);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.45;
}

.meal-radar-ranges {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 14rpx;
}

.meal-radar-ranges text {
  display: block;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(245, 252, 255, 0.92);
  color: var(--text-sub, #6d7e76);
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.25;
}

.meal-radar-priority {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  background: linear-gradient(180deg, var(--honey-bg, #FFF5DC) 0%, var(--honey-soft, #FFE7B2) 100%);
  box-shadow: var(--shadow-warning, 0 6rpx 14rpx rgba(255, 178, 62, 0.14));
}

.meal-radar-priority.empty {
  background: linear-gradient(180deg, #ffffff 0%, var(--cream-bg-2, #fffaf0) 100%);
  box-shadow: 0 8rpx 18rpx rgba(135, 105, 64, 0.08);
}

.meal-radar-priority-label {
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--honey-deep, #B96A12);
  font-size: 22rpx;
  font-weight: 800;
}

.meal-radar-priority-chips {
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meal-radar-priority-chips text {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #8A520E;
  font-size: 22rpx;
  font-weight: 800;
}

.meal-radar-priority-empty {
  min-width: 0;
  color: var(--text-sub, #6d7e76);
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.35;
}

.expiry-food-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--ice-100, #ddf4ff);
  color: var(--ice-700, #1f6d89);
  font-size: 22rpx;
  font-weight: 800;
}

.expiry-recipe-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
}

.expiry-ai-status {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border: 2rpx dashed rgba(234, 219, 196, 0.9);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, var(--cream-bg-2, #fffaf0) 100%);
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.5;
}

.expiry-ai-status.loading {
  border-style: solid;
  background: linear-gradient(180deg, #ffffff 0%, var(--ai-100, #f2efff) 100%);
  color: var(--ai-700, #5d46a3);
}

.meal-recipe-card {
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr);
  gap: 18rpx;
  padding: 16rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 34rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffaf0 100%);
  box-shadow: 0 12rpx 26rpx rgba(120, 92, 60, 0.08);
}

.meal-recipe-image {
  width: 132rpx;
  height: 132rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  background: var(--ice-50, #f5fcff);
  box-shadow: inset 0 4rpx 8rpx rgba(255, 255, 255, 0.9);
}

.meal-recipe-content {
  min-width: 0;
}

.meal-recipe-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.meal-recipe-title {
  min-width: 0;
  color: var(--text-main, #24352f);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.meal-recipe-action {
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: var(--ai-lilac-bg, #F2EFFF);
  color: var(--ai-lilac-deep, #5D46A3);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
}

.meal-recipe-action.saved {
  background: var(--honey-bg, #FFF5DC);
  color: var(--honey-deep, #B96A12);
}

.expiry-match-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.expiry-match-box {
  min-height: 120rpx;
  padding: 16rpx;
  border: 2rpx solid rgba(169, 221, 241, 0.24);
  border-radius: 24rpx;
  background: #f5fcff;
}

.expiry-match-box.missing {
  border-color: rgba(255, 184, 77, 0.12);
  background: #fff8ea;
}

.expiry-match-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 22rpx;
  font-weight: 800;
}

.expiry-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.expiry-food-chip.missing {
  background: var(--color-orange-light, #fff0d6);
  color: #c46d17;
}

.expiry-empty-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-text-light, #a5b1ad);
  font-size: 22rpx;
  font-weight: 700;
}

.expiry-priority-line {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fff9ea 0%, #fff0d6 100%);
  color: #8a6a2f;
  font-size: 23rpx;
  line-height: 1.5;
}

.expiry-empty {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 2rpx dashed rgba(234, 219, 196, 0.9);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, var(--cream-bg-2, #fffaf0) 100%);
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  line-height: 1.5;
}

.safety-box {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(255, 107, 107, 0.12);
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fff8f6 0%, #ffe7e3 100%);
}

.safety-title {
  display: block;
  color: var(--color-expired, #ff7d73);
  font-size: 24rpx;
  font-weight: 800;
}

.safety-line {
  display: block;
  margin-top: 8rpx;
  color: #b64f4f;
  font-size: 23rpx;
  line-height: 1.5;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 34rpx 2rpx 18rpx;
}

.date-head {
  margin-top: 22rpx;
}

.section-title {
  color: var(--color-text-title, #24352f);
  font-size: 30rpx;
  font-weight: 800;
}

.section-count {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 14rpx rgba(80, 130, 100, 0.08);
}

.date-empty {
  margin-top: 18rpx;
  padding: 28rpx 24rpx;
  border: 2rpx dashed rgba(100, 181, 246, 0.2);
  border-radius: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f1fbff 100%);
  color: var(--color-text-sub, #778781);
  font-size: 25rpx;
  text-align: center;
}

.selected-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.selected-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.1);
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(80, 130, 100, 0.08);
}

.selected-name {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 30rpx;
  font-weight: 800;
}

.selected-meta {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
}

.status-chip {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.recipe-detail-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 45;
  background: rgba(31, 45, 42, 0.38);
  backdrop-filter: blur(8rpx);
}

.recipe-detail-panel {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 42rpx;
  max-height: 76vh;
  padding: 28rpx;
  overflow-y: auto;
  border: 2rpx solid rgba(255, 184, 77, 0.16);
  border-radius: 42rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  box-shadow: 0 18rpx 46rpx rgba(31, 45, 42, 0.14);
}

.recipe-detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.recipe-detail-kicker {
  display: block;
  color: var(--honey-700, #c97814);
  font-size: 24rpx;
  font-weight: 800;
}

.recipe-detail-title {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-title, #24352f);
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.25;
}

.recipe-detail-close {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--ice-700, #1f6d89);
  font-size: 40rpx;
  line-height: 1;
  box-shadow: 0 8rpx 16rpx rgba(135, 105, 64, 0.08);
}

.recipe-detail-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.recipe-detail-summary text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(237, 249, 255, 0.9);
  color: #3a91b6;
  font-size: 22rpx;
  font-weight: 800;
}

.recipe-detail-block {
  margin-top: 24rpx;
}

.recipe-detail-block-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 26rpx;
  font-weight: 800;
}

.recipe-detail-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.recipe-step {
  display: grid;
  grid-template-columns: 46rpx minmax(0, 1fr);
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(234, 219, 196, 0.72);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.86);
}

.recipe-step-number {
  width: 46rpx;
  height: 46rpx;
  border-radius: 999rpx;
  background: var(--honey-mid, #FFC76B);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 46rpx;
  text-align: center;
}

.recipe-step-text {
  min-width: 0;
  color: var(--color-text-title, #24352f);
  font-size: 25rpx;
  line-height: 1.55;
}

.recipe-safety-note {
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: var(--color-peach-light, #ffe7e3);
  color: #b64f4f;
  font-size: 23rpx;
  line-height: 1.5;
}

.inventory-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 40;
  background: rgba(31, 45, 42, 0.38);
  backdrop-filter: blur(8rpx);
}

.inventory-panel {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 42rpx;
  max-height: 72vh;
  padding: 26rpx;
  overflow-y: auto;
  border: 2rpx solid rgba(234, 219, 196, 0.72);
  border-radius: 42rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  box-shadow: 0 18rpx 46rpx rgba(31, 45, 42, 0.14);
}

.inventory-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.inventory-title {
  color: var(--color-text-title, #24352f);
  font-size: 32rpx;
  font-weight: 800;
}

.inventory-close {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: var(--ice-100, #ddf4ff);
  color: var(--ice-700, #1f6d89);
  font-size: 40rpx;
  line-height: 1;
}

.inventory-empty {
  margin-top: 24rpx;
  padding: 34rpx;
  border: 2rpx dashed rgba(88, 201, 139, 0.2);
  border-radius: 28rpx;
  background: #ffffff;
  color: var(--color-text-sub, #778781);
  text-align: center;
}

.inventory-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 22rpx;
}

.inventory-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(100, 181, 246, 0.1);
  border-radius: 24rpx;
  background: #ffffff;
}

.inventory-item-main {
  min-width: 0;
  flex: 1;
}

.inventory-name {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 28rpx;
  font-weight: 800;
}

.inventory-meta {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-sub, #778781);
  font-size: 23rpx;
}

.inventory-actions {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.inventory-delete {
  min-width: 96rpx;
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: var(--color-peach-light, #ffe7e3);
  color: #d95d55;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1;
}
