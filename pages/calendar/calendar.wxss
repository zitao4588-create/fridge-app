.calendar-page {
  padding: 24rpx 28rpx calc(140rpx + env(safe-area-inset-bottom));
}

/* 月历卡片 */
.cal-card {
  padding: 26rpx 22rpx 30rpx;
  border-radius: 34rpx;
  background: var(--grad-card);
  box-shadow: var(--shadow-1), var(--hi-inset);
}

.month-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.month-nav {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 40rpx;
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
  box-shadow: var(--shadow-1);
}

.month-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.month-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.today-btn {
  font-size: 22rpx;
  color: var(--ice-ink, #1f6d89);
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-top: 20rpx;
}

.week-grid text {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-light, #9aa9a1);
}

.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-top: 8rpx;
}

.day-cell {
  position: relative;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-number {
  width: 58rpx;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 26rpx;
  color: var(--text-main, #253730);
}

.day-cell.muted .day-number {
  color: #cfd8d3;
}

.day-cell.today .day-number {
  line-height: 54rpx;
  border: 2rpx solid var(--brand-mint, #28b978);
  color: var(--brand-mint-deep, #087a49);
  font-weight: 700;
}

.day-cell.selected .day-number {
  border: none;
  line-height: 58rpx;
  color: #ffffff;
  background: var(--brand-mint, #28b978);
}

.day-dot {
  position: absolute;
  left: 50%;
  bottom: 6rpx;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--honey, #ffb23e);
}

/* 统计卡（图标 + 大数字） */
.stat-row {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  background: var(--grad-card);
  box-shadow: var(--shadow-1), var(--hi-inset);
}

.stat-ic {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 16rpx;
  background: var(--brand-mint-soft, #eaf8ee);
}

.stat-card.warning .stat-ic {
  background: var(--honey-bg, #fff5dc);
}

.stat-card.danger .stat-ic {
  background: var(--coral-bg, #ffece6);
}

.stat-col {
  display: flex;
  flex-direction: column;
}

.stat-num {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.1;
  color: var(--brand-mint-deep, #087a49);
}

.stat-card.warning .stat-num {
  color: var(--honey-deep, #b96a12);
}

.stat-card.danger .stat-num {
  color: var(--coral-deep, #c94238);
}

.stat-name {
  font-size: 20rpx;
  color: var(--text-sub, #6f7c74);
}

/* 选中日 */
.sel-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 28rpx 4rpx 16rpx;
}

.sel-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.sel-count {
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
}

.sel-empty {
  padding: 48rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light, #9aa9a1);
  border: 2rpx dashed var(--cream-line, #eadbc4);
  border-radius: 22rpx;
}

/* 列表行 */
.list-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 22rpx;
  background: var(--grad-card);
  box-shadow: var(--shadow-1);
}

.list-main {
  flex: 1;
  min-width: 0;
}

.list-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main, #253730);
}

.list-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-sub, #6f7c74);
}

.tag-inline {
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.tag-inline.normal {
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.tag-inline.expiring {
  color: var(--honey-deep, #b96a12);
  background: var(--honey-bg, #fff5dc);
}

.tag-inline.overdue {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

.row-actions {
  display: flex;
  gap: 10rpx;
}

.row-btn {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--ice-ink, #1f6d89);
  background: var(--ice-soft, #ddf4ff);
}

.row-btn.danger {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

/* 底部弹层 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(37, 55, 48, 0.38);
  z-index: 50;
  display: flex;
  align-items: flex-end;
}

.sheet {
  position: relative;
  width: 100%;
  max-height: 78vh;
  padding: 32rpx 28rpx 48rpx;
  border-radius: 40rpx 40rpx 0 0;
  background: var(--cream-bg-2, #fffaf0);
  box-shadow: var(--shadow-2);
}

.sheet::before {
  content: '';
  position: absolute;
  top: 14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(37, 55, 48, 0.16);
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin: 12rpx 0 20rpx;
}

.sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.sheet-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
}

.sheet-close {
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
  background: #ffffff;
  box-shadow: var(--shadow-1);
}

.sheet-body {
  max-height: 64vh;
}
