.calendar-page {
  padding: 24rpx 28rpx 64rpx;
}

/* 月历卡片 */
.cal-card {
  padding: 24rpx 22rpx 28rpx;
  border-radius: 28rpx;
  background: var(--cream-surface, #fffef8);
  border: 2rpx solid var(--cream-line, #eadbc4);
  box-shadow: var(--shadow-soft, 0 10rpx 22rpx rgba(135, 105, 64, 0.08));
}

.month-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.month-nav {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 40rpx;
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.month-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.month-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.today-btn {
  font-size: 22rpx;
  color: var(--ice-ink, #1f6d89);
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-top: 20rpx;
}

.week-grid text {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-light, #9aa9a1);
}

.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-top: 8rpx;
}

.day-cell {
  height: 84rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.day-number {
  font-size: 26rpx;
  color: var(--text-main, #253730);
}

.day-cell.muted .day-number {
  color: var(--text-light, #cfd8d3);
}

.day-cell.selected .day-number {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 50%;
  color: #ffffff;
  background: var(--brand-mint, #28b978);
}

.day-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--honey, #ffb23e);
}

/* 统计 */
.stat-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 22rpx 0;
  border-radius: 24rpx;
  background: var(--cream-surface, #fffef8);
  border: 2rpx solid var(--cream-line, #eadbc4);
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--brand-mint-deep, #087a49);
}

.stat-card.warning .stat-num {
  color: var(--honey-deep, #b96a12);
}

.stat-card.danger .stat-num {
  color: var(--coral-deep, #c94238);
}

.stat-name {
  font-size: 22rpx;
  color: var(--text-sub, #6f7c74);
}

/* 选中日 */
.sel-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 28rpx 4rpx 16rpx;
}

.sel-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.sel-count {
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
}

.sel-empty {
  padding: 48rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light, #9aa9a1);
  border: 2rpx dashed var(--cream-line, #eadbc4);
  border-radius: 20rpx;
}

/* 列表行（与首页一致的视觉） */
.list-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  background: var(--cream-surface, #fffef8);
  border: 2rpx solid var(--cream-line, #eadbc4);
}

.list-main {
  flex: 1;
  min-width: 0;
}

.list-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main, #253730);
}

.list-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-sub, #6f7c74);
}

.tag-inline {
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.tag-inline.normal {
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.tag-inline.expiring {
  color: var(--honey-deep, #b96a12);
  background: var(--honey-bg, #fff5dc);
}

.tag-inline.overdue {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

.row-actions {
  display: flex;
  gap: 10rpx;
}

.row-btn {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--ice-ink, #1f6d89);
  background: var(--ice-soft, #ddf4ff);
}

.row-btn.danger {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

/* 底部弹层 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(37, 55, 48, 0.35);
  z-index: 50;
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  max-height: 78vh;
  padding: 28rpx 28rpx 48rpx;
  border-radius: 36rpx 36rpx 0 0;
  background: var(--cream-bg-2, #fffaf0);
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.sheet-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
}

.sheet-close {
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
  background: var(--cream-surface, #fffef8);
}

.sheet-body {
  max-height: 64vh;
}
