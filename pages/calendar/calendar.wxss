.calendar-page {
  padding-bottom: 72rpx;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 14% 4%, rgba(221, 248, 232, 0.76), rgba(221, 248, 232, 0) 260rpx),
    radial-gradient(circle at 88% 16%, rgba(221, 244, 255, 0.82), rgba(221, 244, 255, 0) 260rpx),
    linear-gradient(180deg, #f7fff6 0%, #fff8ea 58%, #ffffff 100%);
}

.calendar-card {
  position: relative;
  overflow: hidden;
  padding: 26rpx;
  border: 2rpx solid rgba(100, 181, 246, 0.2);
  border-radius: 42rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(237, 249, 255, 0.82) 100%);
  box-shadow:
    inset 0 4rpx 12rpx rgba(255, 255, 255, 0.92),
    var(--shadow-ice, 0 10rpx 28rpx rgba(92, 160, 190, 0.18));
}

.calendar-card::before {
  content: "";
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  top: 14rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.98), rgba(100, 181, 246, 0.1));
}

.month-row {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 88rpx minmax(0, 1fr) 88rpx;
  align-items: center;
  gap: 24rpx;
}

.month-button {
  width: 88rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-primary-deep, #1f9f73);
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(80, 130, 100, 0.12);
}

.month-title {
  min-width: 0;
  overflow: hidden;
  color: var(--color-text-title, #24352f);
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.week-grid,
.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-grid {
  margin-top: 28rpx;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.day-grid {
  gap: 8rpx;
  margin-top: 14rpx;
}

.day-cell {
  position: relative;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(100, 181, 246, 0.08);
  border-radius: 22rpx;
  color: var(--color-text-title, #24352f);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 -4rpx 10rpx rgba(100, 181, 246, 0.06);
}

.day-cell.muted {
  color: var(--color-text-light, #a5b1ad);
  background: rgba(255, 255, 255, 0.42);
}

.day-cell.selected {
  border-color: rgba(88, 201, 139, 0.18);
  background: linear-gradient(180deg, #74dda0 0%, #35ba78 100%);
  color: #ffffff;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(88, 201, 139, 0.24);
}

.day-cell.marked:not(.selected) {
  border-color: rgba(100, 181, 246, 0.16);
  background: var(--color-blue-ice, #ddf3ff);
  color: #3a91b6;
}

.day-number {
  font-size: 26rpx;
}

.day-dot {
  position: absolute;
  right: 8rpx;
  top: 6rpx;
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: var(--color-orange, #ffb85c);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 10rpx rgba(255, 184, 77, 0.28);
}

.calendar-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 18rpx;
}

.calendar-stat-card {
  position: relative;
  overflow: hidden;
  min-width: 0;
  height: 104rpx;
  padding: 14rpx 18rpx;
  border-radius: 34rpx;
  box-shadow:
    inset 0 4rpx 10rpx rgba(255, 255, 255, 0.9),
    0 14rpx 28rpx rgba(82, 124, 94, 0.14);
}

.calendar-stat-card::after {
  content: "";
  position: absolute;
  right: -18rpx;
  bottom: -20rpx;
  width: 82rpx;
  height: 82rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.38);
}

.calendar-stat-card.total {
  background: linear-gradient(180deg, #ffffff 0%, #bff0d2 100%);
}

.calendar-stat-card.warning {
  background: linear-gradient(180deg, #fffdf7 0%, #ffd991 100%);
}

.calendar-stat-card.danger {
  background: linear-gradient(180deg, #ffffff 0%, #ffc9c0 100%);
}

.calendar-stat-card:active,
.expiry-recipe-card:active {
  transform: scale(0.985);
}

.calendar-stat-label {
  position: relative;
  z-index: 1;
  display: block;
  overflow: hidden;
  color: rgba(36, 53, 47, 0.68);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.calendar-stat-value {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.calendar-stat-value.total {
  color: #1f9f73;
}

.calendar-stat-value.warning {
  color: #c97922;
}

.calendar-stat-value.danger {
  color: #d95d55;
}

.expiry-card {
  position: relative;
  overflow: hidden;
  margin-top: 22rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.1);
  border-radius: 42rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #fff8ea 100%),
    radial-gradient(circle at 92% 8%, rgba(221, 248, 232, 0.68), rgba(221, 248, 232, 0) 170rpx);
  box-shadow: var(--shadow-card, 0 12rpx 32rpx rgba(80, 130, 100, 0.14));
}

.expiry-card::before {
  display: none;
}

.expiry-food-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.expiry-food-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--color-mint, #def7e9);
  color: var(--color-primary-deep, #1f9f73);
  font-size: 22rpx;
  font-weight: 800;
}

.expiry-recipe-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.expiry-recipe-card {
  padding: 24rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.12);
  border-radius: 32rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #fffaf0 100%);
  box-shadow: 0 12rpx 30rpx rgba(120, 92, 60, 0.08);
}

.expiry-recipe-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.expiry-recipe-main {
  min-width: 0;
  flex: 1;
}

.expiry-recipe-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.expiry-recipe-action {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: var(--color-mint, #def7e9);
  color: var(--color-primary-deep, #1f9f73);
  font-size: 22rpx;
  font-weight: 800;
}

.expiry-match-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.expiry-match-box {
  min-height: 120rpx;
  padding: 16rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.08);
  border-radius: 24rpx;
  background: #f7fff6;
}

.expiry-match-box.missing {
  border-color: rgba(255, 184, 77, 0.12);
  background: #fff8ea;
}

.expiry-match-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 22rpx;
  font-weight: 800;
}

.expiry-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.expiry-food-chip.missing {
  background: var(--color-orange-light, #fff0d6);
  color: #c46d17;
}

.expiry-empty-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-text-light, #a5b1ad);
  font-size: 22rpx;
  font-weight: 700;
}

.expiry-priority-line {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fff9ea 0%, #fff0d6 100%);
  color: #8a6a2f;
  font-size: 23rpx;
  line-height: 1.5;
}

.expiry-empty {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 2rpx dashed rgba(88, 201, 139, 0.2);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fff6 100%);
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  line-height: 1.5;
}

.safety-box {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(255, 107, 107, 0.12);
  border-radius: 26rpx;
  background: linear-gradient(180deg, #fff8f6 0%, #ffe7e3 100%);
}

.safety-title {
  display: block;
  color: var(--color-expired, #ff7d73);
  font-size: 24rpx;
  font-weight: 900;
}

.safety-line {
  display: block;
  margin-top: 8rpx;
  color: #b64f4f;
  font-size: 23rpx;
  line-height: 1.5;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 34rpx 2rpx 18rpx;
}

.date-head {
  margin-top: 22rpx;
}

.section-title {
  color: var(--color-text-title, #24352f);
  font-size: 30rpx;
  font-weight: 900;
}

.section-count {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 14rpx rgba(80, 130, 100, 0.08);
}

.date-empty {
  margin-top: 18rpx;
  padding: 28rpx 24rpx;
  border: 2rpx dashed rgba(100, 181, 246, 0.2);
  border-radius: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f1fbff 100%);
  color: var(--color-text-sub, #778781);
  font-size: 25rpx;
  text-align: center;
}

.selected-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 18rpx;
}

.selected-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.1);
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(80, 130, 100, 0.08);
}

.selected-name {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 30rpx;
  font-weight: 900;
}

.selected-meta {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
}

.status-chip {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.recipe-detail-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 45;
  background: rgba(31, 45, 42, 0.38);
  backdrop-filter: blur(8rpx);
}

.recipe-detail-panel {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 42rpx;
  max-height: 76vh;
  padding: 28rpx;
  overflow-y: auto;
  border: 2rpx solid rgba(255, 184, 77, 0.16);
  border-radius: 42rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(221, 248, 232, 0.66), rgba(221, 248, 232, 0) 180rpx),
    linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  box-shadow: 0 18rpx 54rpx rgba(31, 45, 42, 0.18);
}

.recipe-detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.recipe-detail-kicker {
  display: block;
  color: var(--color-primary-deep, #1f9f73);
  font-size: 24rpx;
  font-weight: 900;
}

.recipe-detail-title {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-title, #24352f);
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.recipe-detail-close {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-primary-deep, #1f9f73);
  font-size: 40rpx;
  line-height: 1;
  box-shadow: 0 8rpx 18rpx rgba(80, 130, 100, 0.12);
}

.recipe-detail-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.recipe-detail-summary text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(237, 249, 255, 0.9);
  color: #3a91b6;
  font-size: 22rpx;
  font-weight: 800;
}

.recipe-detail-block {
  margin-top: 24rpx;
}

.recipe-detail-block-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 26rpx;
  font-weight: 900;
}

.recipe-detail-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.recipe-step {
  display: grid;
  grid-template-columns: 46rpx minmax(0, 1fr);
  gap: 14rpx;
  margin-top: 14rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.08);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.86);
}

.recipe-step-number {
  width: 46rpx;
  height: 46rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #74dda0 0%, #35ba78 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 46rpx;
  text-align: center;
}

.recipe-step-text {
  min-width: 0;
  color: var(--color-text-title, #24352f);
  font-size: 25rpx;
  line-height: 1.55;
}

.recipe-safety-note {
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: var(--color-peach-light, #ffe7e3);
  color: #b64f4f;
  font-size: 23rpx;
  line-height: 1.5;
}

.inventory-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 40;
  background: rgba(31, 45, 42, 0.38);
  backdrop-filter: blur(8rpx);
}

.inventory-panel {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 42rpx;
  max-height: 72vh;
  padding: 26rpx;
  overflow-y: auto;
  border: 2rpx solid rgba(88, 201, 139, 0.12);
  border-radius: 42rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  box-shadow: 0 18rpx 54rpx rgba(31, 45, 42, 0.18);
}

.inventory-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.inventory-title {
  color: var(--color-text-title, #24352f);
  font-size: 32rpx;
  font-weight: 900;
}

.inventory-close {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f7fff6;
  color: var(--color-primary-deep, #1f9f73);
  font-size: 40rpx;
  line-height: 1;
}

.inventory-empty {
  margin-top: 24rpx;
  padding: 34rpx;
  border: 2rpx dashed rgba(88, 201, 139, 0.2);
  border-radius: 28rpx;
  background: #ffffff;
  color: var(--color-text-sub, #778781);
  text-align: center;
}

.inventory-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 22rpx;
}

.inventory-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(100, 181, 246, 0.1);
  border-radius: 24rpx;
  background: #ffffff;
}

.inventory-name {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 28rpx;
  font-weight: 900;
}

.inventory-meta {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-sub, #778781);
  font-size: 23rpx;
}
