.calendar-page {
  padding: 24rpx 28rpx calc(152rpx + env(safe-area-inset-bottom));
}

/* 月历卡片 */
.cal-card {
  padding: 26rpx 22rpx 30rpx;
  border-radius: 34rpx;
  background: var(--grad-card);
  box-shadow: var(--shadow-1), var(--hi-inset);
}

.month-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.month-nav {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 40rpx;
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
  box-shadow: var(--shadow-1);
}

.month-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.month-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.today-btn {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.week-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-top: 20rpx;
}

.week-grid text {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-light, #647264);
}

.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-top: 8rpx;
}

.day-cell {
  position: relative;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-number {
  width: 58rpx;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  border-radius: 50%;
  font-size: 26rpx;
  color: var(--text-main, #253730);
}

.day-cell.muted .day-number {
  color: #cfd8d3;
}

.day-cell.today .day-number {
  line-height: 54rpx;
  border: 2rpx solid var(--brand-mint, #28b978);
  color: var(--brand-mint-deep, #087a49);
  font-weight: 700;
}

.day-cell.selected .day-number {
  border: none;
  line-height: 58rpx;
  color: #ffffff;
  background: var(--brand-mint, #28b978);
}

.day-dot {
  position: absolute;
  left: 50%;
  bottom: 6rpx;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--honey, #ffb23e);
}

/* 统计卡（图标 + 大数字） */
.stat-row {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  background: var(--grad-card);
  box-shadow: var(--shadow-1), var(--hi-inset);
}

.stat-ic {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 16rpx;
  background: var(--brand-mint-soft, #eaf8ee);
}

.stat-card.warning .stat-ic {
  background: var(--honey-bg, #fff5dc);
}

.stat-card.danger .stat-ic {
  background: var(--coral-bg, #ffece6);
}

.stat-col {
  display: flex;
  flex-direction: column;
}

.stat-num {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.1;
  color: var(--brand-mint-deep, #087a49);
}

.stat-card.warning .stat-num {
  color: var(--honey-deep, #b96a12);
}

.stat-card.danger .stat-num {
  color: var(--coral-deep, #c94238);
}

.stat-name {
  font-size: 20rpx;
  color: var(--text-sub, #6f7c74);
}

/* 选中日 */
.sel-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 28rpx 4rpx 16rpx;
}

.sel-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.sel-count {
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
}

.sel-empty {
  padding: 48rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-light, #647264);
  border: 2rpx dashed var(--cream-line, #eadbc4);
  border-radius: 22rpx;
}

/* 列表行 */
.list-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 22rpx;
  background: var(--grad-card);
  box-shadow: var(--shadow-1);
}

.list-main {
  flex: 1;
  min-width: 0;
}

.list-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main, #253730);
}

.list-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-sub, #6f7c74);
}

.tag-inline {
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.tag-inline.normal {
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
}

.tag-inline.expiring {
  color: var(--honey-deep, #b96a12);
  background: var(--honey-bg, #fff5dc);
}

.tag-inline.overdue {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

.row-actions {
  display: flex;
  gap: 16rpx;
}

.row-btn {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--neutral-ink, #4d5a52);
  background: var(--neutral-soft, #eef0ec);
}

.row-btn.danger {
  color: var(--coral-deep, #c94238);
  background: var(--coral-bg, #ffece6);
}

/* 底部弹层 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(37, 55, 48, 0.38);
  z-index: 50;
  display: flex;
  align-items: flex-end;
}

.sheet {
  position: relative;
  width: 100%;
  max-height: 78vh;
  padding: 32rpx 28rpx 48rpx;
  border-radius: 40rpx 40rpx 0 0;
  background: var(--cream-bg-2, #fffaf0);
  box-shadow: var(--shadow-2);
}

.sheet::before {
  content: '';
  position: absolute;
  top: 14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(37, 55, 48, 0.16);
}

.sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin: 12rpx 0 20rpx;
}

.sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main, #253730);
}

.sheet-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
}

.sheet-close {
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--text-sub, #6f7c74);
  background: #ffffff;
  box-shadow: var(--shadow-1);
}

.sheet-body {
  max-height: 64vh;
}


/* 开饭雷达（玻璃雷达屏，恢复原版 UI） */
.meal-radar-card {
  position: relative;
  overflow: hidden;
  margin-top: 22rpx;
  padding: 26rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 40rpx;
  background: linear-gradient(180deg, var(--cream-surface, #fffef8) 0%, var(--cream-bg, #fff6e8) 100%);
  box-shadow: inset 0 6rpx 14rpx rgba(255, 255, 255, 0.92), 0 18rpx 42rpx rgba(135, 105, 64, 0.13);
}

.meal-radar-card::before {
  content: "";
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  top: 16rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0));
}

.meal-radar-decor {
  position: absolute;
  z-index: 0;
  pointer-events: none;
}

.meal-radar-decor.sparkle {
  left: 28rpx;
  bottom: 28rpx;
  width: 34rpx;
  height: 34rpx;
  opacity: 0.72;
}

.meal-radar-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.meal-radar-title-wrap {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.meal-radar-mascot {
  width: 86rpx;
  height: 86rpx;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, var(--ice-soft, #ddf4ff) 100%);
  box-shadow: 0 10rpx 22rpx rgba(46, 156, 200, 0.12);
}

.meal-radar-title {
  display: block;
  color: var(--text-main, #24352f);
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.15;
}

.meal-radar-console {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 246rpx minmax(0, 1fr);
  gap: 18rpx;
  margin-top: 22rpx;
  align-items: stretch;
}

.meal-radar-screen {
  position: relative;
  min-height: 246rpx;
  overflow: hidden;
  border: 5rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 38rpx;
  background:
    radial-gradient(circle at 50% 42%, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0) 76rpx),
    linear-gradient(180deg, var(--ice-bg, #f5fcff) 0%, var(--ice-soft, #e4f7ff) 42%, var(--ice-mid, #c7edfc) 100%);
  box-shadow:
    inset 0 8rpx 18rpx rgba(255, 255, 255, 0.96),
    inset 0 -16rpx 28rpx rgba(58, 175, 216, 0.12),
    var(--shadow-ice, 0 14rpx 30rpx rgba(58, 175, 216, 0.12));
}

.meal-radar-screen.high .radar-score-value { color: var(--ice-ink, #1f6d89); }
.meal-radar-screen.medium .radar-score-value { color: var(--honey-deep, #c86f13); }
.meal-radar-screen.low .radar-score-value { color: var(--coral-deep, #e85242); }

.radar-orbit {
  position: absolute;
  left: 50%;
  top: 50%;
  border: 2rpx solid rgba(56, 166, 215, 0.22);
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.orbit-one { width: 202rpx; height: 202rpx; }
.orbit-two { width: 142rpx; height: 142rpx; }
.orbit-three { width: 80rpx; height: 80rpx; }

.radar-sweep {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 104rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(46, 156, 200, 0) 0%, rgba(46, 156, 200, 0.9) 100%);
  transform-origin: 0 50%;
  animation: radarSweep 3.4s linear infinite;
}

.radar-sweep::after {
  content: "";
  position: absolute;
  right: 0;
  top: 50%;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(46, 156, 200, 0.95);
  transform: translateY(-50%);
  box-shadow: 0 0 10rpx rgba(46, 156, 200, 0.6);
}

.radar-core {
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  top: 50%;
  z-index: 1;
  padding: 18rpx 12rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  text-align: center;
  transform: translateY(-50%);
}

.radar-score-label {
  display: block;
  color: var(--ice-ink, #22789e);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
}

.radar-score-value {
  display: block;
  margin-top: 14rpx;
  color: var(--ice-ink, #1f6d89);
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1;
}

@keyframes radarSweep {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.meal-radar-explain {
  min-width: 0;
  padding: 20rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 4rpx 10rpx rgba(255, 255, 255, 0.9);
}

.meal-radar-verdict {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.3;
}

.meal-radar-verdict.high { color: var(--brand-mint-deep, #087a49); }
.meal-radar-verdict.medium { color: var(--honey-deep, #b96a12); }
.meal-radar-verdict.low { color: var(--coral-deep, #c94238); }

.meal-radar-ranges {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 14rpx;
}

.meal-radar-ranges text {
  display: block;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(245, 252, 255, 0.92);
  color: var(--text-sub, #6d7e76);
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.25;
  opacity: 0.5;
}

.meal-radar-ranges text.on {
  opacity: 1;
  background: #ffffff;
  color: var(--ice-ink, #1f6d89);
  box-shadow: var(--shadow-1);
}

.meal-radar-priority {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  background: linear-gradient(180deg, var(--honey-bg, #FFF5DC) 0%, var(--honey-soft, #FFE7B2) 100%);
  box-shadow: var(--shadow-warning, 0 6rpx 14rpx rgba(255, 178, 62, 0.14));
}

.meal-radar-priority.empty {
  background: linear-gradient(180deg, #ffffff 0%, var(--cream-bg-2, #fffaf0) 100%);
  box-shadow: 0 8rpx 18rpx rgba(135, 105, 64, 0.08);
}

.meal-radar-priority-label {
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--honey-deep, #b96a12);
  font-size: 22rpx;
  font-weight: 800;
}

.meal-radar-priority-chips {
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.meal-radar-priority-chips text {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #8a520e;
  font-size: 22rpx;
  font-weight: 800;
}

.meal-radar-priority-empty {
  min-width: 0;
  color: var(--text-sub, #6d7e76);
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.35;
}
