.confirm-page {
  overflow-x: hidden;
  background:
    radial-gradient(circle at 12% 4%, rgba(221, 248, 232, 0.82), rgba(221, 248, 232, 0) 250rpx),
    linear-gradient(180deg, #fff8ea 0%, #f7fff6 58%, #ffffff 100%);
}

.confirm-hero {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
  border-color: rgba(88, 201, 139, 0.14);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.94) 0%, rgba(221, 248, 232, 0.84) 54%, rgba(237, 249, 255, 0.78) 100%);
  box-shadow: var(--shadow-card, 0 12rpx 30rpx rgba(80, 130, 100, 0.11));
}

.confirm-hero-mark {
  position: relative;
  flex-shrink: 0;
  width: 82rpx;
  height: 82rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #ddf3ff 100%);
  box-shadow: inset 0 4rpx 10rpx rgba(255, 255, 255, 0.9);
}

.confirm-hero-mark::before {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 18rpx;
  width: 36rpx;
  height: 36rpx;
  border: 6rpx solid #1f9f73;
  border-radius: 999rpx;
}

.confirm-hero-mark::after {
  content: "";
  position: absolute;
  right: 14rpx;
  bottom: 16rpx;
  width: 26rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #1f9f73;
  transform: rotate(45deg);
}

.parse-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 22rpx;
  padding: 26rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.12);
  border-radius: 34rpx;
  background:
    linear-gradient(135deg, rgba(221, 248, 232, 0.84) 0%, rgba(255, 248, 236, 0.96) 46%, rgba(237, 249, 255, 0.9) 100%);
  box-shadow: 0 12rpx 30rpx rgba(80, 130, 100, 0.12);
}

.parse-label {
  display: block;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  font-weight: 700;
}

.parse-value {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-title, #24352f);
  font-size: 30rpx;
  font-weight: 900;
}

.notice-card {
  margin-top: 18rpx;
  padding: 22rpx 26rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.18);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fffdf8 0%, var(--color-orange-light, #fff0d6) 100%);
  color: #c46d17;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: var(--shadow-warning, 0 8rpx 20rpx rgba(255, 184, 77, 0.22));
}

.recognition-alert {
  position: relative;
  overflow: hidden;
  margin-top: 18rpx;
  padding: 24rpx 26rpx 24rpx 94rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.16);
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fffdf8 0%, #fff4d8 64%, #f7fff6 100%);
  box-shadow: 0 10rpx 26rpx rgba(144, 112, 58, 0.1);
}

.recognition-alert.real {
  border-color: rgba(88, 201, 139, 0.2);
  background: linear-gradient(135deg, #f7fff6 0%, #e7fff0 62%, #effaff 100%);
}

.recognition-alert.partial,
.recognition-alert.local,
.recognition-alert.unknown {
  border-color: rgba(100, 181, 246, 0.2);
  background: linear-gradient(135deg, #f8fdff 0%, #eaf7ff 62%, #f7fff6 100%);
}

.recognition-alert::before {
  content: "";
  position: absolute;
  left: 24rpx;
  top: 26rpx;
  width: 48rpx;
  height: 54rpx;
  border: 3rpx solid rgba(36, 169, 107, 0.16);
  border-radius: 16rpx 16rpx 14rpx 14rpx;
  background: linear-gradient(180deg, #e8fff2 0%, #c5f4dc 100%);
  box-shadow: inset 0 3rpx 8rpx rgba(255, 255, 255, 0.9);
}

.recognition-alert.real::before {
  border-color: rgba(36, 169, 107, 0.22);
  background: linear-gradient(180deg, #f8fff9 0%, #bff2d6 100%);
}

.recognition-alert.partial::before,
.recognition-alert.local::before,
.recognition-alert.unknown::before {
  border-color: rgba(64, 148, 220, 0.2);
  background: linear-gradient(180deg, #ffffff 0%, #d5efff 100%);
}

.recognition-alert::after {
  content: "";
  position: absolute;
  left: 40rpx;
  top: 56rpx;
  width: 20rpx;
  height: 8rpx;
  border-bottom: 4rpx solid #24352f;
  border-radius: 0 0 999rpx 999rpx;
}

.recognition-alert-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 28rpx;
  font-weight: 900;
}

.recognition-alert-desc {
  display: block;
  margin-top: 10rpx;
  color: #8a6a2f;
  font-size: 25rpx;
  line-height: 1.6;
}

.recommend-card {
  position: relative;
  overflow: hidden;
  margin-top: 18rpx;
  padding: 24rpx 26rpx;
  border: 2rpx solid rgba(100, 181, 246, 0.2);
  border-radius: 32rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(221, 244, 255, 0.7) 100%);
  box-shadow:
    inset 0 3rpx 10rpx rgba(255, 255, 255, 0.86),
    var(--shadow-ice, 0 10rpx 28rpx rgba(92, 160, 190, 0.18));
}

.recommend-card.active {
  border-color: rgba(88, 201, 139, 0.28);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(221, 248, 232, 0.8) 100%);
}

.recommend-card::before {
  content: "";
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 14rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96), rgba(100, 181, 246, 0.08));
}

.recommend-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.recommend-label {
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  font-weight: 700;
}

.recommend-value {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  padding: 7rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(88, 201, 139, 0.14);
  color: var(--color-primary-deep, #1f9f73);
  font-size: 30rpx;
  font-weight: 900;
}

.recommend-current {
  margin-top: 10rpx;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
}

.recommend-button {
  width: 100%;
  height: 72rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #73dda0 0%, #35ba78 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 72rpx;
  box-shadow: var(--shadow-button, 0 8rpx 18rpx rgba(88, 201, 139, 0.28));
}

.recommend-button::after {
  border: none;
}

.photo-preview-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(100, 181, 246, 0.18);
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, rgba(237, 249, 255, 0.78) 100%);
  box-shadow: var(--shadow-ice, 0 10rpx 28rpx rgba(92, 160, 190, 0.18));
}

.photo-preview-image {
  flex-shrink: 0;
  width: 150rpx;
  height: 150rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 28rpx;
  background: var(--color-bg-ice, #f1fbff);
  box-shadow: 0 8rpx 20rpx rgba(92, 160, 190, 0.18);
}

.photo-preview-copy {
  min-width: 0;
  flex: 1;
}

.photo-preview-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 28rpx;
  font-weight: 900;
}

.photo-preview-desc {
  display: block;
  margin-top: 10rpx;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  line-height: 1.45;
}

.form-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.1);
  border-radius: 38rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffaf0 100%);
  box-shadow: var(--shadow-card, 0 12rpx 32rpx rgba(80, 130, 100, 0.14));
}

.two-col {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 180rpx;
  gap: 20rpx;
}

.input,
.textarea,
.picker-field {
  border-color: var(--color-line, rgba(88, 201, 139, 0.13));
  border-radius: 30rpx;
}

.primary-button {
  height: 92rpx;
  font-weight: 900;
}

.required-date {
  color: var(--color-primary-deep, #1f9f73);
  font-weight: 800;
}
