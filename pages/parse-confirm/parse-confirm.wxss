.parse-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 30rpx;
  padding: 24rpx;
}

.parse-label {
  display: block;
  color: #64748b;
  font-size: 24rpx;
}

.parse-value {
  display: block;
  margin-top: 8rpx;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 700;
}

.notice-card {
  margin-top: 18rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  background: #fff7ed;
  color: #c2410c;
  font-size: 26rpx;
}

.mock-alert {
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid #fde68a;
  border-radius: 18rpx;
  background: #fffbeb;
}

.mock-alert-title {
  display: block;
  color: #92400e;
  font-size: 28rpx;
  font-weight: 700;
}

.mock-alert-desc {
  display: block;
  margin-top: 10rpx;
  color: #a16207;
  font-size: 25rpx;
  line-height: 1.6;
}

.form-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.two-col {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 180rpx;
  gap: 20rpx;
}

.required-date {
  color: #0f766e;
  font-weight: 600;
}
