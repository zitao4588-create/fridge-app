.form-page {
  overflow-x: hidden;
}

.form-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.option-grid {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option-chip {
  width: calc((100% - 28rpx) / 3);
  max-width: calc((100% - 28rpx) / 3);
  flex: 0 0 calc((100% - 28rpx) / 3);
  min-width: 0;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #dbe4ef;
  border-radius: 16rpx;
  background: #ffffff;
  color: #5f6f69;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.2;
  margin: 0;
  padding: 0 12rpx;
}

.option-chip.active {
  border-color: #1f9f73;
  background: #eefaf2;
  color: #1f9f73;
}

.required-date {
  color: #1f9f73;
  font-weight: 600;
}

.date-field {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.date-mode-switch {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.date-mode-button {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #dbe4ef;
  border-radius: 16rpx;
  background: #ffffff;
  color: #5f6f69;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.2;
  margin: 0;
  padding: 0 10rpx;
}

.date-mode-button::after,
.calendar-nav::after,
.calendar-day::after {
  border: 0;
}

.date-mode-button.active {
  border-color: #1f9f73;
  background: #eefaf2;
  color: #1f9f73;
}

.date-method {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 18rpx;
  border: 1rpx solid #e5eee8;
  border-radius: 18rpx;
  background: #fbfffd;
}

.date-method-error {
  border-color: #ff7d73;
}

.date-method-title {
  color: #24352f;
  font-size: 26rpx;
  font-weight: 800;
}

.selected-date-row {
  min-height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e5eee8;
  padding: 0 20rpx;
  color: #5f6f69;
  font-size: 25rpx;
  font-weight: 700;
}

.selected-date-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #a5b1ad;
}

.selected-date-value.active {
  color: #1f9f73;
}

.date-arrow {
  color: #a5b1ad;
  font-size: 36rpx;
  line-height: 1;
}

.date-popup-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99;
  display: flex;
  align-items: flex-end;
  background: rgba(15, 23, 42, 0.42);
  padding: 24rpx;
}

.date-popup {
  width: 100%;
  border-radius: 28rpx 28rpx 20rpx 20rpx;
  background: #ffffff;
  padding: 24rpx;
  box-shadow: 0 -18rpx 44rpx rgba(15, 23, 42, 0.16);
}

.date-popup-head {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
}

.date-popup-title {
  color: #24352f;
  font-size: 32rpx;
  font-weight: 800;
  white-space: nowrap;
}

.calendar-panel {
  border-radius: 18rpx;
  background: #fbfffd;
  padding: 18rpx;
}

.calendar-month-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.calendar-nav {
  width: 76rpx;
  max-width: 76rpx;
  min-width: 0;
  flex: 0 0 76rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #eefaf2;
  color: #1f9f73;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.calendar-title {
  flex: 1;
  min-width: 0;
  text-align: center;
  color: #24352f;
  font-size: 30rpx;
  font-weight: 800;
  white-space: nowrap;
}

.calendar-week-grid,
.calendar-day-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
}

.calendar-week-grid {
  margin-top: 18rpx;
  color: #778781;
  font-size: 22rpx;
  text-align: center;
}

.calendar-day-grid {
  gap: 8rpx;
  margin-top: 10rpx;
}

.calendar-day {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #ffffff;
  color: #24352f;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.calendar-day.muted {
  color: #cbd5e1;
}

.calendar-day.selected {
  background: #1f9f73;
  color: #ffffff;
}

.date-result {
  min-height: 58rpx;
  display: flex;
  align-items: center;
  border-radius: 14rpx;
  background: #ffffff;
  padding: 0 20rpx;
  color: #778781;
  font-size: 25rpx;
}

.date-result.active {
  background: #ecfdf5;
  color: #1f9f73;
  font-weight: 700;
}

.date-separator {
  text-align: center;
  color: #a5b1ad;
  font-size: 24rpx;
  font-weight: 700;
}

.input-error {
  border-color: #ff7d73;
  background: #ffe7e3;
}

.field-error {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #d95d55;
}

.form-page {
  min-height: 100vh;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 12% 4%, rgba(221, 248, 232, 0.9), rgba(221, 248, 232, 0) 28%),
    linear-gradient(180deg, #fff8ea 0%, #f7fff6 58%, #ffffff 100%);
}

.form-hero {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
  border-color: rgba(88, 201, 139, 0.14);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.94) 0%, rgba(221, 248, 232, 0.84) 54%, rgba(255, 248, 236, 0.9) 100%);
  box-shadow: var(--shadow-card, 0 12rpx 30rpx rgba(80, 130, 100, 0.11));
}

.form-hero-subtitle {
  margin-top: 10rpx;
  color: #778781;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.45;
}

.form-hero-mark {
  position: relative;
  flex-shrink: 0;
  width: 82rpx;
  height: 82rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.84);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #def7e9 100%);
  box-shadow: inset 0 4rpx 10rpx rgba(255, 255, 255, 0.9);
}

.form-hero-mark::before,
.form-hero-mark::after {
  content: "";
  position: absolute;
}

.form-hero-mark::before {
  left: 20rpx;
  top: 24rpx;
  width: 38rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #1f9f73;
  box-shadow: 0 16rpx 0 #67bce8;
}

.form-hero-mark::after {
  right: 16rpx;
  top: 16rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #ffb85c;
}

.form-card {
  position: relative;
  overflow: hidden;
  margin-top: 22rpx;
  padding: 30rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.14);
  border-radius: 38rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(255, 248, 236, 0.92) 100%);
  box-shadow: 0 14rpx 34rpx rgba(120, 92, 60, 0.1);
}

.form-card::before {
  content: "";
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  top: 14rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.92), rgba(88, 201, 139, 0.14));
}

.field {
  position: relative;
  z-index: 1;
}

.field-label {
  color: #24352f;
  font-weight: 900;
}

.input,
.textarea {
  border: 2rpx solid var(--color-line, rgba(88, 201, 139, 0.13));
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #24352f;
  box-shadow: inset 0 2rpx 8rpx rgba(80, 130, 100, 0.04);
}

.textarea {
  border-radius: 30rpx;
}

.option-grid {
  gap: 14rpx;
}

.option-chip {
  height: 76rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.14);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #526463;
  font-weight: 800;
  box-shadow: 0 8rpx 16rpx rgba(80, 130, 100, 0.06);
}

.option-chip.active {
  border-color: rgba(88, 201, 139, 0.44);
  background: linear-gradient(180deg, #def7e9 0%, #f7fff6 100%);
  color: #1f9f73;
  box-shadow: 0 8rpx 18rpx rgba(88, 201, 139, 0.18);
}

.option-chip::after {
  border: 0;
}

.date-mode-switch {
  gap: 14rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(221, 244, 255, 0.56);
  box-shadow: inset 0 2rpx 8rpx rgba(100, 181, 246, 0.08);
}

.date-mode-button {
  height: 68rpx;
  border: 0;
  border-radius: 999rpx;
  background: transparent;
  color: #778781;
  font-weight: 900;
}

.date-mode-button.active {
  border: 0;
  background: linear-gradient(180deg, #73dca2 0%, #1f9f73 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(88, 201, 139, 0.24);
}

.date-method {
  gap: 16rpx;
  padding: 22rpx;
  border: 2rpx solid rgba(120, 190, 220, 0.22);
  border-radius: 32rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(221, 244, 255, 0.52)),
    linear-gradient(90deg, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0));
  box-shadow:
    inset 0 4rpx 10rpx rgba(255, 255, 255, 0.9),
    0 10rpx 22rpx rgba(92, 160, 190, 0.1);
}

.date-method-error {
  border-color: rgba(255, 107, 107, 0.5);
  background: linear-gradient(180deg, #ffffff 0%, #ffe7e3 100%);
}

.date-method-title {
  color: #24352f;
  font-size: 27rpx;
}

.selected-date-row,
.date-result {
  min-height: 68rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.12);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #526463;
}

.selected-date-value {
  color: #a5b1ad;
  font-weight: 800;
}

.selected-date-value.active,
.date-result.active {
  color: #1f9f73;
}

.date-result.active {
  background: #def7e9;
  font-weight: 900;
}

.date-arrow {
  color: #67bce8;
}

.date-popup-mask {
  background: rgba(38, 50, 56, 0.36);
}

.date-popup {
  border: 2rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 42rpx 42rpx 28rpx 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  box-shadow: 0 -18rpx 48rpx rgba(80, 130, 100, 0.18);
}

.date-popup-title {
  color: #24352f;
  font-size: 34rpx;
}

.calendar-panel {
  border: 2rpx solid rgba(120, 190, 220, 0.2);
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(237, 249, 255, 0.82), rgba(246, 255, 245, 0.72));
  box-shadow: inset 0 3rpx 8rpx rgba(255, 255, 255, 0.92);
}

.calendar-nav {
  border-radius: 999rpx;
  background: #ffffff;
  color: #1f9f73;
  box-shadow: 0 6rpx 14rpx rgba(80, 130, 100, 0.08);
}

.calendar-title {
  color: #24352f;
}

.calendar-week-grid {
  color: #778781;
  font-weight: 800;
}

.calendar-day {
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #24352f;
}

.calendar-day.selected {
  background: linear-gradient(180deg, #73dca2 0%, #1f9f73 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(88, 201, 139, 0.22);
}

.primary-button {
  margin-top: 8rpx;
  height: 92rpx;
  font-weight: 900;
}

.input-error {
  border-color: rgba(255, 107, 107, 0.62);
  background: #fff7f3;
}

.field-error {
  color: #ff7d73;
  font-weight: 800;
}
