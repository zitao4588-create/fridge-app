<view class="page form-page">
  <view class="form-hero card">
    <view>
      <view class="page-title">{{isEdit ? '编辑食品' : '添加食品'}}</view>
      <view class="form-hero-subtitle">名称、品类和到期日是库存提醒的关键。</view>
    </view>
    <view class="form-hero-mark"></view>
  </view>

  <view class="form-card card">
    <view class="field">
      <text class="field-label">食品名称</text>
      <input class="input {{errors.name ? 'input-error' : ''}}" value="{{form.name}}" placeholder="例如：牛奶、鸡蛋、菠菜" data-field="name" bindinput="handleInput" />
      <text wx:if="{{errors.name}}" class="field-error">{{errors.name}}</text>
    </view>

    <view class="field">
      <text class="field-label">品类</text>
      <view class="option-grid category-options">
        <button
          class="option-chip {{form.category === item ? 'active' : ''}}"
          wx:for="{{categoryOptions}}"
          wx:key="*this"
          data-index="{{index}}"
          bindtap="handleCategoryTap"
        >
          {{item}}
        </button>
      </view>
    </view>

    <view class="field date-field">
      <text class="field-label">过期日期</text>

      <view class="date-mode-switch">
        <button
          class="date-mode-button {{dateMode === 'production' ? 'active' : ''}}"
          data-mode="production"
          bindtap="handleDateModeTap"
        >
          生产日 + 保质期
        </button>
        <button
          class="date-mode-button {{dateMode === 'expire' ? 'active' : ''}}"
          data-mode="expire"
          bindtap="handleDateModeTap"
        >
          直接选过期日
        </button>
      </view>

      <view wx:if="{{dateMode === 'production'}}" class="date-method">
        <view class="date-method-title">方式一：生产日期 + 保质期</view>
        <view class="selected-date-row" data-target="production" bindtap="openDatePicker">
          <text>生产日期</text>
          <view class="selected-date-value {{form.productionDate ? 'active' : ''}}">
            <text>{{form.productionDate || '点这里选择'}}</text>
            <text class="date-arrow">›</text>
          </view>
        </view>
        <input class="input {{errors.shelfLifeDays ? 'input-error' : ''}}" type="number" value="{{form.shelfLifeDays}}" placeholder="填写保质期天数，例如 7、30、180" bindinput="handleShelfLifeInput" />
        <view class="date-result {{form.expireDate ? 'active' : ''}}">
          {{form.productionDate && form.shelfLifeDays && form.expireDate ? '自动生成过期日：' + form.expireDate : '填写后会自动生成过期日期'}}
        </view>
        <text wx:if="{{errors.shelfLifeDays}}" class="field-error">{{errors.shelfLifeDays}}</text>
      </view>

      <view wx:else class="date-method {{errors.expireDate ? 'date-method-error' : ''}}">
        <view class="date-method-title">方式二：直接选择过期日</view>
        <view class="selected-date-row {{errors.expireDate ? 'input-error' : ''}}" data-target="expire" bindtap="openDatePicker">
          <text>过期日期</text>
          <view class="selected-date-value {{form.expireDate ? 'active' : ''}}">
            <text>{{form.expireDate || '点这里选择'}}</text>
            <text class="date-arrow">›</text>
          </view>
        </view>

        <text wx:if="{{errors.expireDate}}" class="field-error">{{errors.expireDate}}</text>
      </view>
    </view>

    <view class="field">
      <text class="field-label">备注</text>
      <textarea class="textarea" value="{{form.note}}" placeholder="例如：开封后尽快吃完" data-field="note" bindinput="handleInput" />
    </view>

    <button class="primary-button" loading="{{saving}}" bindtap="handleSubmit">
      {{isEdit ? '保存修改' : '保存食品'}}
    </button>
  </view>

  <view wx:if="{{datePickerVisible}}" class="date-popup-mask" bindtap="closeDatePicker">
    <view class="date-popup" catchtap="stopDatePickerClose">
      <view class="date-popup-head">
        <text class="date-popup-title">{{datePickerTarget === 'production' ? '选择生产日期' : '选择过期日期'}}</text>
      </view>

      <view class="calendar-panel">
        <view class="calendar-month-row">
          <button class="calendar-nav" bindtap="handlePrevCalendarMonth">上月</button>
          <text class="calendar-title">{{calendarTitle}}</text>
          <button class="calendar-nav" bindtap="handleNextCalendarMonth">下月</button>
        </view>
        <view class="calendar-week-grid">
          <text wx:for="{{weekLabels}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="calendar-day-grid">
          <button
            wx:for="{{calendarDays}}"
            wx:key="date"
            class="calendar-day {{item.inCurrentMonth ? '' : 'muted'}} {{item.selected ? 'selected' : ''}}"
            data-date="{{item.date}}"
            bindtap="handleSelectCalendarDate"
          >
            {{item.day}}
          </button>
        </view>
      </view>
    </view>
  </view>
</view>
