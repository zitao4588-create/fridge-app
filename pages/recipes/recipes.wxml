<view class="page recipes-page">
  <view class="page-title">今天吃什么</view>
  <view class="page-subtitle">优先使用 3 天内过期食品，没有临期食品时按库存推荐。</view>

  <view wx:if="{{loading}}" class="empty card">正在生成推荐</view>
  <view wx:elif="{{recommendations.length === 0}}" class="empty card">暂无可推荐菜谱，先添加一些未过期食品。</view>

  <view wx:else class="recipe-list">
    <view class="recipe-card card" wx:for="{{recommendations}}" wx:key="id">
      <view class="recipe-head">
        <view>
          <text class="recipe-label">推荐 {{index + 1}}</text>
          <text class="recipe-title">{{item.title}}</text>
        </view>
      </view>

      <view class="used-list">
        <text class="used-chip" wx:for="{{item.usedItems}}" wx:for-item="food" wx:key="_id">
          {{food.name}}{{food.quantity}}{{food.unit}}
        </text>
      </view>

      <view class="steps-box">
        <text class="steps-title">简单做法</text>
        <text class="step-line" wx:for="{{item.steps}}" wx:for-item="step" wx:key="*this">
          {{index + 1}}. {{step}}
        </text>
      </view>

      <text class="reason">{{item.reason}}</text>
    </view>
  </view>
</view>

