.recipes-page {
  padding-bottom: 72rpx;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 12% 4%, rgba(221, 248, 232, 0.78), rgba(221, 248, 232, 0) 260rpx),
    radial-gradient(circle at 88% 12%, rgba(255, 240, 210, 0.82), rgba(255, 240, 210, 0) 260rpx),
    linear-gradient(180deg, #f7fff6 0%, #fff8ea 58%, #ffffff 100%);
}

.tips-card {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.12);
  border-radius: 42rpx;
  background:
    linear-gradient(135deg, rgba(221, 248, 232, 0.9) 0%, rgba(255, 248, 236, 0.96) 48%, rgba(237, 249, 255, 0.9) 100%);
  box-shadow: var(--shadow-card, 0 12rpx 32rpx rgba(80, 130, 100, 0.14));
}

.tips-card::after {
  content: "";
  position: absolute;
  right: -42rpx;
  top: -50rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 999rpx;
  background: rgba(255, 184, 77, 0.16);
}

.tips-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.tips-avatar {
  width: 94rpx;
  height: 94rpx;
  flex-shrink: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: repeat(2, 1fr);
  align-items: center;
  justify-content: center;
  justify-items: center;
  border: 3rpx solid rgba(36, 169, 107, 0.16);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #e8fff2 0%, #c5f4dc 100%);
  color: var(--color-primary-deep, #1f9f73);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
  text-align: center;
  box-shadow:
    inset 0 3rpx 8rpx rgba(255, 255, 255, 0.9),
    0 8rpx 18rpx rgba(88, 201, 139, 0.18);
}

.tips-avatar text {
  line-height: 1;
}

.tips-main {
  flex: 1;
  min-width: 0;
}

.tips-text {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.55;
}

.tips-meta-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 22rpx;
}

.tips-meta-item {
  min-height: 92rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: inset 0 -4rpx 10rpx rgba(100, 181, 246, 0.06);
}

.tips-meta-value {
  color: var(--color-text-title, #24352f);
  font-size: 24rpx;
  font-weight: 900;
}

.tips-meta-name {
  margin-top: 6rpx;
  color: var(--color-text-sub, #778781);
  font-size: 20rpx;
  font-weight: 700;
}

.guide-button-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 18rpx;
}

.guide-button {
  position: relative;
  overflow: hidden;
  min-height: 124rpx;
  padding: 22rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.1);
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fff6 100%);
  box-shadow: 0 12rpx 30rpx rgba(80, 130, 100, 0.1);
}

.guide-button::after {
  content: "";
  position: absolute;
  right: 16rpx;
  bottom: 14rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 999rpx;
  background: rgba(88, 201, 139, 0.12);
}

.guide-button::before {
  content: "";
  position: absolute;
  right: 30rpx;
  top: 28rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 184, 77, 0.34);
  box-shadow: -18rpx 24rpx 0 rgba(88, 201, 139, 0.2);
}

.guide-button.active {
  border-color: rgba(88, 201, 139, 0.32);
  background: linear-gradient(180deg, #ffffff 0%, #def7e9 100%);
  box-shadow: 0 12rpx 28rpx rgba(88, 201, 139, 0.2);
}

.guide-button-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.guide-button-desc {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guide-panel {
  margin-top: 22rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.12);
  border-radius: 42rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  box-shadow: var(--shadow-card, 0 12rpx 32rpx rgba(80, 130, 100, 0.14));
}

.guide-panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.guide-panel-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 32rpx;
  font-weight: 900;
}

.guide-panel-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  line-height: 1.45;
}

.guide-clear {
  flex-shrink: 0;
  color: var(--color-primary-deep, #1f9f73);
  font-size: 24rpx;
  font-weight: 800;
}

.guide-selected {
  margin-top: 18rpx;
  padding: 16rpx;
  border: 2rpx solid rgba(100, 181, 246, 0.12);
  border-radius: 24rpx;
  background: rgba(237, 249, 255, 0.72);
}

.guide-selected-label {
  display: block;
  color: var(--color-text-sub, #778781);
  font-size: 22rpx;
  font-weight: 800;
}

.chip-row.compact {
  margin-top: 10rpx;
}

.ai-recipe-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(255, 184, 77, 0.12);
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(120, 92, 60, 0.07);
}

.recipe-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.recipe-title-group {
  min-width: 0;
  flex: 1;
}

.recipe-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.2;
}

.match-pill {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: var(--color-orange-light, #fff0d6);
  color: #c46d17;
  font-size: 22rpx;
  font-weight: 800;
}

.match-pill.ready {
  background: var(--color-mint, #def7e9);
  color: var(--color-primary-deep, #1f9f73);
}

.match-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.match-box {
  min-height: 138rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.08);
  border-radius: 24rpx;
  background: #f7fff6;
}

.match-box.missing {
  border-color: rgba(255, 184, 77, 0.12);
  background: #fff8ea;
}

.match-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 24rpx;
  font-weight: 800;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.food-chip,
.empty-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: var(--color-primary-deep, #1f9f73);
  font-size: 22rpx;
  font-weight: 800;
}

.food-chip.selected {
  background: var(--color-mint, #def7e9);
}

.food-chip.missing {
  background: var(--color-orange-light, #fff0d6);
  color: #c46d17;
}

.empty-chip {
  color: var(--color-text-light, #a5b1ad);
}

.priority-line {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fff9ea 0%, #fff0d6 100%);
  color: #8a6a2f;
  font-size: 24rpx;
  line-height: 1.5;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.meta-row text {
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(237, 249, 255, 0.9);
  color: #3a91b6;
  font-size: 22rpx;
  font-weight: 800;
}

.recipe-reason-box {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(88, 201, 139, 0.1);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7fff6 0%, #ffffff 100%);
}

.recipe-reason-title,
.recipe-reason-text {
  display: block;
}

.recipe-reason-title {
  color: var(--color-primary-deep, #1f9f73);
  font-size: 23rpx;
  font-weight: 900;
}

.recipe-reason-text {
  margin-top: 8rpx;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
  line-height: 1.55;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 40;
  background: rgba(31, 45, 42, 0.38);
  backdrop-filter: blur(8rpx);
}

.recipe-detail {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 42rpx;
  max-height: 78vh;
  padding: 26rpx;
  overflow-y: auto;
  border: 2rpx solid rgba(88, 201, 139, 0.12);
  border-radius: 42rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  box-shadow: 0 18rpx 54rpx rgba(31, 45, 42, 0.18);
}

.modal-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.modal-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f7fff6;
  color: var(--color-primary-deep, #1f9f73);
  font-size: 40rpx;
  line-height: 1;
}

.detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.detail-meta text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--color-mint, #def7e9);
  color: var(--color-primary-deep, #1f9f73);
  font-size: 23rpx;
  font-weight: 800;
}

.detail-section {
  margin-top: 24rpx;
}

.detail-title {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 27rpx;
  font-weight: 900;
}

.detail-reason {
  display: block;
  margin-top: 10rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #f7fff6;
  color: var(--color-text-sub, #778781);
  font-size: 25rpx;
  line-height: 1.55;
}

.step-line {
  display: block;
  margin-top: 10rpx;
  color: var(--color-text-sub, #778781);
  font-size: 25rpx;
  line-height: 1.6;
}

.safety-note {
  display: block;
  margin-top: 22rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(255, 107, 107, 0.12);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fff8f6 0%, #ffe7e3 100%);
  color: var(--color-expired, #ff7d73);
  font-size: 24rpx;
  line-height: 1.55;
}

.picker-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 82vh;
  padding: 30rpx 28rpx calc(30rpx + env(safe-area-inset-bottom));
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  overflow-y: auto;
  border: 2rpx solid rgba(88, 201, 139, 0.12);
  background: linear-gradient(180deg, #ffffff 0%, #fff8ea 100%);
  box-shadow: 0 -14rpx 44rpx rgba(31, 45, 42, 0.14);
}

.picker-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--color-text-sub, #778781);
  font-size: 24rpx;
}

.picker-empty {
  margin-top: 28rpx;
  padding: 36rpx;
  border: 2rpx dashed rgba(88, 201, 139, 0.2);
  border-radius: 28rpx;
  background: #ffffff;
  color: var(--color-text-sub, #778781);
  text-align: center;
}

.picker-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 24rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(100, 181, 246, 0.1);
  border-radius: 24rpx;
  background: #ffffff;
}

.picker-item.selected {
  border-color: rgba(88, 201, 139, 0.3);
  background: var(--color-mint, #def7e9);
}

.picker-item.disabled {
  opacity: 0.58;
}

.picker-name {
  display: block;
  color: var(--color-text-title, #24352f);
  font-size: 28rpx;
  font-weight: 900;
}

.picker-meta {
  display: block;
  margin-top: 7rpx;
  color: var(--color-text-sub, #778781);
  font-size: 23rpx;
}

.status-chip {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 800;
}

.picker-actions {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.picker-button {
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.picker-button.secondary {
  border: 2rpx solid rgba(88, 201, 139, 0.18);
  background: #ffffff;
  color: var(--color-primary-deep, #1f9f73);
}

.picker-button.primary {
  background: linear-gradient(180deg, #73dda0 0%, #35ba78 100%);
  color: #ffffff;
  box-shadow: var(--shadow-button, 0 8rpx 18rpx rgba(88, 201, 139, 0.28));
}
