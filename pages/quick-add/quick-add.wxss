.mock-notice {
  margin-top: 28rpx;
  padding: 22rpx 24rpx;
  border-color: #fde68a;
  background: #fffbeb;
}

.mock-title {
  display: block;
  color: #92400e;
  font-size: 28rpx;
  font-weight: 700;
}

.mock-desc {
  display: block;
  margin-top: 10rpx;
  color: #a16207;
  font-size: 25rpx;
  line-height: 1.6;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 36rpx;
}

.entry-card {
  width: 100%;
  min-height: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 28rpx;
  text-align: left;
  color: #0f172a;
}

.entry-title {
  font-size: 34rpx;
  font-weight: 700;
}

.entry-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #64748b;
}
