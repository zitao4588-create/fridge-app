<view class="page quick-page">
  <view class="quick-hero card">
    <view class="quick-hero-copy">
      <view class="page-title">智能录入</view>
      <view class="page-subtitle">不确定分区时，可以先识别，再按推荐分区保存。</view>
    </view>
    <view class="quick-hero-fridge">
      <view class="quick-hero-face"></view>
    </view>
  </view>

  <view class="entry-list">
    <button class="entry-card card manual" bindtap="handleManualSmart">
      <view class="entry-icon manual"></view>
      <view class="entry-copy">
        <text class="entry-kicker">只知道名称</text>
        <text class="entry-title">手动输入</text>
        <text class="entry-desc">输入名称和品类后，帮你推荐分区</text>
      </view>
      <view class="entry-arrow">›</view>
    </button>

    <button class="entry-card card food" bindtap="handleFoodPhoto">
      <view class="entry-icon food"></view>
      <view class="entry-copy">
        <text class="entry-kicker">单个食品</text>
        <text class="entry-title">拍食品</text>
        <text class="entry-desc">识别食品本身，自动给出推荐分区</text>
      </view>
      <view class="entry-arrow">›</view>
    </button>

    <button class="entry-card card package" bindtap="handlePackagePhoto">
      <view class="entry-icon package"></view>
      <view class="entry-copy">
        <text class="entry-kicker">包装信息</text>
        <text class="entry-title">拍包装</text>
        <text class="entry-desc">识别包装说明文字，提取名称和保质期</text>
      </view>
      <view class="entry-arrow">›</view>
    </button>

    <button class="entry-card card receipt" bindtap="handleReceiptPhoto">
      <view class="entry-icon receipt"></view>
      <view class="entry-copy">
        <text class="entry-kicker">批量添加</text>
        <text class="entry-title">拍购物小票</text>
        <text class="entry-desc">识别多条食品，逐个确认分区后保存</text>
      </view>
      <view class="entry-arrow">›</view>
    </button>
  </view>
</view>
