.form-page {
  padding: 24rpx 28rpx 64rpx;
}

.form-card {
  padding: 28rpx 24rpx 32rpx;
  border-radius: 28rpx;
  background: var(--cream-surface, #fffef8);
  border: 2rpx solid var(--cream-line, #eadbc4);
  box-shadow: var(--shadow-soft, 0 10rpx 22rpx rgba(135, 105, 64, 0.08));
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main, #253730);
}

.field-error {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--coral-deep, #c94238);
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 12rpx 26rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--text-sub, #6f7c74);
  background: var(--cream-bg, #fff6e8);
  border: 2rpx solid var(--cream-line, #eadbc4);
}

.chip.active {
  color: var(--brand-mint-deep, #087a49);
  background: var(--brand-mint-soft, #eaf8ee);
  border-color: var(--brand-mint, #28b978);
  font-weight: 700;
}

.seg {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.seg-item {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-sub, #6f7c74);
  background: var(--cream-bg, #fff6e8);
}

.seg-item.active {
  color: #ffffff;
  background: var(--brand-mint, #28b978);
}

.shelf-input {
  margin-top: 20rpx;
}

.date-result {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-light, #9aa9a1);
}

.date-result.active {
  color: var(--brand-mint-deep, #087a49);
}

.recommend {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 16rpx 22rpx;
  border-radius: 20rpx;
  background: var(--brand-mint-soft, #eaf8ee);
}

.recommend-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--brand-mint-deep, #087a49);
}

.submit-btn {
  margin-top: 12rpx;
}
