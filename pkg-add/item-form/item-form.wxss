.form-page {
  padding: 24rpx 28rpx 64rpx;
}

.form-card {
  padding: 30rpx 24rpx 34rpx;
  border-radius: 34rpx;
  background: var(--grad-card);
  box-shadow: var(--shadow-1), var(--hi-inset);
}

.field {
  margin-bottom: 30rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main, #253730);
}

.field-error {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--coral-deep, #c94238);
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--text-sub, #5c6a62);
  background: var(--cream-bg, #fff6e8);
  border: 2rpx solid var(--cream-line, #eadbc4);
}

.chip.active {
  color: #ffffff;
  background: var(--grad-mint);
  border-color: transparent;
  font-weight: 700;
  box-shadow: var(--shadow-mint), var(--hi-inset);
}

.seg {
  display: flex;
  gap: 12rpx;
  margin-bottom: 22rpx;
  padding: 6rpx;
  border-radius: 18rpx;
  background: var(--cream-bg, #fff6e8);
}

.seg-item {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-sub, #6f7c74);
}

.seg-item.active {
  color: #ffffff;
  background: var(--grad-mint);
  box-shadow: var(--shadow-mint), var(--hi-inset);
}

.shelf-input {
  margin-top: 20rpx;
}

.date-result {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-light, #647264);
}

.date-result.active {
  color: var(--brand-mint-deep, #087a49);
}

.recommend {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: var(--brand-mint-soft, #eaf8ee);
  box-shadow: var(--hi-inset);
}

.recommend-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--brand-mint-deep, #087a49);
}

.submit-btn {
  margin-top: 16rpx;
}
