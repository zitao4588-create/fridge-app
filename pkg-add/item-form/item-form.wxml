<view class="page form-page">
  <view class="form-card">
    <view class="field">
      <text class="field-label">食品名称</text>
      <t-input
        value="{{form.name}}"
        placeholder="例如：牛奶、鸡蛋、菠菜"
        maxlength="30"
        bindchange="handleNameInput"
      />
      <text wx:if="{{errors.name}}" class="field-error">{{errors.name}}</text>
    </view>

    <view class="field">
      <text class="field-label">品类</text>
      <view class="chip-row">
        <view
          wx:for="{{categoryOptions}}"
          wx:key="*this"
          class="chip {{form.category === item ? 'active' : ''}}"
          data-index="{{index}}"
          bindtap="handleCategoryTap"
        >{{item}}</view>
      </view>
    </view>

    <view class="field">
      <text class="field-label">存放分区</text>
      <view class="chip-row">
        <view
          wx:for="{{locationOptions}}"
          wx:key="*this"
          class="chip {{form.storageLocation === item ? 'active' : ''}}"
          data-index="{{index}}"
          bindtap="handleLocationTap"
        >{{item}}</view>
      </view>
      <view wx:if="{{showLocationRecommend}}" class="recommend">
        <text class="recommend-text">推荐放「{{recommendedStorageLocation}}」（当前：{{form.storageLocation}}）</text>
        <t-button size="extra-small" theme="primary" variant="outline" bindtap="handleApplyRecommendedLocation">采纳</t-button>
      </view>
    </view>

    <view class="field">
      <text class="field-label">过期日期</text>
      <view class="seg">
        <view class="seg-item {{dateMode === 'production' ? 'active' : ''}}" data-mode="production" bindtap="handleDateModeTap">生产日 + 保质期</view>
        <view class="seg-item {{dateMode === 'expire' ? 'active' : ''}}" data-mode="expire" bindtap="handleDateModeTap">直接选过期日</view>
      </view>

      <block wx:if="{{dateMode === 'production'}}">
        <t-cell title="生产日期" note="{{form.productionDate || '点此选择'}}" arrow hover data-target="production" bindtap="openDatePicker" />
        <view class="shelf-input">
          <t-input
            type="number"
            value="{{form.shelfLifeDays}}"
            placeholder="保质期天数，例如 7 / 30 / 180"
            bindchange="handleShelfLifeInput"
          />
        </view>
        <text class="date-result {{form.expireDate ? 'active' : ''}}">{{form.productionDate && form.shelfLifeDays && form.expireDate ? '自动生成过期日：' + form.expireDate : '填写后自动生成过期日'}}</text>
        <text wx:if="{{errors.shelfLifeDays}}" class="field-error">{{errors.shelfLifeDays}}</text>
      </block>

      <block wx:else>
        <t-cell title="过期日期" note="{{form.expireDate || '点此选择'}}" arrow hover data-target="expire" bindtap="openDatePicker" />
      </block>

      <text wx:if="{{errors.expireDate}}" class="field-error">{{errors.expireDate}}</text>
    </view>

    <view class="field">
      <text class="field-label">备注</text>
      <t-textarea
        value="{{form.note}}"
        placeholder="例如：开封后尽快吃完"
        maxlength="100"
        bindchange="handleNoteInput"
      />
    </view>

    <t-button class="submit-btn" theme="primary" size="large" block loading="{{saving}}" bindtap="handleSubmit">
      {{isEdit ? '保存修改' : '保存食品'}}
    </t-button>
  </view>

  <t-date-time-picker
    visible="{{datePickerVisible}}"
    mode="date"
    value="{{datePickerValue}}"
    format="YYYY-MM-DD"
    title="{{datePickerTarget === 'production' ? '选择生产日期' : '选择过期日期'}}"
    start="2018-01-01"
    end="2035-12-31"
    usePopup
    bindconfirm="handleDateConfirm"
    bindcancel="handleDateCancel"
  />
</view>
